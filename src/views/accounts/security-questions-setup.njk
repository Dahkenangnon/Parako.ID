{% extends "layouts/account-layout.njk" %}
{% block account_content %}
    <div class="space-y-6">
        <!-- Back to Settings Link -->
        <a href="{{ routes.accountFull.settings_recovery }}" class="inline-flex items-center text-sm text-muted-foreground hover:text-foreground transition-colors">
            <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            {{ t('common.back_to_settings', 'Back to Settings') }}
        </a>

        <!-- Header -->
        <div>
            <h2 class="text-lg font-semibold text-foreground mb-2 flex items-center">
                <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                {{ t('security-questions.title') }}
            </h2>
            <p class="text-sm text-muted-foreground max-w-3xl">{{ t('security-questions.description') }}</p>
        </div>

        <!-- Security Questions Form -->
        <div class="bg-background border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4">{{ t('security-questions.setup.title') }}</h2>
            <p class="text-muted-foreground mb-6">{{ t('security-questions.setup.select_questions', { count: 3 }) }}</p>
            <p class="text-sm text-muted-foreground mb-6">{{ t('security-questions.setup.instruction') }}</p>

            <form action="{{ routes.accountFull.security_questions_setup }}" method="POST" class="space-y-6" id="security-questions-form">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>

                <!-- Question 1 -->
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-foreground">Question 1 *</label>
                    <select name="question_1" id="question_1" class="w-full px-3 py-2.5 border border-input text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-ring" required>
                        <option value="">{{ t('security-questions.setup.select_question') if t('security-questions.setup.select_question') else 'Select a question...' }}</option>
                        {% for key in availableQuestionKeys %}
                            <option value="{{ key }}" {% if existingQuestions | length > 0 and existingQuestions[0] and existingQuestions[0].question_key == key %}selected{% endif %}>
                                {{ t('security-questions.questions.' + key) }}
                            </option>
                        {% endfor %}
                    </select>
                    <input type="text" name="answer_1" id="answer_1"
                        placeholder="{{ t('security-questions.setup.answer_placeholder') }}"
                        class="w-full px-3 py-2.5 border border-input text-sm font-mono bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-ring"
                        minlength="3" required/>
                </div>

                <!-- Question 2 -->
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-foreground">Question 2 *</label>
                    <select name="question_2" id="question_2" class="w-full px-3 py-2.5 border border-input text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-ring" required>
                        <option value="">{{ t('security-questions.setup.select_question') if t('security-questions.setup.select_question') else 'Select a question...' }}</option>
                        {% for key in availableQuestionKeys %}
                            <option value="{{ key }}" {% if existingQuestions | length > 1 and existingQuestions[1] and existingQuestions[1].question_key == key %}selected{% endif %}>
                                {{ t('security-questions.questions.' + key) }}
                            </option>
                        {% endfor %}
                    </select>
                    <input type="text" name="answer_2" id="answer_2"
                        placeholder="{{ t('security-questions.setup.answer_placeholder') }}"
                        class="w-full px-3 py-2.5 border border-input text-sm font-mono bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-ring"
                        minlength="3" required/>
                </div>

                <!-- Question 3 -->
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-foreground">Question 3 *</label>
                    <select name="question_3" id="question_3" class="w-full px-3 py-2.5 border border-input text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-ring" required>
                        <option value="">{{ t('security-questions.setup.select_question') if t('security-questions.setup.select_question') else 'Select a question...' }}</option>
                        {% for key in availableQuestionKeys %}
                            <option value="{{ key }}" {% if existingQuestions | length > 2 and existingQuestions[2] and existingQuestions[2].question_key == key %}selected{% endif %}>
                                {{ t('security-questions.questions.' + key) }}
                            </option>
                        {% endfor %}
                    </select>
                    <input type="text" name="answer_3" id="answer_3"
                        placeholder="{{ t('security-questions.setup.answer_placeholder') }}"
                        class="w-full px-3 py-2.5 border border-input text-sm font-mono bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-ring"
                        minlength="3" required/>
                </div>

                <!-- Validation messages area -->
                <div id="validation-errors" class="hidden p-4 bg-destructive/10 border border-destructive/20 text-destructive text-sm"></div>

                <!-- Submit Button -->
                <div class="flex justify-center pt-4">
                    <button
                        type="submit"
                        class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-sm font-medium
                            text-primary-foreground bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring transition-colors">
                        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824
                                    10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                        {{ t('security-questions.setup.save') }}
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Client-side validation to prevent duplicate questions
        document.getElementById('security-questions-form').addEventListener('submit', function(e) {
            const q1 = document.getElementById('question_1').value;
            const q2 = document.getElementById('question_2').value;
            const q3 = document.getElementById('question_3').value;

            const questions = [q1, q2, q3].filter(q => q !== '');
            const uniqueQuestions = new Set(questions);

            if (uniqueQuestions.size !== questions.length) {
                e.preventDefault();
                const errorDiv = document.getElementById('validation-errors');
                errorDiv.textContent = '{{ t("security-questions.validation.select_different_questions") if t("security-questions.validation.select_different_questions") else "Please select different questions for each." }}';
                errorDiv.classList.remove('hidden');
                return false;
            }

            // Hide any previous errors
            document.getElementById('validation-errors').classList.add('hidden');
        });
    </script>
{% endblock %}