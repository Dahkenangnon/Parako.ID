{% extends "layouts/account-layout.njk" %}
{% block account_content %}
    <div class="space-y-6">
        <!-- Back to Settings Link -->
        <a href="{{ routes.accountFull.settings_recovery }}" class="inline-flex items-center text-sm text-muted-foreground hover:text-foreground transition-colors">
            <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            {{ t('common.back_to_settings', 'Back to Settings') }}
        </a>

        <!-- Header -->
        <div>
            <h2 class="text-lg font-semibold text-foreground mb-2 flex items-center">
                <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                {{ t('account-recovery-setup.title') }}
            </h2>
            {% set mfaMethod = t('account-recovery-setup.method_email') if pageUser.mfa and pageUser.mfa.method == 'email' else t('account-recovery-setup.method_app') %}
            <p class="text-sm text-muted-foreground max-w-3xl">{{ t('account-recovery-setup.subtitle', { method: mfaMethod }) }}</p>
        </div>

        <!-- Recovery Setup Form -->
        <div class="bg-background border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4">{{ t('account-recovery-setup.setup_recovery.title') }}</h2>
            <p class="text-muted-foreground mb-6">{{ t('account-recovery-setup.setup_recovery.description') }}</p>
            <form action="{{ routes.accountFull.enable_recovery }}" method="POST" class="space-y-6">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                <input type="hidden" name="source" value="recovery_setup"/>
                <!-- Backup Codes Info -->
                <div class="bg-primary/10 border border-primary/20 p-4">
                    <div class="flex items-start">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-primary mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                            </svg>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-foreground">{{ t('account-recovery-setup.backup_codes.title') }}</h3>
                            <p class="text-sm text-muted-foreground mt-1">
                                {% set recoveryMethod = t('account-recovery-setup.backup_codes.method_email_account') if pageUser.mfa and pageUser.mfa.method == 'email' else t('account-recovery-setup.method_app') %}
                                {{ t('account-recovery-setup.backup_codes.description', { method: recoveryMethod }) }}
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Secondary Email (Optional) -->
                <div>
                    <label for="secondary-email" class="block text-sm font-medium text-foreground mb-2">
                        {{ t('account-recovery-setup.backup_email.label') }}
                    </label>
                    <input type="email" id="secondary-email" name="email" placeholder="{{ t('account-recovery-setup.backup_email.placeholder') }}" class="w-full px-3 py-2.5 border border-input text-sm font-mono bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-ring"/>
                    <p class="text-xs text-muted-foreground mt-2">
                        {{ t('account-recovery-setup.backup_email.help_text') }}
                    </p>
                </div>
                <!-- Submit Button -->
                <div class="flex justify-center">
                    <button
                        type="submit"
                        class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-sm font-medium
                            text-primary-foreground bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring transition-colors">
                        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824
                                    10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                        {{ t('account-recovery-setup.button.submit') }}
                    </button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}