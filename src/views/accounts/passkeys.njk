{% extends "layouts/account-layout.njk" %}
{% block account_content %}
<div class="space-y-6">
    <!-- Back to Settings Link -->
    <a href="{{ routes.accountFull.settings_security }}" class="inline-flex items-center text-sm text-muted-foreground hover:text-foreground transition-colors">
        <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        {{ t('common.back_to_settings', 'Back to Settings') }}
    </a>

    <!-- Header Section -->
    <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h2 class="text-lg font-semibold text-foreground mb-2 flex items-center">
                    <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                    </svg>
                    {{ t('account-passkeys.title', 'Passkeys') }}
                </h2>
                <p class="text-sm text-muted-foreground max-w-3xl">
                    {{ t('account-passkeys.description', 'Manage your passkeys for secure, passwordless authentication. Passkeys use biometrics like Touch ID or Face ID, or security keys like YubiKey.') }}
                </p>
            </div>
            <button type="button" id="add-passkey-btn"
                    class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium
                           text-white bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring transition-colors
                           w-full sm:w-auto">
                <svg class="h-4 w-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                <span>{{ t('account-passkeys.add_button', 'Add Passkey') }}</span>
            </button>
        </div>
    </div>

    <!-- Status Message -->
    <div id="passkeys-status" class="hidden p-4 border-2" role="alert"></div>

    <!-- Passkeys Container -->
    <div class="bg-card border border-border overflow-hidden">
        <!-- Loading State -->
        <div id="passkeys-loading" class="p-8 text-center">
            <svg class="animate-spin h-8 w-8 mx-auto text-primary" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <p class="mt-2 text-sm text-muted-foreground">{{ t('account-passkeys.loading', 'Loading passkeys...') }}</p>
        </div>

        <!-- Empty State -->
        <div id="passkeys-empty" class="hidden p-8 text-center">
            <div class="flex justify-center mb-4">
                <div class="bg-muted p-4 rounded-full">
                    <svg class="h-8 w-8 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                    </svg>
                </div>
            </div>
            <h3 class="text-lg font-medium text-foreground mb-2">{{ t('account-passkeys.empty.title', 'No Passkeys Yet') }}</h3>
            <p class="text-sm text-muted-foreground mb-4 max-w-md mx-auto">
                {{ t('account-passkeys.empty.description', 'Add a passkey to use Touch ID, Face ID, Windows Hello, or a security key for faster, more secure sign-in.') }}
            </p>
            <button type="button" id="add-passkey-btn-empty"
                    class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium
                           text-white bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring transition-colors">
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                {{ t('account-passkeys.add_button', 'Add Passkey') }}
            </button>
        </div>

        <!-- Passkeys List -->
        <div id="passkeys-list" class="hidden divide-y divide-border">
            <!-- Passkeys will be dynamically inserted here -->
        </div>
    </div>

    <!-- Info Box -->
    <div class="p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800">
        <div class="flex">
            <svg class="h-5 w-5 text-blue-500 dark:text-blue-400 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div class="text-sm text-blue-800 dark:text-blue-200">
                <p class="font-medium mb-1">{{ t('account-passkeys.info.title', 'About Passkeys') }}</p>
                <ul class="list-disc list-inside space-y-1 text-xs">
                    <li>{{ t('account-passkeys.info.point1', 'Passkeys are more secure than passwords and protect against phishing') }}</li>
                    <li>{{ t('account-passkeys.info.point2', 'They work across devices synced with your iCloud, Google, or Microsoft account') }}</li>
                    <li>{{ t('account-passkeys.info.point3', 'You can have multiple passkeys for different devices') }}</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Rename Modal Template -->
<template id="rename-modal-template">
    <div class="fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:p-0">
            <!-- Background overlay -->
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75 transition-opacity" aria-hidden="true"></div>

            <!-- Modal panel -->
            <div class="relative inline-block bg-white dark:bg-card border border-gray-200 dark:border-border text-left overflow-hidden shadow-xl transform transition-all sm:max-w-lg sm:w-full">
                <div class="px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <div class="sm:flex sm:items-start">
                        <div class="mt-3 text-center sm:mt-0 sm:text-left w-full">
                            <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-foreground" id="modal-title">
                                {{ t('account-passkeys.rename.title', 'Rename Passkey') }}
                            </h3>
                            <div class="mt-4">
                                <label for="new-passkey-name" class="block text-sm font-medium text-gray-700 dark:text-muted-foreground mb-2">
                                    {{ t('account-passkeys.rename.label', 'Passkey Name') }}
                                </label>
                                <input type="text" id="new-passkey-name" name="new-passkey-name"
                                       class="w-full px-3 py-2 bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-900 dark:text-foreground focus:outline-none focus:border-primary"
                                       placeholder="{{ t('account-passkeys.rename.placeholder', 'e.g., MacBook Touch ID') }}" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 dark:bg-muted px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                    <button type="button" id="rename-confirm-btn"
                            class="w-full inline-flex justify-center px-4 py-2 bg-primary text-white font-medium border border-transparent focus:outline-none focus:ring-2 focus:ring-primary sm:ml-3 sm:w-auto sm:text-sm">
                        {{ t('account-passkeys.rename.confirm', 'Save') }}
                    </button>
                    <button type="button" id="rename-cancel-btn"
                            class="mt-3 w-full inline-flex justify-center px-4 py-2 bg-white dark:bg-card text-gray-700 dark:text-foreground font-medium border border-gray-300 dark:border-border focus:outline-none focus:ring-2 focus:ring-gray-500 sm:mt-0 sm:w-auto sm:text-sm">
                        {{ t('account-passkeys.rename.cancel', 'Cancel') }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</template>

<!-- Passkey Item Template -->
<template id="passkey-item-template">
    <div class="passkey-item flex items-center justify-between p-4 hover:bg-muted/50 transition-colors" data-credential-id="">
        <div class="flex items-center space-x-4">
            <div class="flex-shrink-0">
                <div class="passkey-icon bg-primary/10 p-2 rounded">
                    <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"></path>
                    </svg>
                </div>
            </div>
            <div>
                <div class="passkey-name text-sm font-medium text-foreground">Passkey Name</div>
                <div class="flex items-center space-x-2 text-xs text-muted-foreground">
                    <span class="passkey-device">Device Type</span>
                    <span>-</span>
                    <span class="passkey-created">Created Date</span>
                </div>
                <div class="passkey-last-used text-xs text-muted-foreground mt-1"></div>
            </div>
        </div>
        <div class="flex items-center space-x-2">
            <button type="button" class="passkey-rename-btn p-2 text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
                    title="{{ t('account-passkeys.actions.rename', 'Rename') }}">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
            </button>
            <button type="button" class="passkey-delete-btn p-2 text-muted-foreground hover:text-destructive hover:bg-destructive/10 transition-colors"
                    title="{{ t('account-passkeys.actions.delete', 'Delete') }}">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
            </button>
        </div>
    </div>
</template>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="/js/account/settings/passkeys.js"></script>

<!-- Configuration for Passkeys Management -->
<script id="___PASSKEYS_STATE___" type="application/json">
{
  "config": {
    "apiBasePath": "{{ routes.api }}",
    "credentialsUrl": "{{ routes.api }}/webauthn/credentials",
    "registerUrl": "{{ routes.accountFull.setup_webauthn }}",
    "csrfToken": {{ csrfToken | tojson | safe }},
    "debug": {{ (app.env === 'development') | tojson }}
  },
  "translations": {
    "loading": {{ t('account-passkeys.loading', 'Loading passkeys...') | tojson | safe }},
    "addPasskey": {{ t('account-passkeys.add_button', 'Add Passkey') | tojson | safe }},
    "adding": {{ t('account-passkeys.adding', 'Adding...') | tojson | safe }},
    "rename": {{ t('account-passkeys.actions.rename', 'Rename') | tojson | safe }},
    "delete": {{ t('account-passkeys.actions.delete', 'Delete') | tojson | safe }},
    "deleteConfirmTitle": {{ t('account-passkeys.delete.confirmTitle', 'Delete Passkey') | tojson | safe }},
    "deleteConfirmMessage": {{ t('account-passkeys.delete.confirmMessage', 'Are you sure you want to delete this passkey? This action cannot be undone.') | tojson | safe }},
    "successAdded": {{ t('account-passkeys.success.added', 'Passkey added successfully') | tojson | safe }},
    "successRenamed": {{ t('account-passkeys.success.renamed', 'Passkey renamed successfully') | tojson | safe }},
    "successDeleted": {{ t('account-passkeys.success.deleted', 'Passkey deleted successfully') | tojson | safe }},
    "errorLoading": {{ t('account-passkeys.error.loading', 'Failed to load passkeys') | tojson | safe }},
    "errorAdding": {{ t('account-passkeys.error.adding', 'Failed to add passkey') | tojson | safe }},
    "errorRenaming": {{ t('account-passkeys.error.renaming', 'Failed to rename passkey') | tojson | safe }},
    "errorDeleting": {{ t('account-passkeys.error.deleting', 'Failed to delete passkey') | tojson | safe }},
    "errorNotSupported": {{ t('account-passkeys.error.notSupported', 'Passkeys are not supported in your browser') | tojson | safe }},
    "lastUsed": {{ t('account-passkeys.lastUsed', 'Last used') | tojson | safe }},
    "neverUsed": {{ t('account-passkeys.neverUsed', 'Never used') | tojson | safe }},
    "createdOn": {{ t('account-passkeys.createdOn', 'Created on') | tojson | safe }},
    "platform": {{ t('account-passkeys.deviceType.platform', 'Platform authenticator') | tojson | safe }},
    "crossPlatform": {{ t('account-passkeys.deviceType.crossPlatform', 'Security key') | tojson | safe }},
    "singleDevice": {{ t('account-passkeys.deviceType.singleDevice', 'Single device') | tojson | safe }},
    "multiDevice": {{ t('account-passkeys.deviceType.multiDevice', 'Synced across devices') | tojson | safe }}
  }
}
</script>
{% endblock %}
