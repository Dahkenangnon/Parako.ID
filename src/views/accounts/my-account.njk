{% extends "layouts/account-layout.njk" %}
{% block account_content %}
    <div class="space-y-8">
        <!-- Profile Header -->
        <div class="bg-card">
            <div class="p-8">
                <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
                    <!-- Profile Picture -->
                    <div class="flex-shrink-0">
                        {% if pageUser.picture %}
                            <img src="{{ pageUser.picture }}" alt="{{ pageUser.displayName or pageUser.name or pageUser.given_name }}" class="w-20 h-20 rounded-full object-cover"/>
                        {% else %}
                            <div class="w-20 h-20 rounded-full bg-primary flex items-center justify-center text-primary-foreground text-2xl font-medium">
                                {{ pageUser.initials or ((pageUser.given_name or 'U') | slice(0, 1)) + ((pageUser.family_name or 'S') | slice(0, 1)) }}
                            </div>
                        {% endif %}
                    </div>
                    <!-- User Details -->
                    <div class="flex-1 text-center sm:text-left">
                        <h1 class="text-2xl font-normal tracking-tight text-foreground mb-2">
                            {{ pageUser.given_name or '' }}
                            {{ pageUser.family_name or '' }}
                        </h1>
                        <div class="space-y-1">
                            {% if pageUser.email %}
                                <p class="text-sm text-muted-foreground font-mono">{{ pageUser.email }}</p>
                            {% elif accountData.phone_number %}
                                <p class="text-sm text-muted-foreground font-mono">{{ accountData.phone_number | mask_phone }}</p>
                            {% endif %}
                            {% if lastActivity.formattedTimestamp %}
                                <p class="text-xs text-muted-foreground">
                                    {{ t('account-profile.last_activity') }}: {{ lastActivity.formattedTimestamp }}
                                    {% if lastActivity.description %}
                                        · {{ lastActivity.description }}
                                    {% endif %}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Account Navigation -->
        <div class="bg-card divide-y divide-border">
            <!-- Profile & Preferences -->
            <a href="{{ routes.accountFull.settings_profile }}" class="flex items-center justify-between p-5 hover:bg-muted/50 transition-colors group">
                <div class="flex items-center gap-4">
                    <div class="flex-shrink-0 h-10 w-10 bg-primary/10 flex items-center justify-center rounded-lg">
                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-foreground">{{ t('account-profile.quick_actions.edit_profile.title') }}</p>
                        <p class="text-xs text-muted-foreground">
                            {% if userLocale %}
                                {% set availableLocales = getAvailableLocales() %}
                                {% for localeData in availableLocales %}
                                    {% if localeData.code == userLocale %}
                                        {{ localeData.flag }} {{ localeData.label }}
                                    {% endif %}
                                {% endfor %}
                            {% else %}
                                {{ t('account-profile.security_account.language_default') }}
                            {% endif %}
                        </p>
                    </div>
                </div>
                <svg class="h-4 w-4 text-muted-foreground group-hover:text-foreground transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            </a>

            <!-- Security -->
            <a href="{{ routes.accountFull.settings_security }}" class="flex items-center justify-between p-5 hover:bg-muted/50 transition-colors group">
                <div class="flex items-center gap-4">
                    <div class="flex-shrink-0 h-10 w-10 bg-primary/10 flex items-center justify-center rounded-lg">
                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-foreground">{{ t('account-profile.quick_actions.security_settings.title') }}</p>
                        <p class="text-xs">
                            {% set anyMethodAvailable = mfaConfig and mfaConfig.enabled and (mfaConfig.methods.totp.enabled or mfaConfig.methods.email.enabled or mfaConfig.methods.webauthn.enabled) %}
                            {% if not mfaConfig or not mfaConfig.enabled or not anyMethodAvailable %}
                                <span class="text-muted-foreground">{{ t('account-profile.security_account.two_factor_auth') }}: {{ t('account-profile.security_account.not_available', 'Not Available') }}</span>
                            {% elif pageUser.mfa and pageUser.mfa.enabled %}
                                <span class="text-primary font-medium">{{ t('account-profile.security_account.two_factor_auth') }}: {{ t('account-profile.security_account.enabled') }}</span>
                            {% else %}
                                <span class="text-warning font-medium">{{ t('account-profile.security_account.two_factor_auth') }}: {{ t('account-profile.security_account.not_enabled') }}</span>
                            {% endif %}
                        </p>
                    </div>
                </div>
                <svg class="h-4 w-4 text-muted-foreground group-hover:text-foreground transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            </a>

            <!-- Sessions -->
            <a href="{{ routes.accountFull.sessions }}" class="flex items-center justify-between p-5 hover:bg-muted/50 transition-colors group">
                <div class="flex items-center gap-4">
                    <div class="flex-shrink-0 h-10 w-10 bg-primary/10 flex items-center justify-center rounded-lg">
                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-foreground">{{ t('account-profile.security_account.active_sessions') }}</p>
                        <p class="text-xs text-muted-foreground font-mono">{{ pageUser.activeSessions or '0 devices' }}</p>
                    </div>
                </div>
                <svg class="h-4 w-4 text-muted-foreground group-hover:text-foreground transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            </a>

            <!-- Connected Apps -->
            <a href="{{ routes.accountFull.apps }}" class="flex items-center justify-between p-5 hover:bg-muted/50 transition-colors group">
                <div class="flex items-center gap-4">
                    <div class="flex-shrink-0 h-10 w-10 bg-primary/10 flex items-center justify-center rounded-lg">
                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-foreground">{{ t('account-profile.security_account.connected_apps') }}</p>
                        <p class="text-xs text-muted-foreground font-mono">{{ pageUser.connectedApps or '0 applications' }}</p>
                    </div>
                </div>
                <svg class="h-4 w-4 text-muted-foreground group-hover:text-foreground transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            </a>
        </div>

        <!-- Sign Out -->
        <a href="{{ routes.authFull.logout }}" class="flex items-center justify-center gap-2 p-3 text-sm font-medium text-destructive hover:text-destructive/80 transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
            </svg>
            {{ t('account-profile.quick_actions.sign_out.title') }}
        </a>
    </div>
{% endblock %}