{% extends "layouts/account-layout.njk" %}
{% block account_content %}
    {% include "partials/account-settings-tabs.njk" %}

    <div class="space-y-10">
        <!-- Notification Preferences Settings -->
        {% if notificationConfig and notificationConfig.defaults.allow_user_preferences %}
        <div class="mb-8" id="notifications">
            <div>
                <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                    <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                    </svg>
                    {{ t('account-settings.notifications.title', 'Notification Preferences') }}
                </h2>
                <form action="{{ routes.accountFull.update_notification_preferences }}" method="POST" class="space-y-6">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                    <div class="space-y-4">
                        <!-- Preferred Channel -->
                        <div class="bg-muted/50 p-6">
                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                <div class="flex items-start sm:items-center">
                                    <div class="flex-shrink-0">
                                        <div class="h-10 w-10 bg-primary/10 rounded-full flex items-center justify-center">
                                            <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="ml-4">
                                        <p class="text-sm font-medium text-foreground">{{ t('account-settings.notifications.preferred_channel', 'Preferred notification method') }}</p>
                                        <p class="text-sm text-muted-foreground mt-1">{{ t('account-settings.notifications.preferred_channel_desc', 'Choose how you want to receive notifications') }}</p>
                                    </div>
                                </div>
                                <select name="preferred_channel" id="preferred_channel"
                                    class="appearance-none bg-background border border-border text-sm font-medium text-foreground px-3 py-2 pr-8 focus:outline-none focus:ring-2 focus:ring-ring focus:border-border transition-colors">
                                    <option value="auto" {% if not pageUser.notification_preferences or pageUser.notification_preferences.preferred_channel == 'auto' %}selected{% endif %}>{{ t('account-settings.notifications.channel_auto', 'Automatic') }}</option>
                                    <option value="email" {% if pageUser.notification_preferences and pageUser.notification_preferences.preferred_channel == 'email' %}selected{% endif %}>{{ t('account-settings.notifications.channel_email', 'Email') }}</option>
                                    {% if notificationConfig.channels.sms.enabled %}
                                    <option value="sms" {% if pageUser.notification_preferences and pageUser.notification_preferences.preferred_channel == 'sms' %}selected{% endif %}>{{ t('account-settings.notifications.channel_sms', 'SMS') }}</option>
                                    {% endif %}
                                </select>
                            </div>
                        </div>

                        <!-- Security Alerts Toggle -->
                        <div class="bg-muted/50 p-6">
                            <div class="flex items-center justify-between">
                                <div class="flex items-start sm:items-center">
                                    <div class="flex-shrink-0">
                                        <div class="h-10 w-10 bg-destructive/10 rounded-full flex items-center justify-center">
                                            <svg class="h-5 w-5 text-destructive" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="ml-4">
                                        <p class="text-sm font-medium text-foreground">{{ t('account-settings.notifications.security_alerts', 'Security alerts') }}</p>
                                        <p class="text-sm text-muted-foreground mt-1">{{ t('account-settings.notifications.security_alerts_desc', 'Get notified about suspicious login attempts and security events') }}</p>
                                    </div>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" name="security_alerts" value="on" class="sr-only peer"
                                        {% if not pageUser.notification_preferences or pageUser.notification_preferences.security_alerts !== false %}checked{% endif %}>
                                    <div class="w-11 h-6 bg-muted peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-ring rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                </label>
                            </div>
                        </div>

                        <!-- New Session Alerts Toggle -->
                        <div class="bg-muted/50 p-6">
                            <div class="flex items-center justify-between">
                                <div class="flex items-start sm:items-center">
                                    <div class="flex-shrink-0">
                                        <div class="h-10 w-10 bg-primary/10 rounded-full flex items-center justify-center">
                                            <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="ml-4">
                                        <p class="text-sm font-medium text-foreground">{{ t('account-settings.notifications.new_session_alerts', 'New session alerts') }}</p>
                                        <p class="text-sm text-muted-foreground mt-1">{{ t('account-settings.notifications.new_session_alerts_desc', 'Get notified when a new device signs in to your account') }}</p>
                                    </div>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" name="new_session_alerts" value="on" class="sr-only peer"
                                        {% if not pageUser.notification_preferences or pageUser.notification_preferences.new_session_alerts !== false %}checked{% endif %}>
                                    <div class="w-11 h-6 bg-muted peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-ring rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                </label>
                            </div>
                        </div>

                        <!-- Marketing/Product Updates Toggle -->
                        <div class="bg-muted/50 p-6">
                            <div class="flex items-center justify-between">
                                <div class="flex items-start sm:items-center">
                                    <div class="flex-shrink-0">
                                        <div class="h-10 w-10 bg-primary/10 rounded-full flex items-center justify-center">
                                            <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path>
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="ml-4">
                                        <p class="text-sm font-medium text-foreground">{{ t('account-settings.notifications.marketing', 'Product updates') }}</p>
                                        <p class="text-sm text-muted-foreground mt-1">{{ t('account-settings.notifications.marketing_desc', 'Receive updates about new features and improvements') }}</p>
                                    </div>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" name="marketing" value="on" class="sr-only peer"
                                        {% if pageUser.notification_preferences and pageUser.notification_preferences.marketing %}checked{% endif %}>
                                    <div class="w-11 h-6 bg-muted peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-ring rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Save Button -->
                    <div class="flex justify-end pt-4 border-t border-border">
                        <button type="submit" class="inline-flex items-center px-6 py-2.5 border border-transparent text-sm font-medium text-primary-foreground bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring transition-all duration-200">
                            <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                            {{ t('account-settings.notifications.save_button', 'Save Preferences') }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
        {% endif %}
        <!-- Contact Verification Settings -->
        {% if pageUser.email %}
        <!-- Email Verification Settings -->
        <div class="mb-8">
            <div>
                <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                    <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    {{ t('account-settings.email_verification.title') }}
                </h2>
                <div class="bg-background border border-border p-6">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <div class="flex items-center space-x-3 mb-2">
                                <h3 class="text-sm font-medium text-foreground">{{ t('account-settings.email_verification.primary_email') }}</h3>
                                {% if pageUser.email_verified %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary">
                                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path
                                                fill-rule="evenodd"
                                                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                        {{ t('account-settings.email_verification.verified') }}
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-warning/10 text-warning">
                                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path
                                                fill-rule="evenodd"
                                                d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53
                                                    0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                        {{ t('account-settings.email_verification.unverified') }}
                                    </span>
                                {% endif %}
                            </div>
                            <p class="text-sm text-muted-foreground mb-4">
                                {{ pageUser.email | mask_email }}
                                {% if not pageUser.email_verified %}
                                    <br>
                                        <span class="text-xs text-muted-foreground">{{ t('account-settings.email_verification.verify_prompt') }}</span>
                                    {% endif %}
                                </p>
                                {% if not pageUser.email_verified %}
                                    <div class="flex flex-col sm:flex-row gap-2">
                                        <form action="{{ routes.accountFull.resend_email_verification }}" method="POST" class="inline">
                                            <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                                            <button
                                                type="submit"
                                                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium text-white bg-primary
                                                    hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 transition-colors">
                                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                                </svg>
                                                {{ t('account-settings.email_verification.resend_button') }}
                                            </button>
                                        </form>
                                        <a href="{{ routes.authFull.email_verification }}" class="inline-flex items-center px-4 py-2 border border-border text-sm font-medium text-foreground bg-background hover:border-primary focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 transition-colors">
                                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                            </svg>
                                            {{ t('account-settings.email_verification.verify_manually') }}
                                        </a>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
        {% if pageUser.phone_number %}
        <!-- Phone Verification Settings -->
        <div class="mb-8">
            <div>
                <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                    <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                    </svg>
                    {{ t('account-settings.phone_verification.title') }}
                </h2>
                <div class="bg-background border border-border p-6">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <div class="flex items-center space-x-3 mb-2">
                                <h3 class="text-sm font-medium text-foreground">{{ t('account-settings.phone_verification.primary_phone') }}</h3>
                                {% if pageUser.phone_number_verified %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary">
                                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path
                                                fill-rule="evenodd"
                                                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                        {{ t('account-settings.phone_verification.verified') }}
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-warning/10 text-warning">
                                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path
                                                fill-rule="evenodd"
                                                d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53
                                                    0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                        {{ t('account-settings.phone_verification.unverified') }}
                                    </span>
                                {% endif %}
                            </div>
                            <p class="text-sm text-muted-foreground">
                                {{ pageUser.phone_number | mask_phone }}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
        {% if not pageUser.email and pageUser.phone_number and not (pageUser.recovery and pageUser.recovery.secondary_email and pageUser.recovery.secondary_email.email) %}
        <!-- Add Email for Recovery - only show if user hasn't set up a recovery email -->
        <div class="mb-8">
            <div class="bg-primary/10 border border-primary/20 p-6">
                <div class="flex items-start">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div class="ml-3 flex-1">
                        <h3 class="text-sm font-medium text-foreground">{{ t('account-settings.add_email.title') }}</h3>
                        <p class="text-sm text-muted-foreground mt-1">{{ t('account-settings.add_email.description') }}</p>
                        <div class="mt-4">
                            <a href="{{ routes.accountFull.settings_recovery }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium text-primary-foreground bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring transition-colors">
                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                                </svg>
                                {{ t('account-settings.add_email.button') }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
{% endblock %}

{% block scripts %}
    {{ super() }}
    <script id="___SETTINGS_STATE___" type="application/json">
    {
      "csrfToken": {{ csrfToken | tojson | safe }},
      "debug": {{ (app.env === 'development') | tojson }}
    }
    </script>
    <script src="{{ asset('js/account/settings/index.js') }}"></script>
{% endblock %}
