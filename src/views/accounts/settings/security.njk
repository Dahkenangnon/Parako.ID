{% extends "layouts/account-layout.njk" %}

{% block account_content %}
    {% include "partials/account-settings-tabs.njk" %}

    <div class="space-y-10">
        <!-- Security Settings -->
        <div>
            <div>
                <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                    <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824
                                10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                    {{ t('account-settings.security.title') }}
                </h2>
                {# Calculate enabled MFA methods from multi-method schema #}
                {% set totpEnabled = pageUser.mfa and pageUser.mfa.methods and pageUser.mfa.methods.totp and pageUser.mfa.methods.totp.enabled and pageUser.mfa.methods.totp.secret %}
                {% set emailMfaEnabled = pageUser.mfa and pageUser.mfa.methods and pageUser.mfa.methods.email and pageUser.mfa.methods.email.enabled %}
                {% set webauthnEnabled = pageUser.mfa and pageUser.mfa.methods and pageUser.mfa.methods.webauthn and pageUser.mfa.methods.webauthn.enabled and pageUser.mfa.methods.webauthn.credentials and pageUser.mfa.methods.webauthn.credentials.length > 0 %}
                {% set anyMfaEnabled = totpEnabled or emailMfaEnabled or webauthnEnabled %}
                {% set enabledMethodsCount = (1 if totpEnabled else 0) + (1 if emailMfaEnabled else 0) + (1 if webauthnEnabled else 0) %}
                {% set anyMethodAvailable = mfaConfig and mfaConfig.enabled and (mfaConfig.methods.totp.enabled or mfaConfig.methods.email.enabled or mfaConfig.methods.webauthn.enabled) %}

                {% if mfaConfig and mfaConfig.enabled and (anyMethodAvailable or anyMfaEnabled) %}
                <!-- MFA Status Banner -->
                {% if anyMfaEnabled %}
                    <div class="mb-6 p-4 bg-primary/10 border border-primary/20">
                        <div class="flex items-center">
                            <div class="flex-shrink-0">
                                <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm font-medium text-foreground">
                                    {{ t('account-settings.security.mfa.active_title', 'Two-Factor Authentication Active') }}
                                </p>
                                <p class="text-sm text-muted-foreground mt-1">
                                    {{ t('account-settings.security.mfa.active_description_multi', 'You have {count} verification method(s) enabled.', {count: enabledMethodsCount}) }}
                                </p>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="mb-6 p-4 bg-warning/10 border border-warning/20">
                        <div class="flex items-center">
                            <div class="flex-shrink-0">
                                <svg class="h-5 w-5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                                </svg>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm font-medium text-foreground">
                                    {{ t('account-settings.security.mfa.inactive_title', 'Two-Factor Authentication Not Enabled') }}
                                </p>
                                <p class="text-sm text-muted-foreground mt-1">
                                    {{ t('account-settings.security.mfa.inactive_description', 'Add an extra layer of security to your account.') }}
                                </p>
                            </div>
                        </div>
                    </div>
                {% endif %}

                <!-- MFA Methods Grid -->
                <div class="space-y-4 mb-8">
                    {% if mfaConfig.methods.totp.enabled or totpEnabled %}
                    <!-- Authenticator App (TOTP) -->
                    <div class="bg-muted/50 p-4 border border-border">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                            <div class="flex items-center">
                                <div class="flex-shrink-0">
                                    <div class="h-10 w-10 {{ 'bg-primary/10' if totpEnabled else 'bg-muted' }} rounded-full flex items-center justify-center">
                                        <svg class="h-5 w-5 {{ 'text-primary' if totpEnabled else 'text-muted-foreground' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div class="ml-4">
                                    <p class="text-sm font-medium text-foreground">{{ t('account-settings.security.mfa.totp_title', 'Authenticator App') }}</p>
                                    <p class="text-sm text-muted-foreground">
                                        {% if totpEnabled %}
                                            <span class="text-primary font-medium">{{ t('common.enabled', 'Enabled') }}</span>
                                        {% else %}
                                            <span class="text-muted-foreground">{{ t('common.disabled', 'Disabled') }}</span>
                                        {% endif %}
                                    </p>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                {% if totpEnabled %}
                                    <form action="{{ routes.accountFull.disable_mfa }}?method=totp" method="POST" class="inline">
                                        <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                                        <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-destructive/30 text-sm font-medium text-destructive bg-background hover:border-destructive transition-colors">
                                            {{ t('common.disable', 'Disable') }}
                                        </button>
                                    </form>
                                {% elif mfaConfig.methods.totp.enabled %}
                                    <form action="{{ routes.accountFull.enable_mfa }}" method="POST" class="inline" id="enable-mfa-app-form">
                                        <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                                        <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-border text-sm font-medium text-foreground bg-background hover:border-primary transition-colors">
                                            {{ t('common.enable', 'Enable') }}
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endif %}

                    {% if mfaConfig.methods.email.enabled or emailMfaEnabled %}
                    <!-- Email Verification -->
                    <div class="bg-muted/50 p-4 border border-border">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                            <div class="flex items-center">
                                <div class="flex-shrink-0">
                                    <div class="h-10 w-10 {{ 'bg-primary/10' if emailMfaEnabled else 'bg-muted' }} rounded-full flex items-center justify-center">
                                        <svg class="h-5 w-5 {{ 'text-primary' if emailMfaEnabled else 'text-muted-foreground' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div class="ml-4">
                                    <p class="text-sm font-medium text-foreground">{{ t('account-settings.security.mfa.email_title', 'Email Verification') }}</p>
                                    <p class="text-sm text-muted-foreground">
                                        {% if emailMfaEnabled %}
                                            <span class="text-primary font-medium">{{ t('common.enabled', 'Enabled') }}</span>
                                        {% else %}
                                            <span class="text-muted-foreground">{{ t('common.disabled', 'Disabled') }}</span>
                                        {% endif %}
                                    </p>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                {% if emailMfaEnabled %}
                                    <form action="{{ routes.accountFull.disable_mfa }}?method=email" method="POST" class="inline">
                                        <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                                        <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-destructive/30 text-sm font-medium text-destructive bg-background hover:border-destructive transition-colors">
                                            {{ t('common.disable', 'Disable') }}
                                        </button>
                                    </form>
                                {% elif mfaConfig.methods.email.enabled %}
                                    <form action="{{ routes.accountFull.enable_mfa }}?method=email" method="POST" class="inline" id="enable-mfa-email-form">
                                        <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                                        <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-border text-sm font-medium text-foreground bg-background hover:border-primary transition-colors">
                                            {{ t('common.enable', 'Enable') }}
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endif %}

                    {% if mfaConfig.methods.webauthn.enabled or webauthnEnabled %}
                    <!-- Passkeys (WebAuthn) -->
                    <div class="bg-muted/50 p-4 border border-border">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                            <div class="flex items-center">
                                <div class="flex-shrink-0">
                                    <div class="h-10 w-10 {{ 'bg-primary/10' if webauthnEnabled else 'bg-muted' }} rounded-full flex items-center justify-center">
                                        <svg class="h-5 w-5 {{ 'text-primary' if webauthnEnabled else 'text-muted-foreground' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div class="ml-4">
                                    <p class="text-sm font-medium text-foreground">{{ t('account-settings.security.mfa.webauthn_title', 'Passkeys') }}</p>
                                    <p class="text-sm text-muted-foreground">
                                        {% if webauthnEnabled %}
                                            <span class="text-primary font-medium">{{ t('common.enabled', 'Enabled') }}</span>
                                            - {{ pageUser.mfa.methods.webauthn.credentials.length }} {{ t('account-settings.security.mfa.passkeys_count', 'passkey(s) registered') }}
                                        {% else %}
                                            <span class="text-muted-foreground">{{ t('common.disabled', 'Disabled') }}</span>
                                        {% endif %}
                                    </p>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                {% if webauthnEnabled %}
                                    <a href="{{ routes.accountFull.passkeys }}" class="inline-flex items-center px-3 py-1.5 border border-border text-sm font-medium text-foreground bg-background hover:border-primary transition-colors">
                                        {{ t('account-settings.security.mfa.manage_passkeys', 'Manage Passkeys') }}
                                    </a>
                                    <form action="{{ routes.accountFull.disable_mfa }}?method=webauthn" method="POST" class="inline">
                                        <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                                        <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-destructive/30 text-sm font-medium text-destructive bg-background hover:border-destructive transition-colors">
                                            {{ t('common.disable', 'Disable') }}
                                        </button>
                                    </form>
                                {% elif mfaConfig.methods.webauthn.enabled %}
                                    <a href="{{ routes.accountFull.setup_webauthn }}" class="inline-flex items-center px-3 py-1.5 border border-border text-sm font-medium text-foreground bg-background hover:border-primary transition-colors">
                                        {{ t('common.enable', 'Enable') }}
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>
                {% endif %}
                    <!-- Password Change -->
                    <form
                        action="{{ routes.accountFull.change_password }}" method="POST" class="space-y-6">
                        <!-- CSRF Token -->
                        <input
                        type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                        <!-- Special case message for users with no password and only one social provider -->
                        {% if isSpecialPasswordCase %}
                            <div class="bg-warning/10 border border-warning/20 p-4">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0">
                                        <svg class="h-5 w-5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732
                                                    16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <p class="text-sm font-medium text-foreground">
                                            {{ t('account-settings.security.password.set_title') }}
                                        </p>
                                        <p class="text-sm text-muted-foreground mt-1">
                                            {{ t('account-settings.security.password.set_description') }}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                            {% if not isSpecialPasswordCase %}
                                <div class="sm:col-span-2">
                                    <label for="current-password" class="block text-sm font-medium text-foreground mb-2">{{ t('account-settings.security.password.current_label') }}</label>
                                    <div class="relative">
                                        <input
                                            type="password"
                                            id="current-password"
                                            name="currentPassword"
                                            class="w-full h-11 px-4 py-2 pr-12 bg-background border-2 border-border text-sm text-foreground font-mono focus:ring-2
                                                focus:ring-ring focus:border-border focus:outline-none transition-colors"
                                            required/>
                                        <button
                                            type="button"
                                            class="absolute inset-y-0 right-0 pr-3 flex items-center password-toggle"
                                            data-target="current-password">
                                            <svg
                                                class="h-5 w-5 text-muted-foreground hover:text-foreground transition-colors"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477
                                                        0-8.268-2.943-9.542-7z"></path>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            {% endif %}
                            <div>
                                <label for="new-password" class="block text-sm font-medium text-foreground mb-2">{{ t('account-settings.security.password.new_label') }}</label>
                                <div class="relative">
                                    <input
                                        type="password"
                                        id="new-password"
                                        name="newPassword"
                                        class="w-full h-11 px-4 py-2 pr-12 bg-background border-2 border-border text-sm text-foreground font-mono focus:ring-2
                                            focus:ring-ring focus:border-border focus:outline-none transition-colors"
                                        required/>
                                    <button
                                        type="button"
                                        class="absolute inset-y-0 right-0 pr-3 flex items-center password-toggle"
                                        data-target="new-password">
                                        <svg
                                            class="h-5 w-5 text-muted-foreground hover:text-foreground transition-colors"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477
                                                    0-8.268-2.943-9.542-7z"></path>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                            <div>
                                <label for="confirm-password" class="block text-sm font-medium text-foreground mb-2">{{ t('account-settings.security.password.confirm_label') }}</label>
                                <div class="relative">
                                    <input
                                        type="password"
                                        id="confirm-password"
                                        name="confirmPassword"
                                        class="w-full h-11 px-4 py-2 pr-12 bg-background border-2 border-border text-sm text-foreground font-mono focus:ring-2
                                            focus:ring-ring focus:border-border focus:outline-none transition-colors"
                                        required/>
                                    <button
                                        type="button"
                                        class="absolute inset-y-0 right-0 pr-3 flex items-center password-toggle"
                                        data-target="confirm-password">
                                        <svg
                                            class="h-5 w-5 text-muted-foreground hover:text-foreground transition-colors"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477
                                                    0-8.268-2.943-9.542-7z"></path>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <!-- Password Requirements -->
                        <div class="bg-primary/10 border border-primary/20 p-4">
                            <h4 class="text-sm font-medium text-foreground mb-2">{{ t('account-settings.security.password.requirements_title') }}</h4>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs text-muted-foreground">
                                <div class="flex items-center">
                                    <svg class="h-3 w-3 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                    </svg>
                                    {{ t('account-settings.security.password.min_length', {count: passwordPolicy.minLength}) }}
                                </div>
                                {% if passwordPolicy.requireUppercase %}
                                    <div class="flex items-center">
                                        <svg class="h-3 w-3 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        {{ t('account-settings.security.password.uppercase') }}
                                    </div>
                                {% endif %}
                                {% if passwordPolicy.requireLowercase %}
                                    <div class="flex items-center">
                                        <svg class="h-3 w-3 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        {{ t('account-settings.security.password.lowercase') }}
                                    </div>
                                {% endif %}
                                {% if passwordPolicy.requireNumbers %}
                                    <div class="flex items-center">
                                        <svg class="h-3 w-3 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        {{ t('account-settings.security.password.number') }}
                                    </div>
                                {% endif %}
                                {% if passwordPolicy.requireSymbols %}
                                    <div class="flex items-center">
                                        <svg class="h-3 w-3 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        {{ t('account-settings.security.password.symbol') }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                        <!-- Change Password Button -->
                        <div class="flex justify-end pt-4 border-t border-border">
                            <button
                                type="submit"
                                class="inline-flex items-center px-6 py-2.5 border border-transparent text-sm font-medium text-primary-foreground
                                    bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring transition-all duration-200">
                                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0
                                            1121 9z"></path>
                                </svg>
                                {{ t('account-settings.security.password.change_button') }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
    </div>
{% endblock %}

{% block scripts %}
    {{ super() }}
    <script id="___SETTINGS_STATE___" type="application/json">
    {
      "csrfToken": {{ csrfToken | tojson | safe }},
      "isMfaEnabled": {{ (pageUser.mfa and pageUser.mfa.methods and ((pageUser.mfa.methods.totp and pageUser.mfa.methods.totp.enabled and pageUser.mfa.methods.totp.secret) or (pageUser.mfa.methods.email and pageUser.mfa.methods.email.enabled) or (pageUser.mfa.methods.webauthn and pageUser.mfa.methods.webauthn.enabled and pageUser.mfa.methods.webauthn.credentials and pageUser.mfa.methods.webauthn.credentials.length > 0))) | tojson }},
      "isSpecialPasswordCase": {{ isSpecialPasswordCase | tojson }},
      "translations": {
        "mfaAlreadyEnabled": {{ t('account-settings.security.mfa.already_enabled_message') | tojson | safe }},
        "mfaMethodAlreadyEnabled": {{ t('account-settings.security.mfa.method_already_enabled') | tojson | safe }},
        "mfaNotEnabled": {{ t('account-settings.security.mfa.not_enabled_message') | tojson | safe }},
        "mfaDisableConfirm": {{ t('account-settings.security.mfa.disable_confirm') | tojson | safe }},
        "enableMfaApp": {{ t('account-settings.security.mfa.enable_app_confirm') | tojson | safe }},
        "enableMfaEmail": {{ t('account-settings.security.mfa.enable_email_confirm') | tojson | safe }},
        "passwordMismatch": {{ t('account-settings.security.password.mismatch') | tojson | safe }},
        "passwordChanged": {{ t('account-settings.security.password.change_success') | tojson | safe }}
      },
      "debug": {{ (app.env === 'development') | tojson }}
    }
    </script>
    <script src="{{ asset('js/account/settings/password-visibility.js') }}"></script>
    <script src="{{ asset('js/account/settings/password.js') }}"></script>
    <script src="{{ asset('js/account/settings/mfa.js') }}"></script>
    <script src="{{ asset('js/account/settings/confirm-handler.js') }}"></script>
    <script src="{{ asset('js/account/settings/index.js') }}"></script>
{% endblock %}
