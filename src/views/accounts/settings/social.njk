{% extends "layouts/account-layout.njk" %}
{% block account_content %}
    {% include "partials/account-settings-tabs.njk" %}

    <div class="space-y-10">
        <!-- Social Account Management -->
        <div>
            <div>
                <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                    <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0
                                00-5.656-5.656l-1.1 1.1"></path>
                    </svg>
                    {{ t('account-settings.social.title') }}
                </h2>
                <div class="bg-muted/50 p-6">
                    <p class="text-sm text-muted-foreground mb-6">
                        {{ t('account-settings.social.description') }}
                    </p>
                    <!-- Social Accounts Table -->
                    <div class="space-y-3">
                        {% if socialProviders and socialProviders.length > 0 %}
                            {% for provider in socialProviders %}
                                <div class="flex items-center justify-between p-4 bg-background border border-border">
                                    <div class="flex items-center space-x-3">
                                        <div class="flex-shrink-0">
                                            {% if provider.provider === 'github' %}
                                                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207
                                                    11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729
                                                    1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304
                                                    3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381
                                                    1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138
                                                    3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807
                                                    5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386
                                                    0-6.627-5.373-12-12-12z"/>
                                                </svg>
                                            {% elif provider.provider === 'google' %}
                                                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path
                                                        d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74
                                                            3.28-8.09z"
                                                        fill="#4285F4"/><path
                                                        d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99
                                                            20.53 7.7 23 12 23z"
                                                        fill="#34A853"/><path
                                                        d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18
                                                            4.93l2.85-2.22.81-.62z"
                                                        fill="#FBBC05"/><path
                                                        d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6
                                                            3.3-4.53 6.16-4.53z"
                                                        fill="#EA4335"/>
                                                </svg>
                                            {% elif provider.provider === 'facebook' %}
                                                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125
                                                    11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491
                                                    0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                                                </svg>
                                            {% elif provider.provider === 'microsoft' %}
                                                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M11.4 24H0V12.6h11.4V24zM24 24H12.6V12.6H24V24zM11.4 11.4H0V0h11.4v11.4zM24 11.4H12.6V0H24v11.4z"/>
                                                </svg>
                                            {% elif provider.provider === 'linkedin' %}
                                                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136
                                                    2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337
                                                    7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064
                                                    2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771
                                                    24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                                                </svg>
                                            {% elif provider.provider === 'twitter' %}
                                                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384
                                                    4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0
                                                    01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0
                                                    01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21
                                                    0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                                                </svg>
                                            {% elif provider.provider === 'apple' %}
                                                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2
                                                    .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87
                                                    3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42
                                                    1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35
                                                    1.05-3.11z"/>
                                                </svg>
                                            {% else %}
                                                <div class="h-6 w-6 bg-muted rounded-full flex items-center justify-center text-xs font-medium">{{ provider.provider.charAt(0).toUpperCase() }}</div>
                                            {% endif %}
                                        </div>
                                        <div>
                                            <p class="text-sm font-medium text-foreground">{{ provider.provider.charAt(0).toUpperCase() + provider.provider.slice(1) }}</p>
                                            <p class="text-xs text-muted-foreground">
                                                {% if provider.isLinked %}
                                                    {{ t('account-settings.social.connected') }}
                                                    {% if provider.integration and provider.integration.provider_username %}
                                                        • {{ provider.integration.provider_username }}
                                                    {% endif %}
                                                {% else %}
                                                    {{ t('account-settings.social.not_connected') }}
                                                {% endif %}
                                            </p>
                                        </div>
                                    </div>
                                    <div class="flex items-center space-x-2">
                                        {% if provider.isLinked %}
                                            {% if provider.canUnlink %}
                                                <form method="POST" action="{{ routes.accountFull.accounts_base }}/social/{{ provider.provider }}/unlink" class="inline">
                                                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                                                        <button
                                                            type="submit"
                                                            class="inline-flex items-center px-3 py-1.5 border border-destructive/30 text-xs font-medium text-destructive
                                                                bg-background hover:border-destructive focus:outline-none focus:ring-2 focus:ring-ring transition-colors confirm-action"
                                                            data-confirm-title="Unlink Social Provider"
                                                            data-confirm-message-key="socialUnlinkConfirm"
                                                            data-confirm-provider="{{ provider.provider }}"
                                                            data-confirm-variant="warning">
                                                            <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                                            </svg>
                                                            {{ t('account-settings.social.unlink_button') }}
                                                        </button>
                                                    </form>
                                                {% else %}
                                                    <div class="inline-flex items-center px-3 py-1.5 border border-muted text-xs font-medium text-muted-foreground bg-muted/50
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    cursor-not-allowed" title="{{ t('account-settings.social.set_password_first_tooltip') }}">
                                                        <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path
                                                                stroke-linecap="round"
                                                                stroke-linejoin="round"
                                                                stroke-width="2"
                                                                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                                                        </svg>
                                                        {{ t('account-settings.social.set_password_first') }}
                                                    </div>
                                                {% endif %}
                                            {% else %}
                                                <a
                                                    href="{{ routes.accountFull.accounts_base }}/social/{{ provider.provider }}/link"
                                                    class="inline-flex items-center px-3 py-1.5 border border-border text-xs font-medium text-foreground bg-background
                                                        hover:border-primary focus:outline-none focus:ring-2 focus:ring-ring transition-colors">
                                                    <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                                                    </svg>
                                                    {{ t('account-settings.social.connect_button') }}
                                                </a>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <div class="text-center py-8 text-muted-foreground">
                                    <svg class="h-12 w-12 mx-auto mb-4 text-muted-foreground/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0
                                                00-5.656-5.656l-1.1 1.1"></path>
                                    </svg>
                                    <p>{{ t('account-settings.social.no_accounts') }}</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% block scripts %}
    {{ super() }}
    <script id="___SETTINGS_STATE___" type="application/json">
    {
      "csrfToken": {{ csrfToken | tojson | safe }},
      "translations": {
        "unlinkConfirm": {{ t('account-settings.social.unlink_confirm', 'Are you sure you want to unlink this social account?') | tojson | safe }},
        "unlinkError": {{ t('account-settings.social.unlink_error', 'Failed to unlink social account. Please try again.') | tojson | safe }}
      },
      "debug": {{ (app.env === 'development') | tojson }}
    }
    </script>
    <script src="/js/account/settings/confirm-handler.js"></script>
    <script src="/js/account/settings/index.js"></script>
{% endblock %}
