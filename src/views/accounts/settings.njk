                                            <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                                            <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-destructive/30 text-sm font-medium text-destructive bg-background hover:border-destructive transition-colors">
                                                {{ t('common.disable', 'Disable') }}
                                            </button>
                                        </form>
                                    {% else %}
                                        <form action="{{ routes.accountFull.enable_mfa }}?method=email" method="POST" class="inline" id="enable-mfa-email-form">
                                            <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                                            <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-border text-sm font-medium text-foreground bg-background hover:border-primary transition-colors">
                                                {{ t('common.enable', 'Enable') }}
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <!-- Passkeys (WebAuthn) -->
                        <div class="bg-muted/50 p-4 border border-border">
                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0">
                                        <div class="h-10 w-10 {{ 'bg-primary/10' if webauthnEnabled else 'bg-muted' }} rounded-full flex items-center justify-center">
                                            <svg class="h-5 w-5 {{ 'text-primary' if webauthnEnabled else 'text-muted-foreground' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="ml-4">
                                        <p class="text-sm font-medium text-foreground">{{ t('account-settings.security.mfa.webauthn_title', 'Passkeys') }}</p>
                                        <p class="text-sm text-muted-foreground">
                                            {% if webauthnEnabled %}
                                                <span class="text-primary font-medium">{{ t('common.enabled', 'Enabled') }}</span>
                                                - {{ pageUser.mfa.methods.webauthn.credentials.length }} {{ t('account-settings.security.mfa.passkeys_count', 'passkey(s) registered') }}
                                            {% else %}
                                                <span class="text-muted-foreground">{{ t('common.disabled', 'Disabled') }}</span>
                                            {% endif %}
                                        </p>
                                    </div>
                                </div>
                                <div class="flex gap-2">
                                    {% if webauthnEnabled %}
                                        <a href="{{ routes.accountFull.passkeys }}" class="inline-flex items-center px-3 py-1.5 border border-border text-sm font-medium text-foreground bg-background hover:border-primary transition-colors">
                                            {{ t('account-settings.security.mfa.manage_passkeys', 'Manage Passkeys') }}
                                        </a>
                                        <form action="{{ routes.accountFull.disable_mfa }}?method=webauthn" method="POST" class="inline">
                                            <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                                            <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-destructive/30 text-sm font-medium text-destructive bg-background hover:border-destructive transition-colors">
                                                {{ t('common.disable', 'Disable') }}
                                            </button>
                                        </form>
                                    {% else %}
                                        <a href="{{ routes.accountFull.setup_webauthn }}" class="inline-flex items-center px-3 py-1.5 border border-border text-sm font-medium text-foreground bg-background hover:border-primary transition-colors">
                                            {{ t('common.enable', 'Enable') }}
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                        <!-- Password Change -->
                        <form
                            action="{{ routes.accountFull.change_password }}" method="POST" class="space-y-6">
                            <!-- CSRF Token -->
                            <input
                            type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                            <!-- Special case message for users with no password and only one social provider -->
                            {% if isSpecialPasswordCase %}
                                <div class="bg-warning/10 border border-warning/20 p-4">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0">
                                            <svg class="h-5 w-5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732
                                                        16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                                            </svg>
                                        </div>
                                        <div class="ml-3">
                                            <p class="text-sm font-medium text-foreground">
                                                {{ t('account-settings.security.password.set_title') }}
                                            </p>
                                            <p class="text-sm text-muted-foreground mt-1">
                                                {{ t('account-settings.security.password.set_description') }}
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                {% if not isSpecialPasswordCase %}
                                    <div class="sm:col-span-2">
                                        <label for="current-password" class="block text-sm font-medium text-foreground mb-2">{{ t('account-settings.security.password.current_label') }}</label>
                                        <div class="relative">
                                            <input
                                                type="password"
                                                id="current-password"
                                                name="currentPassword"
                                                class="w-full h-11 px-4 py-2 pr-12 bg-background border-2 border-border text-sm text-foreground font-mono focus:ring-2
                                                    focus:ring-ring focus:border-border focus:outline-none transition-colors"
                                                required/>
                                            <button
                                                type="button"
                                                class="absolute inset-y-0 right-0 pr-3 flex items-center password-toggle"
                                                data-target="current-password">
                                                <svg
                                                    class="h-5 w-5 text-muted-foreground hover:text-foreground transition-colors"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477
                                                            0-8.268-2.943-9.542-7z"></path>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                {% endif %}
                                <div>
                                    <label for="new-password" class="block text-sm font-medium text-foreground mb-2">{{ t('account-settings.security.password.new_label') }}</label>
                                    <div class="relative">
                                        <input
                                            type="password"
                                            id="new-password"
                                            name="newPassword"
                                            class="w-full h-11 px-4 py-2 pr-12 bg-background border-2 border-border text-sm text-foreground font-mono focus:ring-2
                                                focus:ring-ring focus:border-border focus:outline-none transition-colors"
                                            required/>
                                        <button
                                            type="button"
                                            class="absolute inset-y-0 right-0 pr-3 flex items-center password-toggle"
                                            data-target="new-password">
                                            <svg
                                                class="h-5 w-5 text-muted-foreground hover:text-foreground transition-colors"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477
                                                        0-8.268-2.943-9.542-7z"></path>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                                <div>
                                    <label for="confirm-password" class="block text-sm font-medium text-foreground mb-2">{{ t('account-settings.security.password.confirm_label') }}</label>
                                    <div class="relative">
                                        <input
                                            type="password"
                                            id="confirm-password"
                                            name="confirmPassword"
                                            class="w-full h-11 px-4 py-2 pr-12 bg-background border-2 border-border text-sm text-foreground font-mono focus:ring-2
                                                focus:ring-ring focus:border-border focus:outline-none transition-colors"
                                            required/>
                                        <button
                                            type="button"
                                            class="absolute inset-y-0 right-0 pr-3 flex items-center password-toggle"
                                            data-target="confirm-password">
                                            <svg
                                                class="h-5 w-5 text-muted-foreground hover:text-foreground transition-colors"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477
                                                        0-8.268-2.943-9.542-7z"></path>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <!-- Password Requirements -->
                            <div class="bg-primary/10 border border-primary/20 p-4">
                                <h4 class="text-sm font-medium text-foreground mb-2">{{ t('account-settings.security.password.requirements_title') }}</h4>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs text-muted-foreground">
                                    <div class="flex items-center">
                                        <svg class="h-3 w-3 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        {{ t('account-settings.security.password.min_length', {count: passwordPolicy.minLength}) }}
                                    </div>
                                    {% if passwordPolicy.requireUppercase %}
                                        <div class="flex items-center">
                                            <svg class="h-3 w-3 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                            </svg>
                                            {{ t('account-settings.security.password.uppercase') }}
                                        </div>
                                    {% endif %}
                                    {% if passwordPolicy.requireLowercase %}
                                        <div class="flex items-center">
                                            <svg class="h-3 w-3 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                            </svg>
                                            {{ t('account-settings.security.password.lowercase') }}
                                        </div>
                                    {% endif %}
                                    {% if passwordPolicy.requireNumbers %}
                                        <div class="flex items-center">
                                            <svg class="h-3 w-3 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                            </svg>
                                            {{ t('account-settings.security.password.number') }}
                                        </div>
                                    {% endif %}
                                    {% if passwordPolicy.requireSymbols %}
                                        <div class="flex items-center">
                                            <svg class="h-3 w-3 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                            </svg>
                                            {{ t('account-settings.security.password.symbol') }}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                            <!-- Change Password Button -->
                            <div class="flex justify-end pt-4 border-t border-border">
                                <button
                                    type="submit"
                                    class="inline-flex items-center px-6 py-2.5 border border-transparent text-sm font-medium text-primary-foreground
                                        bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring transition-all duration-200">
                                    <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0
                                                1121 9z"></path>
                                    </svg>
                                    {{ t('account-settings.security.password.change_button') }}
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
                <!-- Account Recovery Settings -->
                <div id="recovery">
                    <div>
                        <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                            <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824
                                        10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                            </svg>
                            {{ t('account-settings.recovery.title') }}
                        </h2>
                        <!-- Recovery Status Dashboard -->
                        {% set hasBackupCodes = pageUser.recovery and pageUser.recovery.backup_codes and pageUser.recovery.backup_codes.codes.length > 0 %}
                        {% set hasSecondaryEmail = pageUser.recovery and pageUser.recovery.secondary_email and pageUser.recovery.secondary_email.email and pageUser.recovery.secondary_email.verified %}
                        {% set hasSecurityQuestions = pageUser.recovery and pageUser.recovery.security_questions and pageUser.recovery.security_questions.questions.length > 0 %}
                        {% set backupCodesCount = pageUser.recovery.backup_codes.codes.length if hasBackupCodes else 0 %}
                        {% set recoveryMethodsCount = (1 if hasBackupCodes else 0) + (1 if hasSecondaryEmail else 0) + (1 if hasSecurityQuestions else 0) %}
                        {% set isBackupCodesLow = hasBackupCodes and backupCodesCount <= 3 %}

                        <div class="mb-6 grid grid-cols-1 md:grid-cols-3 gap-4">
                            <!-- Backup Codes Status -->
                            <div class="p-4 border {{ 'border-destructive/30 bg-destructive/5' if not hasBackupCodes else ('border-warning/30 bg-warning/5' if isBackupCodesLow else 'border-primary/30 bg-primary/5') }}">
                                <div class="flex items-center gap-3">
                                    <div class="h-10 w-10 {{ 'bg-destructive/20' if not hasBackupCodes else ('bg-warning/20' if isBackupCodesLow else 'bg-primary/20') }} rounded-full flex items-center justify-center">
                                        <svg class="h-5 w-5 {{ 'text-destructive' if not hasBackupCodes else ('text-warning' if isBackupCodesLow else 'text-primary') }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-sm font-medium text-foreground">{{ t('account-settings.recovery.dashboard.backup_codes') }}</p>
                                        {% if hasBackupCodes %}
                                            <p class="text-xs {{ 'text-warning' if isBackupCodesLow else 'text-primary' }}">{{ backupCodesCount }} {{ t('account-settings.recovery.dashboard.codes_available') }}</p>
                                        {% else %}
                                            <p class="text-xs text-destructive">{{ t('account-settings.recovery.dashboard.not_configured') }}</p>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <!-- Secondary Email Status -->
                            <div class="p-4 border {{ 'border-destructive/30 bg-destructive/5' if not hasSecondaryEmail else 'border-primary/30 bg-primary/5' }}">
                                <div class="flex items-center gap-3">
                                    <div class="h-10 w-10 {{ 'bg-destructive/20' if not hasSecondaryEmail else 'bg-primary/20' }} rounded-full flex items-center justify-center">
                                        <svg class="h-5 w-5 {{ 'text-destructive' if not hasSecondaryEmail else 'text-primary' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-sm font-medium text-foreground">{{ t('account-settings.recovery.dashboard.backup_email') }}</p>
                                        {% if hasSecondaryEmail %}
                                            <p class="text-xs text-primary">{{ t('account-settings.recovery.dashboard.verified') }}</p>
                                        {% else %}
                                            <p class="text-xs text-destructive">{{ t('account-settings.recovery.dashboard.not_configured') }}</p>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <!-- Security Questions Status -->
                            <a href="{{ routes.accountFull.security_questions_setup }}" class="block p-4 border {{ 'border-destructive/30 bg-destructive/5 hover:bg-destructive/10' if not hasSecurityQuestions else 'border-primary/30 bg-primary/5 hover:bg-primary/10' }} transition-colors cursor-pointer">
                                <div class="flex items-center gap-3">
                                    <div class="h-10 w-10 {{ 'bg-destructive/20' if not hasSecurityQuestions else 'bg-primary/20' }} rounded-full flex items-center justify-center">
                                        <svg class="h-5 w-5 {{ 'text-destructive' if not hasSecurityQuestions else 'text-primary' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-sm font-medium text-foreground">{{ t('account-settings.recovery.dashboard.security_questions') }}</p>
                                        {% if hasSecurityQuestions %}
                                            <p class="text-xs text-primary">{{ t('account-settings.recovery.dashboard.configured') }}</p>
                                        {% else %}
                                            <p class="text-xs text-destructive">{{ t('account-settings.recovery.dashboard.not_configured') }}</p>
                                        {% endif %}
                                    </div>
                                    <svg class="h-4 w-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </div>
                            </a>
                        </div>
                        <!-- Overall Recovery Score -->
                        <div class="mb-6 p-4 {{ 'bg-destructive/10 border border-destructive/20' if recoveryMethodsCount == 0 else ('bg-warning/10 border border-warning/20' if recoveryMethodsCount == 1 or isBackupCodesLow else 'bg-primary/10 border border-primary/20') }}">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0">
                                        {% if recoveryMethodsCount == 0 %}
                                            <svg class="h-5 w-5 text-destructive" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                            </svg>
                                        {% elif recoveryMethodsCount == 1 or isBackupCodesLow %}
                                            <svg class="h-5 w-5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                            </svg>
                                        {% else %}
                                            <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                            </svg>
                                        {% endif %}
                                    </div>
                                    <div class="ml-3">
                                        <p class="text-sm font-medium text-foreground">
                                            {{ t('account-settings.recovery.dashboard.score_title') }}
                                        </p>
                                        <p class="text-sm text-muted-foreground">
                                            {% if recoveryMethodsCount == 0 %}
                                                {{ t('account-settings.recovery.dashboard.score_critical') }}
                                            {% elif recoveryMethodsCount == 1 %}
                                                {{ t('account-settings.recovery.dashboard.score_warning') }}
                                            {% elif isBackupCodesLow %}
                                                {{ t('account-settings.recovery.dashboard.score_low_codes') }}
                                            {% else %}
                                                {{ t('account-settings.recovery.dashboard.score_good') }}
                                            {% endif %}
                                        </p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <span class="text-2xl font-bold {{ 'text-destructive' if recoveryMethodsCount == 0 else ('text-warning' if recoveryMethodsCount == 1 or isBackupCodesLow else 'text-primary') }}">
                                        {{ recoveryMethodsCount }}/3
                                    </span>
                                    <p class="text-xs text-muted-foreground">{{ t('account-settings.recovery.dashboard.methods_active') }}</p>
                                </div>
                            </div>
                        </div>
                        <!-- Recovery Status Banner -->
                        {% if pageUser.recovery and pageUser.recovery.enabled %}
                            <div class="mb-6 p-4 bg-primary/10 border border-primary/20">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0">
                                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <p class="text-sm font-medium text-foreground">
                                            {{ t('account-settings.recovery.active_title') }}
                                        </p>
                                        <p class="text-sm text-muted-foreground mt-1">
                                            {{ t('account-settings.recovery.active_description') }}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="mb-6 p-4 bg-warning/10 border border-warning/20">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0">
                                        <svg class="h-5 w-5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732
                                                    16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <p class="text-sm font-medium text-foreground">
                                            {{ t('account-settings.recovery.inactive_title') }}
                                        </p>
                                        <p class="text-sm text-muted-foreground mt-1">
                                            {{ t('account-settings.recovery.inactive_description') }}
