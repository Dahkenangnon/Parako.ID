                                                                {% elif provider.provider === 'twitter' %}
                                                                    <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384
                                                                        4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0
                                                                        01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0
                                                                        01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21
                                                                        0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                                                                    </svg>
                                                                {% elif provider.provider === 'apple' %}
                                                                    <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2
                                                                        .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87
                                                                        3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42
                                                                        1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35
                                                                        1.05-3.11z"/>
                                                                    </svg>
                                                                {% else %}
                                                                    <div class="h-6 w-6 bg-muted rounded-full flex items-center justify-center text-xs font-medium">{{ provider.provider.charAt(0).toUpperCase() }}</div>
                                                                {% endif %}
                                                            </div>
                                                            <div>
                                                                <p class="text-sm font-medium text-foreground">{{ provider.provider.charAt(0).toUpperCase() + provider.provider.slice(1) }}</p>
                                                                <p class="text-xs text-muted-foreground">
                                                                    {% if provider.isLinked %}
                                                                        {{ t('account-settings.social.connected') }}
                                                                        {% if provider.integration and provider.integration.provider_username %}
                                                                            • {{ provider.integration.provider_username }}
                                                                        {% endif %}
                                                                    {% else %}
                                                                        {{ t('account-settings.social.not_connected') }}
                                                                    {% endif %}
                                                                </p>
                                                            </div>
                                                        </div>
                                                        <div class="flex items-center space-x-2">
                                                            {% if provider.isLinked %}
                                                                {% if provider.canUnlink %}
                                                                    <form method="POST" action="/accounts/social/{{ provider.provider }}/unlink" class="inline">
                                                                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                                                                            <button
                                                                                type="submit"
                                                                                class="inline-flex items-center px-3 py-1.5 border border-destructive/30 text-xs font-medium text-destructive
                                                                                    bg-background hover:border-destructive focus:outline-none focus:ring-2 focus:ring-ring transition-colors confirm-action"
                                                                                data-confirm-title="Unlink Social Provider"
                                                                                data-confirm-message-key="socialUnlinkConfirm"
                                                                                data-confirm-provider="{{ provider.provider }}"
                                                                                data-confirm-variant="warning">
                                                                                <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                                                                </svg>
                                                                                {{ t('account-settings.social.unlink_button') }}
                                                                            </button>
                                                                        </form>
                                                                    {% else %}
                                                                        <div class="inline-flex items-center px-3 py-1.5 border border-muted text-xs font-medium text-muted-foreground bg-muted/50
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        cursor-not-allowed" title="{{ t('account-settings.social.set_password_first_tooltip') }}">
                                                                            <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                <path
                                                                                    stroke-linecap="round"
                                                                                    stroke-linejoin="round"
                                                                                    stroke-width="2"
                                                                                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                                                                            </svg>
                                                                            {{ t('account-settings.social.set_password_first') }}
                                                                        </div>
                                                                    {% endif %}
                                                                {% else %}
                                                                    <a
                                                                        href="/accounts/social/{{ provider.provider }}/link"
                                                                        class="inline-flex items-center px-3 py-1.5 border border-border text-xs font-medium text-foreground bg-background
                                                                            hover:border-primary focus:outline-none focus:ring-2 focus:ring-ring transition-colors">
                                                                        <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                                                                        </svg>
                                                                        {{ t('account-settings.social.connect_button') }}
                                                                    </a>
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    {% endfor %}
                                                {% else %}
                                                    <div class="text-center py-8 text-muted-foreground">
                                                        <svg class="h-12 w-12 mx-auto mb-4 text-muted-foreground/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path
                                                                stroke-linecap="round"
                                                                stroke-linejoin="round"
                                                                stroke-width="2"
                                                                d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0
                                                                    00-5.656-5.656l-1.1 1.1"></path>
                                                        </svg>
                                                        <p>{{ t('account-settings.social.no_accounts') }}</p>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endblock %}
                        {% block scripts %}
                            {{ super() }}
                            <script id="___SETTINGS_STATE___" type="application/json">
                            {
                              "removeAvatarUrl": "{{ routes.accountFull.remove_avatar }}",
                              "updateLocaleUrl": "{{ routes.authFull.update_locale }}",
                              "csrfToken": {{ csrfToken | tojson | safe }},
                              "isMfaEnabled": {{ 'true' if pageUser.mfa and pageUser.mfa.enabled else 'false' }},
                              "mfaMethodsEnabled": {
                                "totp": {{ 'true' if totpEnabled else 'false' }},
                                "email": {{ 'true' if emailMfaEnabled else 'false' }},
                                "webauthn": {{ 'true' if webauthnEnabled else 'false' }}
                              },
                              "isSpecialPasswordCase": {{ 'true' if isSpecialPasswordCase else 'false' }},
                              "translations": {
                                "removeConfirm": {{ t('account-settings.profile.remove_confirm') | tojson | safe }},
                                "removeError": {{ t('account-settings.profile.remove_error') | tojson | safe }},
                                "fileReadError": {{ t('account-settings.profile.file_read_error') | tojson | safe }},
                                "processingImage": {{ t('account-settings.upload_widget.title') | tojson | safe }},
                                "languageUpdateError": {{ t('account-settings.preferences.language.update_error') | tojson | safe }},
                                "mfaAlreadyEnabled": {{ t('account-settings.security.mfa.already_enabled_message') | tojson | safe }},
                                "mfaMethodAlreadyEnabled": {{ t('account-settings.security.mfa.method_already_enabled', 'This MFA method is already enabled.') | tojson | safe }},
                                "mfaNotEnabled": {{ t('account-settings.security.mfa.not_enabled_message') | tojson | safe }},
                                "mfaDisableConfirm": {{ t('account-settings.security.mfa.disable_confirm') | tojson | safe }},
                                "passwordMismatch": {{ t('account-settings.security.password.mismatch_error') | tojson | safe }},
                                "backupCodesConfirmNew": {{ t('account-settings.recovery.backup_codes.confirm_new') | tojson | safe }},
                                "backupCodesConfirmRemove": {{ t('account-settings.recovery.backup_codes.confirm_remove') | tojson | safe }},
                                "backupEmailConfirmRemove": {{ t('account-settings.recovery.backup_email.confirm_remove') | tojson | safe }},
                                "socialUnlinkConfirm": {{ t('account-settings.social.confirm_unlink') | tojson | safe }}
                              },
                              "debug": {{ (app.env === 'development') | tojson }}
                            }
                            </script>
                            <script src="{{ asset('js/account/settings/confirm-handler.js') }}"></script>
                            <script src="{{ asset('js/account/settings/avatar.js') }}"></script>
                            <script src="{{ asset('js/account/settings/password.js') }}"></script>
                            <script src="{{ asset('js/account/settings/language.js') }}"></script>
                            <script src="{{ asset('js/account/settings/mfa.js') }}"></script>
                            <script src="{{ asset('js/account/settings/password-visibility.js') }}"></script>
                            <script src="{{ asset('js/account/settings/index.js') }}"></script>
                        {% endblock %}