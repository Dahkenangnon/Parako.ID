{% extends "layouts/account-layout.njk" %}
{% block account_content %}
    <!-- Upload Progress Widget -->
    <div id="upload-progress-widget" class="hidden mb-6 p-4 bg-primary/10 border border-primary/20">
        <div class="flex items-center space-x-3">
            <div class="flex-shrink-0">
                <div class="animate-spin rounded-full h-5 w-5 border border-primary border-t-transparent"></div>
            </div>
            <div>
                <p class="text-sm font-medium text-foreground">{{ t('account-settings.upload_widget.title') }}</p>
                <p class="text-xs text-muted-foreground">{{ t('account-settings.upload_widget.description') }}</p>
            </div>
        </div>
    </div>
    <div
        class="space-y-10">
        <!-- Profile Settings -->
        <div class="mb-8">
            <div>
                <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                    <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    {{ t('account-settings.profile.title') }}
                </h2>
                <form
                    action="{{ routes.accountFull.update_profile }}" method="POST" enctype="multipart/form-data" class="space-y-6" id="profile-form">
                    <!-- CSRF Token -->
                    <input
                    type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                    <!-- Avatar Upload -->
                    <div class="space-y-4">
                        <label class="block text-sm font-medium text-foreground">{{ t('account-settings.profile.picture_label') }}</label>
                        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                            <div class="flex-shrink-0">
                                <div class="relative">
                                    <div class="w-16 h-16 sm:w-20 sm:h-20 bg-muted border border-border rounded-full flex items-center justify-center
                                            overflow-hidden">
                                        {% if pageUser.picture %}
                                            <img src="{{ pageUser.picture }}" alt="{{ pageUser.displayName or pageUser.name or pageUser.given_name }}" id="preview-avatar" class="w-full h-full object-cover rounded-full"/>
                                        {% else %}
                                            <span class="text-primary font-semibold text-lg sm:text-xl" id="initials-placeholder">{{ pageUser.initials or ((pageUser.given_name or 'U') | slice(0, 1)) + ((pageUser.family_name or 'S') | slice(0, 1)) }}</span>
                                            <img src="" alt="" id="preview-avatar" class="w-full h-full object-cover rounded-full hidden"/>
                                        {% endif %}
                                    </div>
                                    <!-- Upload Button Overlay -->
                                    <div class="absolute inset-0 flex items-center justify-center opacity-0 hover:opacity-100 transition-opacity rounded-full">
                                        <label
                                            for="avatar-upload"
                                            class="bg-black/60 rounded-full w-16 h-16 sm:w-20 sm:h-20 flex items-center justify-center cursor-pointer">
                                            <svg class="h-5 w-5 sm:h-6 sm:w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2
                                                        2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                            </svg>
                                        </label>
                                        <input type="file" id="avatar-upload" name="avatar" class="hidden" accept="image/*"/>
                                    </div>
                                </div>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm text-muted-foreground mb-3">{{ t('account-settings.profile.upload_description') }}</p>
                                <div class="flex flex-wrap gap-2">
                                    <button
                                        type="button"
                                        id="upload-button"
                                        class="inline-flex items-center px-3 py-2 border border-border text-sm font-medium text-foreground bg-background
                                            hover:border-primary focus:outline-none focus:ring-2 focus:ring-ring transition-colors">
                                        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                                        </svg>
                                        {{ t('account-settings.profile.upload_button') }}
                                    </button>
                                    {% if pageUser.picture %}
                                        <button
                                            type="button"
                                            id="remove-button"
                                            class="inline-flex items-center px-3 py-2 border border-destructive/30 text-sm font-medium text-destructive bg-background
                                                hover:border-destructive focus:outline-none focus:ring-2 focus:ring-ring transition-colors">
                                            <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1
                                                        1v3M4 7h16"></path>
                                            </svg>
                                            {{ t('account-settings.profile.remove_button') }}
                                        </button>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Form Fields Grid -->
                    <div
                        class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <!-- First Name -->
                        <div>
                            <label for="firstname" class="block text-sm font-medium text-foreground mb-2">{{ t('account-settings.profile.first_name') }}</label>
                            <input type="text" id="firstname" name="firstname" value="{{ pageUser.given_name or '' }}" class="w-full h-11 px-4 py-2 bg-background border border-border text-sm text-foreground font-mono focus:ring-2 focus:ring-ring focus:border-border focus:outline-none transition-colors" required/>
                        </div>
                        <!-- Last Name -->
                        <div>
                            <label for="lastname" class="block text-sm font-medium text-foreground mb-2">{{ t('account-settings.profile.last_name') }}</label>
                            <input type="text" id="lastname" name="lastname" value="{{ pageUser.family_name or '' }}" class="w-full h-11 px-4 py-2 bg-background border border-border text-sm text-foreground font-mono focus:ring-2 focus:ring-ring focus:border-border focus:outline-none transition-colors" required/>
                        </div>
                        <!-- Custom Identifier Fields (if enabled and editable) -->
                        {% for ciField in customIdentifierFields %}
                        {% if ciField.edit_policy != 'admin_only' %}
                        <div class="sm:col-span-2">
                            <label for="custom_identifier_{{ ciField.slot }}" class="block text-sm font-medium text-foreground mb-2">
                                {{ ciField.name or 'Identifier' }}
                                {% if ciField.edit_policy == 'set_once' and pageUser['custom_identifier_' + ciField.slot] %}
                                <svg class="inline h-4 w-4 text-muted-foreground ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" title="This field cannot be changed once set">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                                </svg>
                                {% endif %}
                            </label>
                            <input type="text" id="custom_identifier_{{ ciField.slot }}" name="custom_identifier_{{ ciField.slot }}"
                                value="{{ pageUser['custom_identifier_' + ciField.slot] or '' }}"
                                placeholder="{{ ciField.hint_for_user or '' }}"
                                {% if ciField.edit_policy == 'set_once' and pageUser['custom_identifier_' + ciField.slot] %}readonly{% endif %}
                                class="w-full h-11 px-4 py-2 bg-background border border-border text-sm text-foreground font-mono focus:ring-2 focus:ring-ring focus:border-border focus:outline-none transition-colors {% if ciField.edit_policy == 'set_once' and pageUser['custom_identifier_' + ciField.slot] %}opacity-60 cursor-not-allowed{% endif %}"/>
                            {% if ciField.hint_for_user %}
                            <p class="mt-1 text-xs text-muted-foreground">{{ ciField.hint_for_user }}</p>
                            {% endif %}
                        </div>
                        {% endif %}
                        {% endfor %}
                    </div>
                    <!-- Save Button -->
                    <div class="flex justify-end pt-4 border-t border-border">
                        <button
                            type="submit"
                            class="inline-flex items-center px-6 py-2.5 border border-transparent text-sm font-medium text-primary-foreground
                                bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring transition-all duration-200">
                            <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                            {{ t('account-settings.profile.save_button') }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <!-- Preferences Settings -->
        <div class="mb-8">
            <div>
                <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                    <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0
                                001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0
                                00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0
                                00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07
                                2.572-1.065z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    {{ t('account-settings.preferences.title') }}
                </h2>
                <!-- Language/Locale Settings -->
                <div class="space-y-6">
                    <div class="bg-muted/50 p-6">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                            <div class="flex items-start sm:items-center">
                                <div class="flex-shrink-0">
                                    <div class="h-10 w-10 bg-primary/10 rounded-full flex items-center justify-center">
                                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div class="ml-4">
                                    <p class="text-sm font-medium text-foreground">{{ t('account-settings.preferences.language.title') }}</p>
                                    <p class="text-sm text-muted-foreground mt-1">
                                        {% if userLocale %}
                                            {{ t('account-settings.preferences.language.current') }}
                                            {% set availableLocales = getAvailableLocales() %}
                                            {% for localeData in availableLocales %}
                                                {% if localeData.code == userLocale %}
                                                    {{ localeData.flag }}
                                                    {{ localeData.label }}
                                                {% endif %}
                                            {% endfor %}
                                        {% else %}
                                            {{ t('account-settings.preferences.language.none') }}
                                        {% endif %}
                                    </p>
                                </div>
                            </div>
                            <div class="flex flex-col sm:flex-row gap-2">
                                <select
                                    id="language-selector-settings"
                                    class="appearance-none bg-background border border-border text-sm font-medium text-foreground px-3 py-2 pr-8
                                        focus:outline-none focus:ring-2 focus:ring-ring focus:border-border transition-colors">
                                    {% set availableLocales = getAvailableLocales() %}
                                    {% for localeData in availableLocales %}
                                        <option value="{{ localeData.code }}" {% if localeData.code == userLocale %} selected {% endif %}>
                                            {{ localeData.flag }}
                                            {{ localeData.label }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                    </div>
                    <!-- Timezone Settings -->
                    <div class="bg-muted/50 p-6">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                            <div class="flex items-start sm:items-center">
                                <div class="flex-shrink-0">
                                    <div class="h-10 w-10 bg-primary/10 rounded-full flex items-center justify-center">
                                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div class="ml-4">
                                    <p class="text-sm font-medium text-foreground">{{ t('account-settings.preferences.timezone.title') }}</p>
                                    <p class="text-sm text-muted-foreground mt-1">
                                        {{ t('account-settings.preferences.timezone.current') }} {{ pageUser.zoneinfo or 'UTC' }}
                                    </p>
                                </div>
                            </div>
                            <div class="flex flex-col sm:flex-row gap-2">
                                <select
                                    id="timezone-selector-settings"
                                    class="appearance-none bg-background border border-border text-sm font-medium text-foreground px-3 py-2 pr-8
                                        focus:outline-none focus:ring-2 focus:ring-ring focus:border-border transition-colors">
                                    <optgroup label="Africa">
                                        <option value="Africa/Abidjan" {% if pageUser.zoneinfo == 'Africa/Abidjan' %}selected{% endif %}>Abidjan</option>
                                        <option value="Africa/Accra" {% if pageUser.zoneinfo == 'Africa/Accra' %}selected{% endif %}>Accra</option>
                                        <option value="Africa/Addis_Ababa" {% if pageUser.zoneinfo == 'Africa/Addis_Ababa' %}selected{% endif %}>Addis Ababa</option>
                                        <option value="Africa/Algiers" {% if pageUser.zoneinfo == 'Africa/Algiers' %}selected{% endif %}>Algiers</option>
                                        <option value="Africa/Cairo" {% if pageUser.zoneinfo == 'Africa/Cairo' %}selected{% endif %}>Cairo</option>
                                        <option value="Africa/Casablanca" {% if pageUser.zoneinfo == 'Africa/Casablanca' %}selected{% endif %}>Casablanca</option>
                                        <option value="Africa/Johannesburg" {% if pageUser.zoneinfo == 'Africa/Johannesburg' %}selected{% endif %}>Johannesburg</option>
                                        <option value="Africa/Lagos" {% if pageUser.zoneinfo == 'Africa/Lagos' %}selected{% endif %}>Lagos</option>
                                        <option value="Africa/Nairobi" {% if pageUser.zoneinfo == 'Africa/Nairobi' %}selected{% endif %}>Nairobi</option>
                                        <option value="Africa/Porto-Novo" {% if pageUser.zoneinfo == 'Africa/Porto-Novo' %}selected{% endif %}>Porto-Novo</option>
                                        <option value="Africa/Tunis" {% if pageUser.zoneinfo == 'Africa/Tunis' %}selected{% endif %}>Tunis</option>
                                    </optgroup>
                                    <optgroup label="Americas">
                                        <option value="America/Anchorage" {% if pageUser.zoneinfo == 'America/Anchorage' %}selected{% endif %}>Anchorage</option>
                                        <option value="America/Argentina/Buenos_Aires" {% if pageUser.zoneinfo == 'America/Argentina/Buenos_Aires' %}selected{% endif %}>Buenos Aires</option>
                                        <option value="America/Chicago" {% if pageUser.zoneinfo == 'America/Chicago' %}selected{% endif %}>Chicago</option>
                                        <option value="America/Denver" {% if pageUser.zoneinfo == 'America/Denver' %}selected{% endif %}>Denver</option>
                                        <option value="America/Los_Angeles" {% if pageUser.zoneinfo == 'America/Los_Angeles' %}selected{% endif %}>Los Angeles</option>
                                        <option value="America/Mexico_City" {% if pageUser.zoneinfo == 'America/Mexico_City' %}selected{% endif %}>Mexico City</option>
                                        <option value="America/New_York" {% if pageUser.zoneinfo == 'America/New_York' %}selected{% endif %}>New York</option>
                                        <option value="America/Sao_Paulo" {% if pageUser.zoneinfo == 'America/Sao_Paulo' %}selected{% endif %}>Sao Paulo</option>
                                        <option value="America/Toronto" {% if pageUser.zoneinfo == 'America/Toronto' %}selected{% endif %}>Toronto</option>
                                        <option value="America/Vancouver" {% if pageUser.zoneinfo == 'America/Vancouver' %}selected{% endif %}>Vancouver</option>
                                    </optgroup>
                                    <optgroup label="Asia">
                                        <option value="Asia/Bangkok" {% if pageUser.zoneinfo == 'Asia/Bangkok' %}selected{% endif %}>Bangkok</option>
                                        <option value="Asia/Dubai" {% if pageUser.zoneinfo == 'Asia/Dubai' %}selected{% endif %}>Dubai</option>
                                        <option value="Asia/Hong_Kong" {% if pageUser.zoneinfo == 'Asia/Hong_Kong' %}selected{% endif %}>Hong Kong</option>
                                        <option value="Asia/Jakarta" {% if pageUser.zoneinfo == 'Asia/Jakarta' %}selected{% endif %}>Jakarta</option>
                                        <option value="Asia/Kolkata" {% if pageUser.zoneinfo == 'Asia/Kolkata' %}selected{% endif %}>Kolkata</option>
                                        <option value="Asia/Seoul" {% if pageUser.zoneinfo == 'Asia/Seoul' %}selected{% endif %}>Seoul</option>
                                        <option value="Asia/Shanghai" {% if pageUser.zoneinfo == 'Asia/Shanghai' %}selected{% endif %}>Shanghai</option>
                                        <option value="Asia/Singapore" {% if pageUser.zoneinfo == 'Asia/Singapore' %}selected{% endif %}>Singapore</option>
                                        <option value="Asia/Tokyo" {% if pageUser.zoneinfo == 'Asia/Tokyo' %}selected{% endif %}>Tokyo</option>
                                    </optgroup>
                                    <optgroup label="Australia">
                                        <option value="Australia/Melbourne" {% if pageUser.zoneinfo == 'Australia/Melbourne' %}selected{% endif %}>Melbourne</option>
                                        <option value="Australia/Perth" {% if pageUser.zoneinfo == 'Australia/Perth' %}selected{% endif %}>Perth</option>
                                        <option value="Australia/Sydney" {% if pageUser.zoneinfo == 'Australia/Sydney' %}selected{% endif %}>Sydney</option>
                                    </optgroup>
                                    <optgroup label="Europe">
                                        <option value="Europe/Amsterdam" {% if pageUser.zoneinfo == 'Europe/Amsterdam' %}selected{% endif %}>Amsterdam</option>
                                        <option value="Europe/Berlin" {% if pageUser.zoneinfo == 'Europe/Berlin' %}selected{% endif %}>Berlin</option>
                                        <option value="Europe/Dublin" {% if pageUser.zoneinfo == 'Europe/Dublin' %}selected{% endif %}>Dublin</option>
                                        <option value="Europe/Istanbul" {% if pageUser.zoneinfo == 'Europe/Istanbul' %}selected{% endif %}>Istanbul</option>
                                        <option value="Europe/London" {% if pageUser.zoneinfo == 'Europe/London' %}selected{% endif %}>London</option>
                                        <option value="Europe/Madrid" {% if pageUser.zoneinfo == 'Europe/Madrid' %}selected{% endif %}>Madrid</option>
                                        <option value="Europe/Moscow" {% if pageUser.zoneinfo == 'Europe/Moscow' %}selected{% endif %}>Moscow</option>
                                        <option value="Europe/Paris" {% if pageUser.zoneinfo == 'Europe/Paris' %}selected{% endif %}>Paris</option>
                                        <option value="Europe/Rome" {% if pageUser.zoneinfo == 'Europe/Rome' %}selected{% endif %}>Rome</option>
                                        <option value="Europe/Zurich" {% if pageUser.zoneinfo == 'Europe/Zurich' %}selected{% endif %}>Zurich</option>
                                    </optgroup>
                                    <optgroup label="Pacific">
                                        <option value="Pacific/Auckland" {% if pageUser.zoneinfo == 'Pacific/Auckland' %}selected{% endif %}>Auckland</option>
                                        <option value="Pacific/Fiji" {% if pageUser.zoneinfo == 'Pacific/Fiji' %}selected{% endif %}>Fiji</option>
                                        <option value="Pacific/Honolulu" {% if pageUser.zoneinfo == 'Pacific/Honolulu' %}selected{% endif %}>Honolulu</option>
                                    </optgroup>
                                    <optgroup label="Other">
                                        <option value="UTC" {% if pageUser.zoneinfo == 'UTC' %}selected{% endif %}>UTC</option>
                                    </optgroup>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Notification Preferences Settings -->
        {% if notificationConfig and notificationConfig.defaults.allow_user_preferences %}
        <div class="mb-8" id="notifications">
            <div>
                <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                    <svg class="h-5 w-5 text-muted-foreground mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                    </svg>
                    {{ t('account-settings.notifications.title', 'Notification Preferences') }}
                </h2>
                <form action="{{ routes.accountFull.update_notification_preferences }}" method="POST" class="space-y-6">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                    <div class="space-y-4">
                        <!-- Preferred Channel -->
                        <div class="bg-muted/50 p-6">
                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                <div class="flex items-start sm:items-center">
                                    <div class="flex-shrink-0">
                                        <div class="h-10 w-10 bg-primary/10 rounded-full flex items-center justify-center">
                                            <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="ml-4">
                                        <p class="text-sm font-medium text-foreground">{{ t('account-settings.notifications.preferred_channel', 'Preferred notification method') }}</p>
                                        <p class="text-sm text-muted-foreground mt-1">{{ t('account-settings.notifications.preferred_channel_desc', 'Choose how you want to receive notifications') }}</p>
                                    </div>
                                </div>
                                <select name="preferred_channel" id="preferred_channel"
                                    class="appearance-none bg-background border border-border text-sm font-medium text-foreground px-3 py-2 pr-8 focus:outline-none focus:ring-2 focus:ring-ring focus:border-border transition-colors">
                                    <option value="auto" {% if not pageUser.notification_preferences or pageUser.notification_preferences.preferred_channel == 'auto' %}selected{% endif %}>{{ t('account-settings.notifications.channel_auto', 'Automatic') }}</option>
                                    <option value="email" {% if pageUser.notification_preferences and pageUser.notification_preferences.preferred_channel == 'email' %}selected{% endif %}>{{ t('account-settings.notifications.channel_email', 'Email') }}</option>
                                    {% if notificationConfig.channels.sms.enabled %}
                                    <option value="sms" {% if pageUser.notification_preferences and pageUser.notification_preferences.preferred_channel == 'sms' %}selected{% endif %}>{{ t('account-settings.notifications.channel_sms', 'SMS') }}</option>
                                    {% endif %}
                                </select>
                            </div>
                        </div>

                        <!-- Security Alerts Toggle -->
                        <div class="bg-muted/50 p-6">
