<div class="mt-4 pt-3 border-t border-border text-center">
    <div class="flex flex-wrap justify-center items-center gap-x-3 gap-y-1 text-[10px] text-muted-foreground">
        {% if urls and urls.privacy_policy %}
        <a href="{{ urls.privacy_policy }}" class="hover:text-foreground transition-colors">{{ t('common.footer.privacy_short', 'Privacy') if t else 'Privacy' }}</a>
        {% endif %}
        {% if urls and urls.terms_of_service %}
        <a href="{{ urls.terms_of_service }}" class="hover:text-foreground transition-colors">{{ t('common.footer.terms_short', 'Terms') if t else 'Terms' }}</a>
        {% endif %}
        {% if urls and urls.contact %}
        <a href="{{ urls.contact }}" class="hover:text-foreground transition-colors">{{ t('common.footer.contact', 'Contact') if t else 'Contact' }}</a>
        {% endif %}
    </div>
</div>
