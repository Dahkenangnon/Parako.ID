{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
             <div class="flex justify-center mb-2">
                <img src="{{ branding.logo }}" alt="{{ app.title }} Logo" class="dark:hidden h-12 w-auto" />
                <img src="{{ branding.logoDark }}" alt="{{ app.title }} Logo" class="hidden dark:block h-12 w-auto" />
            </div>
                 <div class="mb-3 flex justify-center">
                    <h1 class="auth-heading text-center text-sm font-bold text-primary leading-tight break-words">
                        {% if stepMessage %}
                            {{ stepMessage }}
                        {% else %}
                            {{ t('home.choose_method') }}
                        {% endif %}
                    </h1>
                 </div>

                <!-- Social Login Section - Show at top if providers are available -->
                {% if socialProviders.enabled.length > 0 %}
                <!-- Social Login Buttons - Full width, vertical stack, max 3 -->
                {% set providerIcons = {
                    'google': {
                        'svg': '<svg class="w-5 h-5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>',
                        'class': 'bg-white dark:bg-accent border border-gray-200 dark:border-border text-gray-700 dark:text-foreground hover:bg-gray-50 dark:hover:bg-secondary'
                    },
                    'github': {
                        'svg': '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 0C4.477 0 0 4.477 0 10c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V19c0 .27.16.59.67.5C17.14 18.16 20 14.42 20 10A10 10 0 0010 0z" clip-rule="evenodd"/></svg>',
                        'class': 'bg-gray-900 border border-gray-800 text-white hover:bg-gray-800'
                    },
                    'facebook': {
                        'svg': '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>',
                        'class': 'bg-[#1877F2] border border-[#1877F2] text-white hover:bg-[#0f5fd9]'
                    },
                    'linkedin': {
                        'svg': '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>',
                        'class': 'bg-[#0077B5] border border-[#0077B5] text-white hover:bg-[#005885]'
                    },
                    'microsoft': {
                        'svg': '<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.4 24H0V12.6h11.4V24zM24 24H12.6V12.6H24V24zM11.4 11.4H0V0h11.4v11.4zm12.6 0H12.6V0H24v11.4z"/></svg>',
                        'class': 'bg-[#00A4EF] border border-[#00A4EF] text-white hover:bg-[#0078D4]'
                    }
                } %}
                <div class="space-y-2">
                    {% set socialCount = { val: 0 } %}
                    {% for provider in socialProviders.enabled %}
                        {% if providerIcons[provider] and socialCount.val < 3 %}
                        <button type="button" data-provider="{{ provider }}" class="w-full flex items-center justify-center gap-3 h-10 text-sm font-medium {{ providerIcons[provider].class }} focus:outline-none cursor-pointer">
                            <span class="flex items-center justify-center w-5 h-5">
                                {{ providerIcons[provider].svg | safe }}
                            </span>
                            <span>{{ t('home.social.sign_in_with', { provider: t('home.social.' + provider, provider | capitalize) }) }}</span>
                        </button>
                        {% set socialCount = { val: socialCount.val + 1 } %}
                        {% endif %}
                    {% endfor %}
                </div>

                <!-- Divider -->
                <div class="relative my-3">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-gray-200 dark:border-border"></div>
                    </div>
                    <div class="relative flex justify-center text-xs">
                        <span class="px-3 bg-white dark:bg-card text-gray-500 dark:text-muted-foreground font-medium">{{ t('home.social_divider') }}</span>
                    </div>
                </div>
                {% endif %}

                <!-- Login Form -->
                <form action="{{ routes.authFull.login }}" method="POST" class="space-y-4" id="login-form">
                    <!-- CSRF Token -->
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

                    <!-- Client Device Infos -->
                    <div id="client-device-infos-container"></div>

                    <!-- Continue URL for OIDC flows -->
                    {% if continueUrl %}
                    <input type="hidden" name="continue" value="{{ continueUrl }}" />
                    {% endif %}

                    <!-- Prompt parameter for OIDC flows -->
                    {% if prompt %}
                    <input type="hidden" name="prompt" value="{{ prompt }}" />
                    {% endif %}

                    <!-- Hidden field for login method - set to "auto" for auto-detection -->
                    <input type="hidden" name="login_method" id="login_method" value="auto" />

                    <!-- Single Identifier Field (email, phone, or custom identifier) -->
                    {% set ciLabel = '' %}
                    {% for ci in authentication.loginMethods.customIdentifiers %}
                      {% if ciLabel %}{% set ciLabel = ciLabel + ', ' + (ci.name | lower) %}{% else %}{% set ciLabel = ci.name | lower %}{% endif %}
                    {% endfor %}
                    <div id="identifier-field" class="space-y-2">
                        <label for="login" class="block text-sm font-semibold text-gray-900 dark:text-gray-100">{% if ciLabel %}{{ t('common.auth.identifier_dynamic', { fieldName: ciLabel }) }}{% else %}{{ t('common.auth.identifier') }}{% endif %}</label>
                        <div class="relative">
                            <input
                                type="text"
                                id="login"
                                name="login"
                                autocomplete="username"
                                autofocus
                                class="w-full h-10 px-4 py-2 pl-11 bg-gray-50 dark:bg-input border-2 border-gray-200 dark:border-border text-gray-900 dark:text-foreground placeholder-gray-500 dark:placeholder-muted-foreground focus:outline-none focus:border-primary dark:focus:border-primary"
                                placeholder="{% if ciLabel %}{{ t('common.auth.identifierPlaceholder_dynamic', { fieldName: ciLabel }) }}{% else %}{{ t('common.auth.identifierPlaceholder') }}{% endif %}"
                                required
                            />
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                            </div>
                        </div>
                    </div>

                    <!-- Password Field - Rectangular -->
                    <div class="space-y-2">
                        <label for="password" class="block text-sm font-semibold text-gray-900 dark:text-gray-100">{{ t('common.field.password') }}</label>
                        <div class="relative">
                            <input
                                type="password"
                                id="password"
                                name="password"
                                autocomplete="current-password"
                                class="w-full h-10 px-4 py-2 pl-11 pr-11 bg-gray-50 dark:bg-input border-2 border-gray-200 dark:border-border text-gray-900 dark:text-foreground placeholder-gray-500 dark:placeholder-muted-foreground focus:outline-none focus:border-primary dark:focus:border-primary"
                                placeholder="{{ t('common.placeholder.password') }}"
                                required
                            />
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                                </svg>
                            </div>
                            <button type="button" id="toggle-password" class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                <svg class="h-5 w-5 text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Sign In Button - Rectangular, Flat, No effects -->
                    <button type="submit" class="auth-btn w-full h-10 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900">
                        {{ t('common.button.sign_in') }}
                    </button>
                </form>

                <!-- Bottom Links -->
                <div class="mt-3 text-center">
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground">
                        {{ t('home.link.sign_up_prompt') }}
                        <a href="{{ routes.authFull.register }}" class="font-semibold text-primary hover:text-gray-900 dark:hover:text-foreground">{{ t('home.link.create_account') }}</a>
                    </p>
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground mt-1">
                        {{ t('common.auth.forgot_password') }}
                        <a href="{{ routes.authFull.forgot_password }}" class="font-semibold text-primary hover:text-gray-900 dark:hover:text-foreground">{{ t('home.link.reset_password') }}</a>
                    </p>
                </div>
{% endblock %}


{% block scripts %}
{{ super() }}
<script src="/js/auth/login.js"></script>

<!-- Complete configuration and translations for LoginManager -->
<script id="___LOGIN_STATE___" type="application/json">
{
  "config": {
    "bothMethodsEnabled": {{ authentication.loginMethods.bothEnabled | tojson }},
    "emailEnabled": {{ authentication.loginMethods.email | tojson }},
    "phoneEnabled": {{ authentication.loginMethods.phone | tojson }},
    "customIdentifiers": {{ authentication.loginMethods.customIdentifiers | tojson | safe }},
    "debug": {{ (app.env === 'development') | tojson }},
    "errorRecoveryTimeout": 120000,
    "csrfToken": {{ csrfToken | tojson | safe }}
  },
  "translations": {
    "signIn": {{ t('common.auth.sign_in') | tojson | safe }},
    "signingIn": {{ t('common.auth.signing_in') | tojson | safe }},
    "connecting": {{ t('common.auth.connecting') | tojson | safe }},
    "emailPlaceholder": {{ t('common.auth.email_placeholder') | tojson | safe }},
    "phonePlaceholder": {{ t('common.auth.phone_placeholder') | tojson | safe }},
    "passwordPlaceholder": {{ t('common.auth.password_placeholder') | tojson | safe }},
    "emailRequired": {{ t('common.auth.email_required') | tojson | safe }},
    "phoneRequired": {{ t('common.auth.phone_required') | tojson | safe }},
    "customIdentifierRequired": {{ t('common.auth.custom_identifier_required', { fieldName: 'Identifier' }) | tojson | safe }},
    "passwordRequired": {{ t('common.auth.password_required') | tojson | safe }},
    "errorRecovery": {{ t('common.auth.error_recovery') | tojson | safe }}
  }
}
</script>

{% endblock %}
