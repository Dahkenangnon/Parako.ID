{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-2">
                    <img src="{{ branding.logo }}" alt="{{ app.title }} Logo" class="dark:hidden h-12 w-auto" />
                    <img src="{{ branding.logoDark }}" alt="{{ app.title }} Logo" class="hidden dark:block h-12 w-auto" />
                </div>

                <!-- Success Icon -->
                <div class="flex justify-center mb-3">
                    <div class="w-12 h-12 bg-green-500 flex items-center justify-center border-2 border-green-600 rounded-md">
                        <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                    </div>
                </div>

                <p class="auth-heading text-gray-800 dark:text-foreground text-center mb-4 text-base font-semibold">
                    Authorization Successful!
                </p>

                <p class="text-gray-600 dark:text-muted-foreground text-center mb-4 text-sm">
                    Your device has been successfully authorized
                </p>

                <!-- Client Information -->
                <div class="bg-gray-50 dark:bg-muted p-3 mb-3 border-l-4 border-green-500 rounded-md">
                    <div class="flex items-center">
                        <div class="bg-green-100 dark:bg-green-900 p-1.5 mr-2 rounded-md">
                            <svg class="h-4 w-4 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="text-xs font-semibold text-gray-900 dark:text-foreground">{{ clientName or 'Application' }}</p>
                            <p class="text-2xs text-gray-500 dark:text-muted-foreground">has been granted access</p>
                        </div>
                    </div>
                </div>

                <!-- Success Message -->
                <div class="bg-green-50 dark:bg-card border-2 border-green-200 dark:border-green-700 p-3 mb-3 rounded-md">
                    <div class="flex items-center">
                        <svg class="h-4 w-4 text-green-600 dark:text-green-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        <p class="text-xs font-semibold text-green-800 dark:text-green-200">
                            Your device is now signed in and ready to use!
                        </p>
                    </div>
                </div>

                <!-- Next Steps -->
                <div class="bg-gray-50 dark:bg-muted border border-gray-200 dark:border-border p-3 mb-4 rounded-md">
                    <h3 class="text-xs font-semibold text-gray-900 dark:text-foreground mb-2 flex items-center">
                        <svg class="h-3 w-3 mr-1.5 text-gray-500 dark:text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                        </svg>
                        What happens next:
                    </h3>
                    <div class="space-y-1.5">
                        <div class="flex items-center text-2xs text-gray-600 dark:text-muted-foreground">
                            <div class="w-4 h-4 bg-green-500 flex items-center justify-center mr-2 flex-shrink-0 border border-green-600 rounded-sm">
                                <svg class="h-2.5 w-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>
                            </div>
                            <span>Device will refresh automatically</span>
                        </div>
                        <div class="flex items-center text-2xs text-gray-600 dark:text-muted-foreground">
                            <div class="w-4 h-4 bg-green-500 flex items-center justify-center mr-2 flex-shrink-0 border border-green-600 rounded-sm">
                                <svg class="h-2.5 w-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>
                            </div>
                            <span>Session is secure and encrypted</span>
                        </div>
                        <div class="flex items-center text-2xs text-gray-600 dark:text-muted-foreground">
                            <div class="w-4 h-4 bg-green-500 flex items-center justify-center mr-2 flex-shrink-0 border border-green-600 rounded-sm">
                                <svg class="h-2.5 w-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>
                            </div>
                            <span>Window closes in <span id="countdown" class="font-semibold">5</span>s</span>
                        </div>
                    </div>
                </div>

                <!-- Close Button -->
                <button id="close-window-btn" class="auth-btn w-full h-9 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white flex items-center justify-center text-sm rounded-md">
                    <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Close Window
                </button>

                <!-- Help Text -->
                <div class="text-center mt-3">
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground">
                        You can now safely close this window
                    </p>
                </div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="{{ asset('js/auth/oidc/device-flow-success.js') }}"></script>

<!-- Complete configuration and translations for DeviceFlowSuccessManager -->
<script id="___OIDC_DEVICE_FLOW_SUCCESS_STATE___" type="application/json">
{
  "config": {
    "enableAutoClose": true,
    "enableCountdown": true,
    "enableBackButtonPrevention": true,
    "enableFormResubmissionPrevention": true,
    "enableVisibilityHandling": true,
    "autoCloseDelay": 5,
    "errorRecoveryTimeout": 30000,
    "debug": {{ (app.env === 'development') | tojson }}
  },
  "translations": {
    "authorizationSuccessful": {{ t('auth.authorizationSuccessful', 'Authorization Successful!') | tojson | safe }},
    "deviceAuthorized": {{ t('auth.deviceAuthorized', 'Your device has been successfully authorized') | tojson | safe }},
    "hasBeenGrantedAccess": {{ t('auth.hasBeenGrantedAccess', 'has been granted access') | tojson | safe }},
    "deviceSignedIn": {{ t('auth.deviceSignedIn', 'Your device is now signed in and ready to use!') | tojson | safe }},
    "whatHappensNext": {{ t('auth.whatHappensNext', 'What happens next:') | tojson | safe }},
    "deviceWillRefresh": {{ t('auth.deviceWillRefresh', 'Device will refresh automatically') | tojson | safe }},
    "sessionSecure": {{ t('auth.sessionSecure', 'Session is secure and encrypted') | tojson | safe }},
    "windowCloses": {{ t('auth.windowCloses', 'Window closes in') | tojson | safe }},
    "closeWindow": {{ t('auth.closeWindow', 'Close Window') | tojson | safe }},
    "safelyCloseWindow": {{ t('auth.safelyCloseWindow', 'You can now safely close this window') | tojson | safe }}
  }
}
</script>

{% endblock %}
