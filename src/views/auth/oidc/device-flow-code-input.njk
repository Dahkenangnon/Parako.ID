{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-2">
                    {{ image(branding.logo, { alt: app.title + " Logo", className: 'dark:hidden h-12 w-auto', loading: 'eager', fetchpriority: 'high' }) }}
                    {{ image(branding.logoDark, { alt: app.title + " Logo", className: 'hidden dark:block h-12 w-auto', loading: 'eager', fetchpriority: 'high' }) }}
                </div>

                <p class="auth-heading text-gray-800 dark:text-foreground text-center mb-4 text-base font-semibold">
                    Device Verification
                </p>

                <p class="text-gray-600 dark:text-muted-foreground text-center mb-4 text-sm">
                    Enter the code from your device
                </p>



                <!-- Message Display -->
                {% if error or warning %}
                <div class="mb-4">
                    {% if error %}
                        <div class="bg-red-50 dark:bg-card border-2 border-red-200 dark:border-red-700 p-3 rounded-md">
                            <div class="flex items-center">
                                <svg class="h-4 w-4 text-red-600 dark:text-red-400 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                <p class="text-xs font-medium text-red-800 dark:text-red-200">{{ error }}</p>
                            </div>
                        </div>
                    {% elif warning %}
                        <div class="bg-yellow-50 dark:bg-card border-2 border-yellow-200 dark:border-yellow-700 p-3 rounded-md">
                            <div class="flex items-center">
                                <svg class="h-4 w-4 text-yellow-600 dark:text-yellow-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                                </svg>
                                <p class="text-xs font-medium text-yellow-800 dark:text-yellow-200">{{ warning }}</p>
                            </div>
                        </div>
                    {% endif %}
                </div>
                {% endif %}

                <!-- Custom Device Code Input Form -->
                <form id="{{ formId }}" novalidate method="{{ formMethod }}" action="{{ formAction }}" class="space-y-4">
                    <!-- XSRF Token (extracted from OIDC provider form) -->
                    <input type="hidden" name="xsrf" value="{{ xsrfToken }}" />

                    <!-- Device Code Input -->
                    <div class="space-y-1 mb-3">
                        <label for="user_code" class="block text-xs font-semibold text-gray-900 dark:text-foreground">Device Code</label>
                        <div class="flex justify-center">
                            <div class="flex items-center space-x-2" id="device-code-container">
                                <!-- Dynamic input fields will be generated by JavaScript based on mask -->
                            </div>
                        </div>
                        <!-- Hidden input to store the complete code -->
                        <input type="hidden" id="user_code" name="user_code" />
                        <p class="text-2xs text-gray-500 dark:text-muted-foreground text-center" id="code-format-hint">
                            Enter your device code as displayed
                        </p>
                    </div>

                    <!-- Verify Button -->
                    <button type="submit" class="auth-btn w-full h-9 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white flex items-center justify-center text-sm rounded-md">
                        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                        Verify Code
                    </button>
                </form>

                <!-- Help Text -->
                <div class="text-center mt-3">
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground">
                        <strong>Need help?</strong> The code should be displayed on your device's screen.
                        If you don't see a code, check your device's display or try refreshing the device's login page.
                    </p>
                </div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="{{ asset('js/auth/oidc/device-flow-code-input.js') }}"></script>

<!-- Complete configuration and translations for DeviceFlowCodeInputManager -->
<script id="___OIDC_DEVICE_FLOW_CODE_INPUT_STATE___" type="application/json">
{
  "config": {
    "deviceCodeMask": {{ (deviceCodeMask or "***-*-***") | tojson | safe }},
    "deviceCodeCharset": {{ (deviceCodeCharset or "digits") | tojson | safe }},
    "initialUserCode": {{ (userCode or "") | tojson | safe }},
    "formId": {{ formId | tojson | safe }},
    "enableLoadingStates": true,
    "enableErrorRecovery": true,
    "errorRecoveryTimeout": 10000,
    "enableBackButtonPrevention": true,
    "enableFormResubmissionPrevention": true,
    "enableDoubleSubmissionPrevention": true,
    "submissionTimeout": 10000,
    "debug": {{ (app.env === 'development') | tojson }}
  },
  "translations": {
    "deviceVerification": {{ t('auth.deviceVerification', 'Device Verification') | tojson | safe }},
    "enterDeviceCode": {{ t('auth.enterDeviceCode', 'Enter the code from your device') | tojson | safe }},
    "deviceCode": {{ t('auth.deviceCode', 'Device Code') | tojson | safe }},
    "verifyCode": {{ t('auth.verifyCode', 'Verify Code') | tojson | safe }},
    "verifying": {{ t('auth.verifying', 'Verifying...') | tojson | safe }},
    "enterCompleteCode": {{ t('auth.enterCompleteCode', 'Please enter a complete device code in the format:') | tojson | safe }},
    "needHelp": {{ t('auth.needHelp', 'Need help?') | tojson | safe }},
    "helpText": {{ t('auth.helpText', 'The code should be displayed on your device\'s screen. If you don\'t see a code, check your device\'s display or try refreshing the device\'s login page.') | tojson | safe }},
    "errorRecovery": {{ t('auth.errorRecovery', 'Session timed out. Please try again.') | tojson | safe }}
  }
}
</script>

{% endblock %}
