{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <!-- Logo or Icon -->
                {% if logoUri %}
                <div class="flex justify-center mb-5">
                    <img src="{{ logoUri }}" alt="{{ clientName or 'Application' }}" class="h-16 w-auto" />
                </div>
                {% else %}
                <div class="flex justify-center mb-5">
                    <div class="bg-blue-50 dark:bg-blue-900 h-16 w-16 flex items-center justify-center border-2 border-blue-200 dark:border-blue-700 rounded-md">
                        <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                        </svg>
                    </div>
                </div>
                {% endif %}

                <!-- Content -->
                <h2 class="auth-heading text-2xl font-bold text-gray-900 dark:text-foreground mb-2 text-center">Confirm Sign Out</h2>
                <p class="text-gray-600 dark:text-muted-foreground mb-6 text-center">Do you want to sign out of your account?</p>

                {% if clientName %}
                <p class="text-gray-500 dark:text-muted-foreground mb-2 text-center">
                    from <span class="font-semibold">{{ clientName }}</span>
                </p>
                {% endif %}

                <p class="text-gray-500 dark:text-muted-foreground mb-6 text-center">This will sign you out from your current session and may sign you out from other connected applications.</p>

                <!-- Logout Form -->
                {{ form | safe }}

                <div class="space-y-3 mt-6">
                    <button autofocus type="submit" form="op.logoutForm" value="yes" name="logout" class="auth-btn w-full h-10 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white rounded-md">
                        Yes, Sign Out
                    </button>
                    <button type="submit" form="op.logoutForm" class="w-full h-10 bg-white dark:bg-card border-2 border-gray-200 dark:border-border text-gray-700 dark:text-foreground font-semibold hover:bg-gray-50 dark:hover:bg-accent focus:outline-none rounded-md">
                        No, Stay Signed In
                    </button>
                </div>

                <!-- Footer Links -->
                {% if policyUri or tosUri %}
                <div class="mt-6 pt-4 border-t border-gray-200 dark:border-border text-center">
                    <div class="flex flex-wrap justify-center items-center gap-x-4 gap-y-1 text-xs text-gray-500 dark:text-muted-foreground">
                        {% if tosUri %}
                        <a href="{{ tosUri }}" class="hover:text-gray-700 dark:hover:text-foreground">Terms of Service</a>
                        {% else %}
                        <a href="{{ urls.terms_of_service }}" class="hover:text-gray-700 dark:hover:text-foreground">Terms of Service</a>
                        {% endif %}

                        {% if policyUri %}
                        <a href="{{ policyUri }}" class="hover:text-gray-700 dark:hover:text-foreground">Privacy Policy</a>
                        {% else %}
                        <a href="{{ urls.privacy_policy }}" class="hover:text-gray-700 dark:hover:text-foreground">Privacy Policy</a>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="/js/auth/oidc/logout.js"></script>

<!-- Complete configuration and translations for OIDCLogoutManager -->
<script id="___OIDC_LOGOUT_STATE___" type="application/json">
{
  "config": {
    "enableLoadingStates": true,
    "enableErrorRecovery": true,
    "errorRecoveryTimeout": 10000,
    "enableBackButtonPrevention": true,
    "enableFormResubmissionPrevention": true,
    "debug": {{ (app.env === 'development') | tojson }},
    "csrfToken": {{ csrfToken | tojson | safe }}
  },
  "translations": {
    "yesSignOut": {{ t('auth.yesSignOut', 'Yes, Sign Out') | tojson | safe }},
    "noStaySignedIn": {{ t('auth.noStaySignedIn', 'No, Stay Signed In') | tojson | safe }},
    "signingOut": {{ t('auth.signingOut', 'Signing Out...') | tojson | safe }},
    "errorRecovery": {{ t('auth.errorRecovery', 'Session timed out. Please try again.') | tojson | safe }}
  }
}
</script>

{% endblock %}
