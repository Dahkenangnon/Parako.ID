{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-2">
                    <img src="{{ branding.logo }}" alt="{{ app.title }} Logo" class="dark:hidden h-12 w-auto" />
                    <img src="{{ branding.logoDark }}" alt="{{ app.title }} Logo" class="hidden dark:block h-12 w-auto" />
                </div>

                <div class="mb-4 flex justify-center">
                    <h1 class="auth-heading text-center font-bold text-primary text-lg sm:text-xl md:text-2xl lg:text-3xl leading-tight break-words">
                        <span class="block max-w-full" style="display: block; width: 100%;">
                            <span class="block w-full" style="display: block; width: 100%; font-size: clamp(1rem, 2.5vw, 2rem);">
                                {{ t('common.recovery.sms_title') }}
                            </span>
                        </span>
                    </h1>
                </div>

                <!-- Phone Number Display -->
                {% if maskedPhone %}
                <div class="text-center mb-4">
                    <div class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-gray-100 dark:bg-muted border border-gray-200 dark:border-border">
                        <svg class="h-5 w-5 text-gray-500 dark:text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                        </svg>
                        <span class="text-sm font-mono text-gray-700 dark:text-gray-300">{{ maskedPhone }}</span>
                    </div>
                </div>
                {% endif %}

                <!-- Error Message -->
                {% if error %}
                <div class="bg-red-50 dark:bg-red-900 border-2 border-red-200 dark:border-red-700 p-4 mb-4">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-red-400 dark:text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-red-800 dark:text-red-200">{{ error }}</p>
                        </div>
                    </div>
                </div>
                {% endif %}

                <!-- Success Message (code sent) -->
                {% if success %}
                <div class="bg-green-50 dark:bg-green-900 border-2 border-green-200 dark:border-green-700 p-4 mb-4">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-green-400 dark:text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-green-800 dark:text-green-200">{{ success }}</p>
                        </div>
                    </div>
                </div>
                {% endif %}

                <!-- Rate Limit Warning -->
                {% if retryAfter %}
                <div class="bg-yellow-50 dark:bg-yellow-900/30 border-2 border-yellow-200 dark:border-yellow-700 p-3 mb-4">
                    <div class="flex items-center">
                        <svg class="h-4 w-4 text-yellow-500 dark:text-yellow-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <p class="text-sm text-yellow-800 dark:text-yellow-200" id="retry-countdown">
                            Please wait <span id="retry-seconds">{{ retryAfter }}</span> seconds before requesting a new code.
                        </p>
                    </div>
                </div>
                {% endif %}

                <!-- Send Code Form -->
                {% if not codeSent %}
                <form action="{{ routes.authFull.recovery_sms }}" method="POST" class="space-y-4" id="send-code-form">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                    <input type="hidden" name="action" value="send_code" />

                    <p class="text-sm text-gray-600 dark:text-muted-foreground text-center">
                        {{ t('common.recovery.sms_desc', { phone: maskedPhone or '***' }) }}
                    </p>

                    <!-- Send Code Button -->
                    <button type="submit" id="send-btn" class="auth-btn w-full h-9 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white text-sm" {% if retryAfter %}disabled{% endif %}>
                        {{ t('common.recovery.send_code') }}
                    </button>
                </form>
                {% else %}
                <!-- Code Sent - Show info and link to verify page -->
                <div class="text-center space-y-4">
                    <div class="p-4 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700">
                        <svg class="h-8 w-8 mx-auto mb-2 text-green-500 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <p class="text-sm font-medium text-green-800 dark:text-green-200">{{ t('common.recovery.code_sent') }}</p>
                        <p class="text-xs text-green-600 dark:text-green-300 mt-1">
                            {{ t('common.recovery.sms_sent_desc', { phone: maskedPhone or '***' }) }}
                        </p>
                    </div>

                    <a href="{{ routes.authFull.recovery_verify_code }}?type=sms" class="auth-btn inline-block w-full h-9 leading-9 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white text-sm text-center">
                        {{ t('common.button.continue') }}
                    </a>

                    <!-- Resend Link -->
                    <form action="{{ routes.authFull.recovery_sms }}" method="POST" class="mt-2">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                        <input type="hidden" name="action" value="send_code" />
                        <button type="submit" class="text-xs text-gray-500 dark:text-muted-foreground hover:text-primary" {% if retryAfter %}disabled{% endif %}>
                            Didn't receive the code? Send again
                        </button>
                    </form>
                </div>
                {% endif %}

                <!-- Bottom Links -->
                <div class="mt-3 text-center">
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground">
                        <a href="{{ routes.authFull.recovery_method_select }}" class="font-semibold text-primary hover:text-gray-900 dark:hover:text-foreground">{{ t('common.recovery.back_to_methods', 'Back to recovery options') }}</a>
                    </p>
                </div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script id="___RECOVERY_SMS_STATE___" type="application/json">
{
  "translations": {
    "sending": {{ t("common.action.sending") | tojson | safe }}
  }
}
</script>
<script src="{{ asset('js/auth/recovery-sms.js') }}"></script>
{% endblock %}
