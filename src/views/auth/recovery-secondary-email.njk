{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-3">
                    <img src="{{ branding.logo }}" alt="{{ app.title }} Logo" class="dark:hidden h-12 w-auto" />
                    <img src="{{ branding.logoDark }}" alt="{{ app.title }} Logo" class="hidden dark:block h-12 w-auto" />
                </div>

                <div class="mb-6 flex justify-center">
                    <h1 class="auth-heading text-center font-bold text-primary text-lg sm:text-xl md:text-2xl lg:text-3xl leading-tight break-words">
                        <span class="block max-w-full" style="display: block; width: 100%;">
                            <span class="block w-full" style="display: block; width: 100%; font-size: clamp(1rem, 2.5vw, 2rem);">
                                Recovery - Secondary Email
                            </span>
                        </span>
                    </h1>
                </div>

                <p class="text-center text-sm text-gray-600 dark:text-muted-foreground mb-2">
                    Enter your secondary email address to receive a verification code
                </p>

                <!-- Error Messages -->
                {% if error %}
                <div class="bg-red-50 dark:bg-red-900 border-2 border-red-200 dark:border-red-700 p-4 mb-4">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-red-400 dark:text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-red-800 dark:text-red-200">{{ error }}</p>
                        </div>
                    </div>
                </div>
                {% endif %}

                <!-- Secondary Email Form -->
                <form action="{{ routes.authFull.process_recovery_secondary_email }}" method="POST" class="space-y-4">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

                    <!-- Secondary Email Input -->
                    <div class="space-y-2">
                        <label for="email" class="block text-sm font-semibold text-gray-900 dark:text-foreground">Secondary Email Address</label>
                        <div class="relative">
                            <input
                                id="email"
                                name="email"
                                type="email"
                                autocomplete="email"
                                required
                                class="w-full h-12 px-4 py-3 pl-11 bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-900 dark:text-foreground placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:border-2 focus:border-primary"
                                placeholder="Enter your secondary email address"
                            />
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path>
                                </svg>
                            </div>
                        </div>
                        <p class="text-xs text-gray-500 dark:text-muted-foreground">
                            Enter the email address you registered as your secondary recovery method
                        </p>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="auth-btn w-full h-10 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white">
                        Send Verification Code
                    </button>
                </form>

                <!-- Bottom Links -->
                <div class="mt-3 text-center">
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground">
                        <a href="{{ routes.authFull.recovery_method_select }}" class="font-semibold text-primary hover:text-gray-900 dark:hover:text-foreground">{{ t('common.recovery.back_to_methods', 'Back to recovery options') }}</a>
                    </p>
                </div>

                <!-- Help Information -->
                <div class="mt-6 bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border p-4">
                    <h3 class="text-sm font-medium text-gray-900 dark:text-foreground mb-2">About Secondary Email Recovery</h3>
                    <div class="text-sm text-gray-600 dark:text-muted-foreground space-y-1">
                        <p>• Enter the exact email address you registered as your secondary recovery method</p>
                        <p>• A verification code will be sent to this email address</p>
                        <p>• The code will expire in 15 minutes</p>
                        <p>• Check your spam folder if you don't receive the email</p>
                    </div>
                </div>
{% endblock %}
