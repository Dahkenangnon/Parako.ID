{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-2">
                    {{ image(branding.logo, { alt: app.title + " Logo", className: 'dark:hidden h-12 w-auto', loading: 'eager', fetchpriority: 'high' }) }}
                    {{ image(branding.logoDark, { alt: app.title + " Logo", className: 'hidden dark:block h-12 w-auto', loading: 'eager', fetchpriority: 'high' }) }}
                </div>

                <div class="mb-4 flex justify-center">
                    <h1 class="auth-heading text-center font-bold text-primary text-lg sm:text-xl md:text-2xl lg:text-3xl leading-tight break-words">
                        <span class="block max-w-full" style="display: block; width: 100%;">
                            <span class="block w-full" style="display: block; width: 100%; font-size: clamp(1rem, 2.5vw, 2rem);">
                                {{ t('common.recovery.method_select_title') }}
                            </span>
                        </span>
                    </h1>
                </div>

                <!-- Account Found Info -->
                {% if maskedIdentifier %}
                <div class="text-center text-sm text-gray-600 dark:text-muted-foreground mb-4">
                    <span class="font-medium">{{ t('common.recovery.account_found') }}:</span>
                    <span class="text-gray-900 dark:text-foreground">{{ maskedIdentifier }}</span>
                </div>
                {% endif %}

                <!-- Error Message -->
                {% if error %}
                <div class="bg-red-50 dark:bg-red-900 border-2 border-red-200 dark:border-red-700 p-4 mb-4">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-red-400 dark:text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-red-800 dark:text-red-200">{{ error }}</p>
                        </div>
                    </div>
                </div>
                {% endif %}

                {% if availableMethods and availableMethods.length > 0 %}
                    <!-- Recommended Method (first available) -->
                    {% set recommendedMethod = availableMethods[0] %}

                    <div class="mb-4">
                        <div class="flex items-center gap-2 mb-3">
                            <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 border border-green-200 dark:border-green-700">
                                {{ t('common.recovery.recommended') }}
                            </span>
                        </div>

                        <form action="{{ routes.authFull.recovery_method_select }}" method="POST">
                            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                            <input type="hidden" name="method" value="{{ recommendedMethod.method }}" />

                            <button type="submit" class="auth-btn w-full p-4 border-2 border-primary bg-primary/5 hover:bg-primary/10 transition-colors text-left">
                                <div class="flex items-start gap-3">
                                    <!-- Method Icon -->
                                    <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-primary/10 text-primary">
                                        {% if recommendedMethod.method == 'backup_codes' %}
                                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                                        </svg>
                                        {% elif recommendedMethod.method == 'secondary_email' %}
                                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                        </svg>
                                        {% elif recommendedMethod.method == 'security_questions' %}
                                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                        {% elif recommendedMethod.method == 'sms' %}
                                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                                        </svg>
                                        {% endif %}
                                    </div>

                                    <!-- Method Info -->
                                    <div class="flex-1 min-w-0">
                                        <h3 class="text-sm font-semibold text-gray-900 dark:text-foreground">
                                            {% if recommendedMethod.method == 'backup_codes' %}
                                                {{ t('common.recovery.use_backup_codes') }}
                                            {% elif recommendedMethod.method == 'secondary_email' %}
                                                {{ t('common.recovery.use_secondary_email') }}
                                            {% elif recommendedMethod.method == 'security_questions' %}
                                                {{ t('common.recovery.use_security_questions') }}
                                            {% elif recommendedMethod.method == 'sms' %}
                                                {{ t('common.recovery.use_sms') }}
                                            {% endif %}
                                        </h3>
                                        <p class="text-xs text-gray-600 dark:text-muted-foreground mt-0.5">
                                            {% if recommendedMethod.method == 'backup_codes' %}
                                                {{ t('common.recovery.backup_codes_desc', { count: recommendedMethod.details.remainingCodes or 0 }) }}
                                            {% elif recommendedMethod.method == 'secondary_email' %}
                                                {{ t('common.recovery.secondary_email_desc', { email: recommendedMethod.details.maskedEmail or '***' }) }}
                                            {% elif recommendedMethod.method == 'security_questions' %}
                                                {{ t('common.recovery.security_questions_desc', { count: 3 }) }}
                                            {% elif recommendedMethod.method == 'sms' %}
                                                {{ t('common.recovery.sms_desc', { phone: recommendedMethod.details.maskedPhone or '***' }) }}
                                            {% endif %}
                                        </p>
                                    </div>

                                    <!-- Arrow Icon -->
                                    <div class="flex-shrink-0 flex items-center">
                                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                        </svg>
                                    </div>
                                </div>
                            </button>
                        </form>
                    </div>

                    <!-- Other Available Methods -->
                    {% if availableMethods.length > 1 %}
                    <div class="mt-4 pt-4 border-t border-gray-200 dark:border-border">
                        <p class="text-xs text-gray-500 dark:text-muted-foreground mb-3">{{ t('common.recovery.other_options') }}</p>

                        <div class="space-y-2">
                            {% for method in availableMethods %}
                                {% if loop.index0 > 0 %}
                                <form action="{{ routes.authFull.recovery_method_select }}" method="POST">
                                    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                                    <input type="hidden" name="method" value="{{ method.method }}" />

                                    <button type="submit" class="w-full p-3 border border-gray-200 dark:border-border hover:border-primary/50 hover:bg-gray-50 dark:hover:bg-muted transition-colors text-left">
                                        <div class="flex items-center gap-3">
                                            <!-- Method Icon -->
                                            <div class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gray-100 dark:bg-muted text-gray-600 dark:text-muted-foreground">
                                                {% if method.method == 'backup_codes' %}
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                                                </svg>
                                                {% elif method.method == 'secondary_email' %}
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                                </svg>
                                                {% elif method.method == 'security_questions' %}
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                </svg>
                                                {% elif method.method == 'sms' %}
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                                                </svg>
                                                {% endif %}
                                            </div>

                                            <!-- Method Name -->
                                            <div class="flex-1 min-w-0">
                                                <span class="text-sm text-gray-700 dark:text-gray-300">
                                                    {% if method.method == 'backup_codes' %}
                                                        {{ t('common.recovery.use_backup_codes') }}
                                                    {% elif method.method == 'secondary_email' %}
                                                        {{ t('common.recovery.use_secondary_email') }}
                                                    {% elif method.method == 'security_questions' %}
                                                        {{ t('common.recovery.use_security_questions') }}
                                                    {% elif method.method == 'sms' %}
                                                        {{ t('common.recovery.use_sms') }}
                                                    {% endif %}
                                                </span>
                                            </div>

                                            <!-- Arrow Icon -->
                                            <div class="flex-shrink-0">
                                                <svg class="h-4 w-4 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                                </svg>
                                            </div>
                                        </div>
                                    </button>
                                </form>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}

                {% else %}
                    <!-- No Methods Available -->
                    <div class="bg-yellow-50 dark:bg-yellow-900/30 border-2 border-yellow-200 dark:border-yellow-700 p-4">
                        <div class="flex">
                            <div class="flex-shrink-0">
                                <svg class="h-5 w-5 text-yellow-400 dark:text-yellow-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                </svg>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-yellow-800 dark:text-yellow-200">{{ t('common.recovery.no_methods_available') }}</p>
                            </div>
                        </div>
                    </div>
                {% endif %}

                <!-- Bottom Links -->
                <div class="mt-3 text-center">
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground">
                        <a href="{{ routes.authFull.account_recovery }}" class="font-semibold text-primary hover:text-gray-900 dark:hover:text-foreground">{{ t('common.button.back') }}</a>
                    </p>
                </div>
{% endblock %}
