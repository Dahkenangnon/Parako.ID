{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-3">
                    {{ image(branding.logo, { alt: app.title + " Logo", className: 'dark:hidden h-12 w-auto', loading: 'eager', fetchpriority: 'high' }) }}
                    {{ image(branding.logoDark, { alt: app.title + " Logo", className: 'hidden dark:block h-12 w-auto', loading: 'eager', fetchpriority: 'high' }) }}
                </div>
                <p class="auth-heading text-gray-600 dark:text-muted-foreground text-center mb-2 text-sm">{{ t('forgot-password.title') }}</p>

                <!-- Display flash messages -->


                <!-- Forgot Password Form -->
                <form action="{{ routes.authFull.forgot_password }}" method="POST" class="space-y-4">
                    <!-- CSRF Token -->
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

                    <!-- Email Field -->
                    <div class="space-y-2">
                        <label for="email" class="block text-sm font-semibold text-gray-900 dark:text-foreground">{{ t('common.field.email_address') }}</label>
                        <div class="relative">
                            <input
                                type="email"
                                id="email"
                                name="email"
                                autocomplete="email"
                                class="w-full h-12 px-4 py-3 pl-11 bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-900 dark:text-foreground placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:border-2 focus:border-primary"
                                placeholder="{{ t('common.placeholder.email') }}"
                                required
                            />
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path>
                                </svg>
                            </div>
                        </div>
                        <p class="text-xs text-gray-500 dark:text-muted-foreground">{{ t('forgot-password.description') }}</p>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="auth-btn w-full h-10 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white">
                        {{ t('forgot-password.button.send_reset_link') }}
                    </button>
                </form>

                <!-- Bottom Links -->
                <div class="mt-3 text-center">
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground">
                        {{ t('forgot-password.link.need_more_help', 'Need more help?') }}
                        <a href="{{ routes.authFull.account_recovery }}" class="font-semibold text-primary hover:text-gray-900 dark:hover:text-foreground">{{ t('common.navigation.account_recovery') }}</a>
                    </p>
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground mt-1">
                        {{ t('forgot-password.link.remember_password', 'Remember your password?') }}
                        <a href="{{ routes.authFull.login }}" class="font-semibold text-primary hover:text-gray-900 dark:hover:text-foreground">{{ t('common.button.sign_in') }}</a>
                    </p>
                </div>
{% endblock %}

{% block scripts %}
    {{ super() }}
    <script src="{{ asset('js/auth/forgot-password.js') }}"></script>

    <!-- Complete configuration and translations for ForgotPasswordManager -->
    <script id="___FORGOT_PASSWORD_STATE___" type="application/json">
    {
      "config": {
        "enableEmailValidation": true,
        "emailValidationTimeout": 300,
        "debug": {{ (app.env === 'development') | tojson }},
        "csrfToken": {{ csrfToken | tojson | safe }}
      },
      "translations": {
        "sendResetLink": {{ t('forgot-password.button.send_reset_link') | tojson | safe }},
        "sendingResetLink": {{ t('forgot-password.button.sending') | tojson | safe }},
        "emailRequired": {{ t('common.auth.email_required') | tojson | safe }},
        "emailInvalid": {{ t('common.validation.email_invalid') | tojson | safe }}
      }
    }
    </script>
{% endblock %}
