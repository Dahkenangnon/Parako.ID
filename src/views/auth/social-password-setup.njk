{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-2">
                    <img src="{{ branding.logo }}" alt="{{ app.title }} Logo" class="dark:hidden h-12 w-auto" />
                    <img src="{{ branding.logoDark }}" alt="{{ app.title }} Logo" class="hidden dark:block h-12 w-auto" />
                </div>
                <p class="auth-heading text-gray-800 dark:text-foreground text-center mb-2 text-base font-semibold">
                    Complete Your Registration
                </p>
                <p class="text-gray-600 dark:text-muted-foreground text-center mb-6 text-sm">
                    Set up a password to allow alternative login in addition to signing in with {{ provider }}.
                </p>



                <!-- Password Setup Form -->
                <form method="POST" class="space-y-4">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

                    <!-- Password Field -->
                    <div>
                        <label for="password" class="block text-sm font-medium text-gray-700 dark:text-muted-foreground mb-2">
                            Password
                        </label>
                        <div class="relative">
                            <input
                                type="password"
                                id="password"
                                name="password"
                                required
                                class="w-full px-3 py-2 border-2 border-gray-200 dark:border-border placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:border-2 focus:border-primary bg-gray-50 dark:bg-muted text-gray-900 dark:text-foreground rounded-md"
                                placeholder="Enter your password"
                            />
                            <button
                                type="button"
                                id="password-toggle"
                                class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
                            >
                                <svg id="password-eye" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Confirm Password Field -->
                    <div>
                        <label for="confirmPassword" class="block text-sm font-medium text-gray-700 dark:text-muted-foreground mb-2">
                            Confirm Password
                        </label>
                        <div class="relative">
                            <input
                                type="password"
                                id="confirmPassword"
                                name="confirmPassword"
                                required
                                class="w-full px-3 py-2 border-2 border-gray-200 dark:border-border placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:border-2 focus:border-primary bg-gray-50 dark:bg-muted text-gray-900 dark:text-foreground rounded-md"
                                placeholder="Confirm your password"
                            />
                            <button
                                type="button"
                                id="confirm-password-toggle"
                                class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
                            >
                                <svg id="confirmPassword-eye" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Password Requirements -->
                    {% if passwordPolicy %}
                    <div class="bg-blue-50 dark:bg-blue-900 border-2 border-blue-200 dark:border-blue-700 p-3 rounded-md">
                        <h4 class="text-sm font-medium text-blue-800 dark:text-blue-200 mb-2">Password Requirements:</h4>
                        <ul class="text-xs text-blue-700 dark:text-blue-300 space-y-1">
                            {% if passwordPolicy.minLength %}
                            <li class="flex items-center">
                                <span id="length-check" class="mr-2">&#10060;</span>
                                At least {{ passwordPolicy.minLength }} characters
                            </li>
                            {% endif %}
                            {% if passwordPolicy.requireUppercase %}
                            <li class="flex items-center">
                                <span id="uppercase-check" class="mr-2">&#10060;</span>
                                One uppercase letter
                            </li>
                            {% endif %}
                            {% if passwordPolicy.requireLowercase %}
                            <li class="flex items-center">
                                <span id="lowercase-check" class="mr-2">&#10060;</span>
                                One lowercase letter
                            </li>
                            {% endif %}
                            {% if passwordPolicy.requireNumbers %}
                            <li class="flex items-center">
                                <span id="number-check" class="mr-2">&#10060;</span>
                                One number
                            </li>
                            {% endif %}
                            {% if passwordPolicy.requireSymbols %}
                            <li class="flex items-center">
                                <span id="symbol-check" class="mr-2">&#10060;</span>
                                One special character
                            </li>
                            {% endif %}
                        </ul>
                    </div>
                    {% endif %}

                    <!-- Submit Button -->
                    <button
                        type="submit"
                        class="auth-btn w-full flex justify-center py-2 px-4 border-2 border-transparent text-sm font-medium text-white bg-primary hover:bg-primary/90 focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white rounded-md"
                    >
                        Complete Registration
                    </button>
                </form>

                <!-- Back to Registration -->
                <div class="mt-6 text-center">
                    <a
                        href="{{ routes.authFull.register }}"
                        class="text-sm text-primary hover:text-primary/80"
                    >
                        ← Back to Registration
                    </a>
                </div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="/js/auth/social-password-setup.js"></script>

<!-- Complete configuration and translations for SocialPasswordSetupManager -->
<script id="___SOCIAL_PASSWORD_SETUP_STATE___" type="application/json">
{
  "config": {
    "debug": {{ (app.env === 'development') | tojson }},
    "errorRecoveryTimeout": 120000,
    "csrfToken": {{ csrfToken | tojson | safe }}
  },
  "passwordPolicy": {
    "minLength": {{ passwordPolicy.minLength | tojson }},
    "requireUppercase": {{ passwordPolicy.requireUppercase | tojson }},
    "requireLowercase": {{ passwordPolicy.requireLowercase | tojson }},
    "requireNumbers": {{ passwordPolicy.requireNumbers | tojson }},
    "requireSymbols": {{ passwordPolicy.requireSymbols | tojson }}
  },
  "translations": {
    "completeRegistration": {{ t('auth.completeRegistration', 'Complete Registration') | tojson | safe }},
    "completingRegistration": {{ t('auth.completingRegistration', 'Completing Registration...') | tojson | safe }},
    "passwordRequired": {{ t('auth.passwordRequired', 'Please enter your password') | tojson | safe }},
    "confirmPasswordRequired": {{ t('auth.confirmPasswordRequired', 'Please confirm your password') | tojson | safe }},
    "passwordsDoNotMatch": {{ t('auth.passwordsDoNotMatch', 'Passwords do not match') | tojson | safe }},
    "errorRecovery": {{ t('auth.errorRecovery', 'Session timed out. Please try again.') | tojson | safe }}
  }
}
</script>
{% endblock %}
