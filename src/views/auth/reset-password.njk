{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-3">
                    <img src="{{ branding.logo }}" alt="{{ app.title }} Logo" class="dark:hidden h-12 w-auto" />
                    <img src="{{ branding.logoDark }}" alt="{{ app.title }} Logo" class="hidden dark:block h-12 w-auto" />
                </div>
                <p class="auth-heading text-gray-600 dark:text-muted-foreground text-center mb-2 text-sm">{{ t('reset-password.title') }}</p>

                <!-- Display flash messages -->


                <!-- Reset Password Form -->
                <form action="{{ routes.authFull.reset_password }}" method="POST" class="space-y-4" id="reset-password-form">
                    <!-- CSRF Token -->
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

                    <!-- Hidden Token Field -->
                    <input type="hidden" name="token" value="{{ token }}" />

                    <!-- Password Field -->
                    <div class="space-y-2">
                        <label for="password" class="block text-sm font-semibold text-gray-900 dark:text-foreground">{{ t('common.field.new_password') }}</label>
                        <div class="relative">
                            <input
                                type="password"
                                id="password"
                                name="password"
                                class="w-full h-12 px-4 py-3 pl-11 pr-11 bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-900 dark:text-foreground placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:border-2 focus:border-primary"
                                placeholder="{{ t('reset-password.placeholder.new_password') }}"
                                required
                            />
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                                </svg>
                            </div>
                            <button type="button" id="toggle-password" class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                <svg class="h-5 w-5 text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Confirm Password Field -->
                    <div class="space-y-2">
                        <label for="confirm-password" class="block text-sm font-semibold text-gray-900 dark:text-foreground">{{ t('common.field.confirm_password') }}</label>
                        <div class="relative">
                            <input
                                type="password"
                                id="confirm-password"
                                name="confirm-password"
                                class="w-full h-12 px-4 py-3 pl-11 bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-900 dark:text-foreground placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:border-2 focus:border-primary"
                                placeholder="{{ t('reset-password.placeholder.confirm_password') }}"
                                required
                            />
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                                </svg>
                            </div>
                        </div>
                    </div>

                    <!-- Password Strength Indicator -->
                    <div class="space-y-1">
                        <div class="h-1 w-full bg-gray-200 dark:bg-border">
                            <div id="password-strength" class="h-full bg-gray-400 dark:bg-gray-500" style="width: 0%"></div>
                        </div>
                        <div class="text-xs text-gray-500 dark:text-muted-foreground">
                            <p id="password-feedback">{{ t('common.password_requirements.title') }}</p>
                            <ul class="list-disc list-inside mt-1 space-y-0.5">
                                <li>{{ t('common.password_requirements.min_length', {count: passwordPolicy.minLength}) }}</li>
                                {% if passwordPolicy.requireUppercase %}<li>{{ t('common.password_requirements.uppercase') }}</li>{% endif %}
                                {% if passwordPolicy.requireLowercase %}<li>{{ t('common.password_requirements.lowercase') }}</li>{% endif %}
                                {% if passwordPolicy.requireNumbers %}<li>{{ t('common.password_requirements.number') }}</li>{% endif %}
                                {% if passwordPolicy.requireSymbols %}<li>{{ t('common.password_requirements.special_char') }}</li>{% endif %}
                            </ul>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="auth-btn w-full h-10 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white">
                        {{ t('reset-password.button.reset_password') }}
                    </button>
                </form>

                <!-- Bottom Links -->
                <div class="mt-3 text-center">
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground">
                        {{ t('reset-password.link.remember_password', 'Remember your password?') }}
                        <a href="{{ routes.authFull.login }}" class="font-semibold text-primary hover:text-gray-900 dark:hover:text-foreground">{{ t('common.button.sign_in') }}</a>
                    </p>
                </div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="/js/auth/reset-password.js"></script>

<!-- Complete configuration and translations for ResetPasswordManager -->
<script id="___RESET_PASSWORD_STATE___" type="application/json">
{
  "config": {
    "enableLanguageSelector": false,
    "enablePasswordToggle": true,
    "enableStrengthMeter": true,
    "enablePasswordConfirmation": true,
    "debug": {{ (app.env === 'development') | tojson }},
    "errorRecoveryTimeout": 120000,
    "csrfToken": {{ csrfToken | tojson | safe }}
  },
  "passwordPolicy": {
    "minLength": {{ passwordPolicy.minLength }},
    "requireUppercase": {{ passwordPolicy.requireUppercase | tojson }},
    "requireLowercase": {{ passwordPolicy.requireLowercase | tojson }},
    "requireNumbers": {{ passwordPolicy.requireNumbers | tojson }},
    "requireSymbols": {{ passwordPolicy.requireSymbols | tojson }}
  },
  "translations": {
    "resetPassword": {{ t('reset-password.button.reset_password') | tojson | safe }},
    "resettingPassword": {{ t('reset-password.button.resetting') | tojson | safe }},
    "passwordRequired": {{ t('common.auth.password_required') | tojson | safe }},
    "confirmPasswordRequired": {{ t('common.validation.confirm_password_required') | tojson | safe }},
    "passwordsDoNotMatch": {{ t('common.validation.passwords_mismatch') | tojson | safe }},
    "passwordTooShort": {{ t('common.validation.password_too_short') | tojson | safe }},
    "passwordRequiresUppercase": {{ t('common.validation.password_requires_uppercase') | tojson | safe }},
    "passwordRequiresLowercase": {{ t('common.validation.password_requires_lowercase') | tojson | safe }},
    "passwordRequiresNumbers": {{ t('common.validation.password_requires_number') | tojson | safe }},
    "passwordRequiresSymbols": {{ t('common.validation.password_requires_special') | tojson | safe }},
    "errorRecovery": {{ t('common.auth.error_recovery') | tojson | safe }}
  }
}
</script>

{% endblock %}
