{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-2">
                    <img src="{{ branding.logo }}" alt="{{ app.title }} Logo" class="dark:hidden h-12 w-auto" />
                    <img src="{{ branding.logoDark }}" alt="{{ app.title }} Logo" class="hidden dark:block h-12 w-auto" />
                </div>

                <div class="mb-4 flex justify-center">
                    <h1 class="auth-heading text-center font-bold text-primary text-lg sm:text-xl md:text-2xl lg:text-3xl leading-tight break-words">
                        <span class="block max-w-full" style="display: block; width: 100%;">
                            <span class="block w-full" style="display: block; width: 100%; font-size: clamp(1rem, 2.5vw, 2rem);">
                                {{ t('common.recovery.title') }}
                            </span>
                        </span>
                    </h1>
                </div>

                <p class="text-center text-sm text-gray-600 dark:text-muted-foreground mb-4">
                    {{ t('common.recovery.subtitle') }}
                </p>

                <!-- Error/Success Messages -->
                {% if error %}
                <div class="bg-red-50 dark:bg-red-900 border-2 border-red-200 dark:border-red-700 p-4 mb-4">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-red-400 dark:text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-red-800 dark:text-red-200">{{ error }}</p>
                        </div>
                    </div>
                </div>
                {% endif %}

                {% if success %}
                <div class="bg-green-50 dark:bg-green-900 border-2 border-green-200 dark:border-green-700 p-4 mb-4">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-green-400 dark:text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-green-800 dark:text-green-200">{{ success }}</p>
                        </div>
                    </div>
                </div>
                {% endif %}

                <!-- Recovery Form -->
                <form action="{{ routes.authFull.account_recovery }}" method="POST" class="space-y-3" id="recovery-form">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

                    <!-- Dynamic Identifier Field (email, phone, or custom identifier) -->
                    <div id="identifier-field" class="space-y-1">
                        <label for="identifier" class="flex items-center gap-1.5 text-sm font-semibold text-gray-900 dark:text-foreground">
                            <span class="relative group flex-shrink-0">
                                <svg class="h-3.5 w-3.5 text-muted-foreground hover:text-foreground cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                <span class="invisible group-hover:visible absolute top-full left-0 mt-1 w-48 rounded bg-popover border border-border px-2 py-1.5 text-2xs font-normal text-popover-foreground shadow-md z-10">
                                    {{ t('common.recovery.help_text') }}
                                </span>
                            </span>
                            {% set ciLabel = '' %}
                            {% for ci in authentication.customIdentifiers %}
                              {% if ciLabel %}{% set ciLabel = ciLabel + ', ' + (ci.name | lower) %}{% else %}{% set ciLabel = ci.name | lower %}{% endif %}
                            {% endfor %}
                            {% if ciLabel %}
                                {{ t('common.recovery.identifier_label_dynamic', { fieldName: ciLabel }) }}
                            {% else %}
                                {{ t('common.recovery.identifier_label') }}
                            {% endif %}
                        </label>
                        <div class="relative">
                            <input
                                id="identifier"
                                name="identifier"
                                type="text"
                                autocomplete="username"
                                required
                                class="w-full h-10 px-3 py-2 pl-9 bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border text-sm text-gray-900 dark:text-foreground placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:border-2 focus:border-primary"
                                placeholder="{% if ciLabel %}{{ t('common.recovery.identifier_placeholder_dynamic', { fieldName: ciLabel }) }}{% else %}{{ t('common.recovery.identifier_placeholder') }}{% endif %}"
                                value="{{ identifier or '' }}"
                            />
                            <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                            </div>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" id="submit-btn" class="auth-btn w-full h-9 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white text-sm">
                        {{ t('common.recovery.continue') }}
                    </button>
                </form>

                <!-- Bottom Links -->
                <div class="mt-3 text-center">
                    <p class="text-2xs text-gray-600 dark:text-muted-foreground">
                        {{ t('forgot-password.link.remember_password', 'Remember your password?') }}
                        <a href="{{ routes.authFull.login }}" class="font-semibold text-primary hover:text-gray-900 dark:hover:text-foreground">{{ t('common.button.sign_in') }}</a>
                    </p>
                </div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script id="___ACCOUNT_RECOVERY_STATE___" type="application/json">
{
  "translations": {
    "processing": {{ t("common.action.processing") | tojson | safe }}
  }
}
</script>
<script src="/js/auth/account-recovery.js"></script>
{% endblock %}
