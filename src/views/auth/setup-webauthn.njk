{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
    <div class="flex justify-center mb-4">
      <div class="bg-primary dark:bg-primary p-3 border-2 border-primary dark:border-primary">
        <svg class="h-8 w-8 text-white dark:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
        </svg>
      </div>
    </div>

    <h2 class="auth-heading text-xl font-bold text-gray-900 dark:text-foreground text-center mb-2">{{ t('common.auth.webauthn.setup.title', 'Set Up Passkey') }}</h2>
    <p class="text-sm text-gray-600 dark:text-muted-foreground text-center mb-6">{{ t('common.auth.webauthn.setup.description', 'Add a passkey to use Touch ID, Face ID, Windows Hello, or a security key for faster, more secure sign-in.') }}</p>

    <!-- Status Message -->
    <div id="webauthn-status" class="hidden mb-4 p-3 border-2" role="alert"></div>

    <!-- Registration Form -->
    <div id="webauthn-register-form" class="space-y-4">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

      <!-- Passkey Name Input (shown after successful registration) -->
      <div id="friendly-name-section" class="hidden">
        <label for="friendly_name" class="block text-sm font-medium text-gray-700 dark:text-muted-foreground mb-2">{{ t('common.auth.webauthn.setup.friendlyNameLabel', 'Passkey Name (optional)') }}</label>
        <input type="text" id="friendly_name" name="friendly_name"
               placeholder="{{ t('common.auth.webauthn.setup.friendlyNamePlaceholder', 'e.g., MacBook Touch ID') }}"
               class="w-full px-3 py-2 bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-900 dark:text-foreground placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:border-primary" />
        <p class="mt-1 text-xs text-gray-500 dark:text-muted-foreground">{{ t('common.auth.webauthn.setup.friendlyNameHelp', 'A name to help you identify this passkey later') }}</p>
      </div>

      <!-- Register Button -->
      <button type="button" id="webauthn-register-btn"
              class="auth-btn w-full h-12 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white flex items-center justify-center space-x-2">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"></path>
        </svg>
        <span id="register-btn-text">{{ t('common.auth.webauthn.setup.registerButton', 'Register Passkey') }}</span>
      </button>

      <!-- Save Button (shown after registration) -->
      <button type="button" id="webauthn-save-btn"
              class="hidden w-full h-12 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white">
        {{ t('common.auth.webauthn.setup.saveButton', 'Save Passkey') }}
      </button>
    </div>

    <!-- Info Box -->
    <div class="mt-6 p-3 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800">
      <div class="flex">
        <svg class="h-5 w-5 text-blue-500 dark:text-blue-400 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div class="text-xs text-blue-800 dark:text-blue-200">
          <p class="font-medium mb-1">{{ t('common.auth.webauthn.setup.infoTitle', 'How it works') }}</p>
          <ul class="list-disc list-inside space-y-1">
            <li>{{ t('common.auth.webauthn.setup.infoStep1', 'Click "Register Passkey" to start') }}</li>
            <li>{{ t('common.auth.webauthn.setup.infoStep2', 'Use your device\'s biometric or security key') }}</li>
            <li>{{ t('common.auth.webauthn.setup.infoStep3', 'Optionally name your passkey for easy identification') }}</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="text-center mt-4">
      <a href="{{ cancelUrl or routes.accountFull.settings_security }}" class="text-sm text-gray-500 dark:text-muted-foreground hover:text-primary">{{ t('common.button.cancel', 'Cancel') }}</a>
    </div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="/js/webauthn/register.js"></script>

<!-- Configuration for WebAuthn Registration -->
<script id="___WEBAUTHN_REGISTER_STATE___" type="application/json">
{
  "config": {
    "apiBasePath": "{{ routes.api }}",
    "registerOptionsUrl": "{{ routes.api }}/webauthn/register/options",
    "registerVerifyUrl": "{{ routes.api }}/webauthn/register/verify",
    "successRedirectUrl": "{{ routes.accountFull.passkeys }}",
    "csrfToken": {{ csrfToken | tojson | safe }},
    "debug": {{ (app.env === 'development') | tojson }}
  },
  "translations": {
    "registerButton": {{ t('common.auth.webauthn.setup.registerButton', 'Register Passkey') | tojson | safe }},
    "registering": {{ t('common.auth.webauthn.setup.registering', 'Registering...') | tojson | safe }},
    "saving": {{ t('common.auth.webauthn.setup.saving', 'Saving...') | tojson | safe }},
    "successTitle": {{ t('common.auth.webauthn.setup.successTitle', 'Passkey Registered') | tojson | safe }},
    "successMessage": {{ t('common.auth.webauthn.setup.successMessage', 'Your passkey has been successfully registered. You can now use it for two-factor authentication.') | tojson | safe }},
    "errorTitle": {{ t('common.auth.webauthn.setup.errorTitle', 'Registration Failed') | tojson | safe }},
    "errorNotSecure": {{ t('common.auth.webauthn.setup.errorNotSecure', 'Passkeys require a secure connection (HTTPS). Please access this site over HTTPS to use passkeys.') | tojson | safe }},
    "errorNotSupported": {{ t('common.auth.webauthn.setup.errorNotSupported', 'Your browser does not support passkeys. Please use a modern browser like Chrome, Safari, Edge, or Firefox.') | tojson | safe }},
    "errorCancelled": {{ t('common.auth.webauthn.setup.errorCancelled', 'Registration was cancelled. Please try again.') | tojson | safe }},
    "errorGeneric": {{ t('common.auth.webauthn.setup.errorGeneric', 'An error occurred during registration. Please try again.') | tojson | safe }}
  }
}
</script>
{% endblock %}
