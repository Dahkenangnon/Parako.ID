{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-3">
                    <img src="{{ branding.logo }}" alt="{{ app.title }} Logo" class="dark:hidden h-12 w-auto" />
                    <img src="{{ branding.logoDark }}" alt="{{ app.title }} Logo" class="hidden dark:block h-12 w-auto" />
                </div>

                <!-- Success Icon -->
                <div class="flex justify-center mb-5">
                    <div class="bg-green-50 dark:bg-green-900 border-2 border-green-200 dark:border-green-700 p-4">
                        <svg class="h-12 w-12 text-green-500 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                </div>

                <!-- Success Message -->
                <div class="text-center mb-5">
                    <h2 class="auth-heading text-xl font-bold text-gray-900 dark:text-foreground">Email Verified!</h2>
                    <p class="text-sm text-gray-600 dark:text-muted-foreground mt-2">
                        Your email address {{ email or 'user@example.com' }} has been successfully verified.
                    </p>
                </div>

                <!-- Account Info (if provided) -->
                {% if accountName %}
                <div class="bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border p-4 mb-5">
                    <div class="flex items-center">
                        <div class="flex-shrink-0 mr-3">
                            <div class="bg-blue-50 dark:bg-blue-900 border-2 border-blue-200 dark:border-blue-700 h-10 w-10 flex items-center justify-center">
                                <span class="text-primary font-semibold text-lg">{{ accountInitials or 'U' }}</span>
                            </div>
                        </div>
                        <div>
                            <h3 class="text-sm font-medium text-gray-900 dark:text-foreground">{{ accountName }}</h3>
                            <p class="text-xs text-gray-500 dark:text-muted-foreground">{{ email or 'user@example.com' }}</p>
                        </div>
                    </div>
                </div>
                {% endif %}

                <!-- Action Buttons -->
                <div class="space-y-3">
                    <a href="{{ nextUrl or routes.accountFull.dashboard }}" class="auth-btn block w-full h-10 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white flex items-center justify-center">
                        {% if accountName %}
                            Continue to Your Account
                        {% else %}
                            Continue to Login
                        {% endif %}
                    </a>

                    <!-- Optional secondary action -->
                    {% if showSecondaryAction %}
                    <a href="{{ secondaryUrl or routes.app.home }}" class="block w-full h-10 bg-gray-100 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-700 dark:text-foreground font-medium hover:bg-gray-200 dark:hover:bg-accent flex items-center justify-center focus:outline-none">
                        {{ secondaryText or 'Back to Homepage' }}
                    </a>
                    {% endif %}
                </div>

                <!-- Extra Info (optional) -->
                {% if showExtraInfo %}
                <div class="mt-5 p-3 bg-blue-50 dark:bg-blue-900 border-2 border-blue-200 dark:border-blue-700">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-blue-400 dark:text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-xs text-blue-700 dark:text-blue-300">
                                {{ extraInfoText or 'You can now use all features of your account. Thank you for verifying your email address.' }}
                            </p>
                        </div>
                    </div>
                </div>
                {% endif %}
{% endblock %}

{% block scripts %}
{{ super() }}
{% endblock %}
