{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-3">
                    <img src="{{ branding.logo }}" alt="{{ app.title }} Logo" class="dark:hidden h-12 w-auto" />
                    <img src="{{ branding.logoDark }}" alt="{{ app.title }} Logo" class="hidden dark:block h-12 w-auto" />
                </div>

                {% if confirmed %}
                <!-- Signed Out Message (shown after confirmation) -->
                <div class="text-center mb-4">
                    <h2 class="auth-heading text-xl font-bold text-gray-900 dark:text-foreground mb-2">
                        {% if logoutType === 'all' %}
                            Signed Out from All Accounts
                        {% else %}
                            Signed Out Successfully
                        {% endif %}
                    </h2>
                    <p class="text-gray-600 dark:text-muted-foreground">
                        {% if logoutType === 'all' %}
                            You have been safely signed out from all {{ accountCount or 'your' }} account{{ 's' if accountCount !== 1 else '' }}.
                        {% elif accountName %}
                            You have been safely signed out from {{ accountName }}.
                        {% else %}
                            You have been safely signed out of your account.
                        {% endif %}
                    </p>
                </div>

                <div class="space-y-3 mb-4">
                    <a href="{{routes.authFull.login}}" class="auth-btn block w-full h-10 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white flex items-center justify-center">
                        Sign In Again
                    </a>

                    <a href="{{ redirectUri or routes.app.home }}" class="block w-full h-10 bg-gray-100 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-700 dark:text-foreground font-medium hover:bg-gray-200 dark:hover:bg-accent flex items-center justify-center focus:outline-none">
                        Go to Homepage
                    </a>
                </div>

                {% else %}
                <!-- Confirmation Request (shown initially) -->

                {% if hasMultipleAccounts %}
                <!-- Multiple Accounts - Show Account Selection -->
                <div class="text-center mb-4">
                    <h2 class="auth-heading text-xl font-bold text-gray-900 dark:text-foreground mb-2">Choose Sign Out Option</h2>
                    <p class="text-gray-600 dark:text-muted-foreground">
                        You have multiple accounts signed in. Choose how you'd like to sign out:
                    </p>
                </div>

                <!-- Sign Out Options -->
                <div class="space-y-3 mb-4">
                    <!-- Sign Out from All Accounts -->
                    <form action="{{ routes.authFull.logout }}" method="POST" class="w-full">
                        <!-- CSRF Token -->
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                        <input type="hidden" name="confirmed" value="true" />
                        <input type="hidden" name="type" value="all" />
                        <input type="hidden" name="redirect_uri" value="{{ redirectUri or routes.app.home }}" />

                        <button type="submit" class="block w-full">
                            <div class="flex items-center p-3 bg-red-50 dark:bg-red-900 border-2 border-red-200 dark:border-red-700 hover:bg-red-100 dark:hover:bg-red-800">
                                <div class="flex-shrink-0 mr-3">
                                    <div class="h-10 w-10 bg-red-500 border-2 border-red-600 flex items-center justify-center">
                                        <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0 text-left">
                                    <p class="text-sm font-medium text-gray-900 dark:text-white">Sign out from all accounts</p>
                                    <p class="text-xs text-gray-500 dark:text-gray-400">Remove all {{ accounts.length }} account{{ 's' if accounts.length !== 1 else '' }} from this device</p>
                                </div>
                                <div class="flex-shrink-0 ml-2">
                                    <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </div>
                            </div>
                        </button>
                    </form>

                    <!-- Sign Out from Specific Account -->
                    <div class="border-2 border-gray-200 dark:border-border p-3">
                        <div class="mb-2">
                            <div class="flex items-center mb-2">
                                <div class="h-8 w-8 bg-orange-500 border-2 border-orange-600 flex items-center justify-center mr-2">
                                    <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4 class="text-sm font-medium text-gray-900 dark:text-foreground">Sign out from specific account</h4>
                                    <p class="text-xs text-gray-600 dark:text-muted-foreground">Choose which account to sign out from</p>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-2 max-h-32 overflow-y-auto">
                            {% for account in accounts %}
                            <form action="{{ routes.authFull.logout }}" method="POST" class="w-full">
                                <!-- CSRF Token -->
                                <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                                <input type="hidden" name="confirmed" value="true" />
                                <input type="hidden" name="type" value="single" />
                                <input type="hidden" name="account_id" value="{{ account.id }}" />
                                <input type="hidden" name="redirect_uri" value="{{ redirectUri or routes.app.home }}" />

                                <button type="submit" class="block w-full">
                                    <div class="flex items-center p-2 bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border hover:bg-gray-100 dark:hover:bg-accent">
                                        <div class="flex-shrink-0 mr-2">
                                            {% if account.avatar %}
                                                <img src="{{ account.avatar }}" alt="{{ account.name }}" class="h-8 w-8 object-cover" />
                                            {% else %}
                                                <div class="h-8 w-8 bg-indigo-500 border-2 border-indigo-600 flex items-center justify-center">
                                                    <span class="text-xs font-medium text-white">{{ account.initials or 'U' }}</span>
                                                </div>
                                            {% endif %}
                                        </div>
                                        <div class="flex-1 min-w-0 text-left">
                                            <p class="text-xs font-medium text-gray-900 dark:text-white truncate">{{ account.name }}</p>
                                            {% if account.email %}
                                                <p class="text-xs text-gray-500 dark:text-gray-400 truncate">{{ account.email }}</p>
                                            {% endif %}
                                            {% if account.is_active %}
                                                <p class="text-xs text-indigo-600 dark:text-indigo-400">Currently signed in</p>
                                            {% endif %}
                                        </div>
                                        <div class="flex-shrink-0 ml-2">
                                            <svg class="h-4 w-4 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                            </svg>
                                        </div>
                                    </div>
                                </button>
                            </form>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <!-- Cancel Button -->
                <div class="mb-2">
                    <a href="{{ cancelUrl or '/' }}" class="flex items-center justify-center w-full h-10 bg-gray-100 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-700 dark:text-foreground font-medium hover:bg-gray-200 dark:hover:bg-accent focus:outline-none">
                        <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        <span>Cancel</span>
                    </a>
                </div>

                {% else %}
                <!-- Single Account - Simple Confirmation -->
                <div class="text-center mb-4">
                    <h2 class="auth-heading text-xl font-bold text-gray-900 dark:text-foreground mb-2">Sign Out</h2>
                    <p class="text-gray-600 dark:text-muted-foreground">
                        Are you sure you want to sign out of your account?
                    </p>

                    {% if sessionInfo %}
                    <div class="mt-3 p-3 bg-gray-50 dark:bg-muted border-2 border-gray-200 dark:border-border">
                        <div class="flex items-center">
                            <div class="flex-shrink-0 mr-3">
                                {% if sessionInfo.avatar %}
                                    <img src="{{ sessionInfo.avatar }}" alt="{{ sessionInfo.name }}" class="h-10 w-10 object-cover" />
                                {% else %}
                                    <div class="h-10 w-10 bg-indigo-500 border-2 border-indigo-600 flex items-center justify-center">
                                        <span class="text-sm font-medium text-white">{{ sessionInfo.initials or 'U' }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="text-left">
                                <p class="text-sm font-medium text-gray-900 dark:text-foreground">{{ sessionInfo.name or '' }}</p>
                                <p class="text-xs text-gray-500 dark:text-muted-foreground">{{ sessionInfo.email or '' }}</p>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>

                <form action="{{ routes.authFull.logout }}" method="POST" class="space-y-3 mb-4">
                <!-- CSRF Token -->
                <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                    <input type="hidden" name="confirmed" value="true" />
                    <input type="hidden" name="type" value="single" />
                    <input type="hidden" name="redirect_uri" value="{{ redirectUri or routes.app.home }}" />

                    <button type="submit" class="auth-btn w-full h-10 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white">
                        Confirm Sign Out
                    </button>
                </form>

                <!-- Cancel Button -->
                <div>
                    <a href="{{ cancelUrl or routes.app.home }}" class="flex items-center justify-center w-full h-10 bg-gray-100 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-700 dark:text-foreground font-medium hover:bg-gray-200 dark:hover:bg-accent focus:outline-none">
                        <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        <span>Cancel</span>
                    </a>
                </div>
                {% endif %}

                {% endif %}
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="/js/auth/logout.js"></script>

<!-- Complete configuration and translations for LogoutManager -->
<script id="___LOGOUT_STATE___" type="application/json">
{
  "config": {
    "enableConfirmation": true,
    "debug": {{ (app.env === 'development') | tojson }},
    "csrfToken": {{ csrfToken | tojson | safe }}
  },
  "translations": {
    "confirmSignOut": {{ t('auth.confirmSignOut', 'Confirm Sign Out') | tojson | safe }},
    "signingOut": {{ t('auth.signingOut', 'Signing Out...') | tojson | safe }},
    "confirmSignOutAll": {{ t('auth.confirmSignOutAll', 'Are you sure you want to sign out from all {count} accounts? This will remove all signed-in accounts from this device.') | tojson | safe }},
    "confirmSignOutSingle": {{ t('auth.confirmSignOutSingle', 'Are you sure you want to sign out from your account?') | tojson | safe }}
  }
}
</script>

{% endblock %}
