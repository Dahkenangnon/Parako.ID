{% extends "layouts/admin-layout.njk" %}
{% block admin_content %}
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="mb-6">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="min-w-0 flex-1">
                    <h1 class="text-xl sm:text-2xl font-bold text-foreground truncate">JWKS Key Management</h1>
                    <p class="mt-1 text-sm text-muted-foreground">View and manage JSON Web Key Sets used for token signing</p>
                </div>
                <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
                    <form method="post" action="/admin/jwks/rotate" class="inline" onsubmit="return confirmRotateKeys(event)">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <button type="submit"
                            class="inline-flex items-center justify-center px-3 sm:px-4 py-2 bg-primary text-primary-foreground text-sm
                                font-medium hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 w-full sm:w-auto">
                            <i data-lucide="refresh-cw" class="h-4 w-4 mr-1 sm:mr-2"></i>
                            Rotate Keys
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Rotation Warning Banner -->
        {% if needsRotation %}
        <div class="mb-6 bg-warning/10 border border-warning/30 p-4">
            <div class="flex items-start gap-3">
                <i data-lucide="alert-triangle" class="h-5 w-5 text-warning-foreground dark:text-warning flex-shrink-0 mt-0.5"></i>
                <div class="flex-1">
                    <h3 class="text-sm font-medium text-warning-foreground dark:text-warning">Key rotation is due</h3>
                    <p class="mt-1 text-sm text-muted-foreground">
                        Your keys have exceeded the configured rotation interval. It is recommended to rotate them now.
                    </p>
                </div>
                <form method="post" action="/admin/jwks/rotate" class="flex-shrink-0" onsubmit="return confirmRotateKeys(event)">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <button type="submit"
                        class="inline-flex items-center px-3 py-1.5 bg-warning text-warning-foreground text-sm font-medium hover:bg-warning/90">
                        Rotate Now
                    </button>
                </form>
            </div>
        </div>
        {% endif %}

        {% if keyStoreConfig.type == 'file' %}
        <div class="mb-6 bg-secondary/10 border border-secondary/30 p-4">
            <div class="flex items-start gap-3">
                <i data-lucide="info" class="h-5 w-5 text-secondary-foreground flex-shrink-0 mt-0.5"></i>
                <div>
                    <h3 class="text-sm font-medium text-foreground">File-based key store</h3>
                    <p class="mt-1 text-sm text-muted-foreground">
                        Keys are stored in a local file. Rotation replaces the file contents. For production use, consider switching to database-backed key storage.
                    </p>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- Configuration Info Card -->
        <div class="bg-card border border-border mb-6">
            <div class="px-6 py-4 border-b border-border">
                <h2 class="text-lg font-semibold text-foreground flex items-center">
                    <i data-lucide="settings" class="h-5 w-5 mr-2 text-primary"></i>
                    Configuration
                </h2>
            </div>
            <div class="p-6">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                    <div>
                        <label class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Key Store Type</label>
                        <p class="mt-1 text-sm text-foreground font-medium capitalize">{{ keyStoreConfig.type }}</p>
                    </div>
                    <div>
                        <label class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Algorithms</label>
                        <div class="mt-1 flex flex-wrap gap-1">
                            {% for alg in keyStoreConfig.algorithms %}
                            <span class="inline-flex items-center px-2 py-0.5 text-xs font-mono font-medium bg-muted text-foreground">{{ alg }}</span>
                            {% endfor %}
                        </div>
                    </div>
                    <div>
                        <label class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Rotation Interval</label>
                        <p class="mt-1 text-sm text-foreground font-medium">{{ keyStoreConfig.rotation_interval_days }} days</p>
                    </div>
                    <div>
                        <label class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Overlap Window</label>
                        <p class="mt-1 text-sm text-foreground font-medium">{{ (keyStoreConfig.overlap_window_seconds / 3600) | round(1) }} hours</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Grid -->
        <div class="grid grid-cols-1 xs:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-6">
            <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Total Keys</p>
                        <p class="mt-2 text-2xl font-bold text-foreground">{{ stats.total }}</p>
                    </div>
                    <div class="flex-shrink-0 ml-3">
                        <div class="w-12 h-12 bg-primary/10 flex items-center justify-center">
                            <i data-lucide="file-key" class="h-6 w-6 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Active</p>
                        <p class="mt-2 text-2xl font-bold text-foreground">{{ stats.active }}</p>
                    </div>
                    <div class="flex-shrink-0 ml-3">
                        <div class="w-12 h-12 bg-primary/10 flex items-center justify-center">
                            <i data-lucide="check-circle" class="h-6 w-6 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Expiring</p>
                        <p class="mt-2 text-2xl font-bold text-foreground">{{ stats.expiring }}</p>
                    </div>
                    <div class="flex-shrink-0 ml-3">
                        <div class="w-12 h-12 bg-warning/10 flex items-center justify-center">
                            <i data-lucide="clock" class="h-6 w-6 text-warning-foreground dark:text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Retired</p>
                        <p class="mt-2 text-2xl font-bold text-foreground">{{ stats.retired }}</p>
                    </div>
                    <div class="flex-shrink-0 ml-3">
                        <div class="w-12 h-12 bg-muted flex items-center justify-center">
                            <i data-lucide="archive" class="h-6 w-6 text-muted-foreground"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Keys Table -->
        <div class="bg-card border border-border mb-6">
            <div class="px-6 py-4 border-b border-border">
                <div class="flex items-center justify-between">
                    <h2 class="text-lg font-semibold text-foreground flex items-center">
                        <i data-lucide="file-key" class="h-5 w-5 mr-2 text-primary"></i>
                        Keys
                    </h2>
                    <div class="text-sm text-muted-foreground">
                        {{ stats.total }} key{{ 's' if stats.total != 1 else '' }}
                    </div>
                </div>
            </div>
            {% if keys and keys.length > 0 %}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-border">
                        <thead class="bg-muted/50 border-b border-border">
                            <tr>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Key ID</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Algorithm</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Usage</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Status</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Created</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Rotated At</th>
                                <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-muted-foreground uppercase tracking-wide">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-card divide-y divide-border">
                            {% for key in keys %}
                            <tr class="hover:bg-muted/50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm font-mono text-foreground truncate max-w-[180px]" title="{{ key.kid }}">{{ key.kid }}</span>
                                        <button type="button"
                                            onclick="copyToClipboard('{{ key.kid }}', this)"
                                            class="text-muted-foreground hover:text-foreground flex-shrink-0"
                                            title="Copy Key ID">
                                            <i data-lucide="copy" class="h-3.5 w-3.5"></i>
                                        </button>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2 py-0.5 text-xs font-mono font-medium bg-muted text-foreground">{{ key.alg }}</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-sm text-foreground">{{ key.use }}</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    {% if key.status == 'active' and key.promoted %}
                                        <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-primary/10 text-primary">
                                            <i data-lucide="check-circle" class="h-3 w-3 mr-1"></i>
                                            Active
                                        </span>
                                    {% elif key.status == 'active' and not key.promoted %}
                                        <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-secondary/10 text-secondary-foreground">
                                            <i data-lucide="clock" class="h-3 w-3 mr-1"></i>
                                            Pending promotion
                                        </span>
                                    {% elif key.status == 'expiring' %}
                                        <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-warning/10 text-warning-foreground dark:text-warning">
                                            <i data-lucide="clock" class="h-3 w-3 mr-1"></i>
                                            Expiring
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-muted text-muted-foreground">
                                            <i data-lucide="archive" class="h-3 w-3 mr-1"></i>
                                            Retired
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-sm text-foreground">{{ key.createdAt | date("MMM DD, YYYY HH:mm", displayTimezone) }}</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    {% if key.rotatedAt %}
                                        <span class="text-sm text-foreground">{{ key.rotatedAt | date("MMM DD, YYYY HH:mm", displayTimezone) }}</span>
                                    {% else %}
                                        <span class="text-sm text-muted-foreground">-</span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <a href="/admin/jwks/{{ key.kid }}" class="text-primary hover:text-primary/80" title="View Details">
                                        <i data-lucide="eye" class="h-4 w-4"></i>
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="p-8 text-center">
                    <i data-lucide="file-key" class="h-16 w-16 text-muted-foreground mx-auto mb-4"></i>
                    <h3 class="text-lg font-medium text-foreground mb-2">No Keys Found</h3>
                    <p class="text-muted-foreground">
                        No JWKS keys are currently stored. Keys will be generated automatically when the OIDC provider starts.
                    </p>
                </div>
            {% endif %}
        </div>

        <!-- Danger Zone -->
        {% if stats.expiring > 0 or stats.retired > 0 %}
        <div class="bg-card border border-destructive/30 mb-6">
            <div class="px-6 py-4 border-b border-destructive/30">
                <h2 class="text-lg font-semibold text-foreground flex items-center">
                    <i data-lucide="alert-triangle" class="h-5 w-5 mr-2 text-destructive"></i>
                    Maintenance
                </h2>
            </div>
            <div class="p-6">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div>
                        <h3 class="text-sm font-medium text-foreground">Retire Expired Keys</h3>
                        <p class="mt-1 text-sm text-muted-foreground">
                            Remove keys that have passed the overlap window. This only affects keys in "expiring" status
                            that are no longer needed for token verification.
                        </p>
                    </div>
                    <form method="post" action="/admin/jwks/retire-expired" class="flex-shrink-0" onsubmit="return confirmRetireExpired(event)">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <button type="submit"
                            class="inline-flex items-center px-4 py-2 bg-secondary text-secondary-foreground text-sm font-medium
                                hover:bg-secondary/80 focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2">
                            <i data-lucide="archive" class="h-4 w-4 mr-2"></i>
                            Retire Expired Keys
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="/js/admin/jwks.js"></script>
{% endblock %}
