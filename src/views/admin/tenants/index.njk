{% extends "layouts/admin-layout.njk" %}

{% block admin_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Page Header -->
    <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="min-w-0 flex-1">
                <h1 class="text-xl sm:text-2xl font-bold text-foreground truncate">Tenant Management</h1>
                <p class="mt-1 text-sm text-muted-foreground">Manage tenants across the platform</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
                <a href="/admin/tenants/new" class="inline-flex items-center justify-center px-3 sm:px-4 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                    <i data-lucide="plus" class="h-4 w-4 mr-1 sm:mr-2"></i>
                    <span class="hidden xs:inline">New Tenant</span>
                    <span class="xs:hidden">New</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Statistics Grid -->
    <div class="grid grid-cols-1 xs:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-6">
        <!-- Total -->
        <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
            <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Total</p>
                    <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ stats.total | default(0) }}</p>
                </div>
                <div class="flex-shrink-0 ml-3">
                    <div class="w-12 h-12 bg-primary/10 flex items-center justify-center">
                        <i data-lucide="building-2" class="h-6 w-6 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Active -->
        <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
            <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Active</p>
                    <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ stats.active | default(0) }}</p>
                </div>
                <div class="flex-shrink-0 ml-3">
                    <div class="w-12 h-12 bg-primary/10 flex items-center justify-center">
                        <i data-lucide="check-circle" class="h-6 w-6 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Suspended -->
        <div class="bg-card border border-border p-4 hover:border-warning/30 transition-colors">
            <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Suspended</p>
                    <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ stats.suspended | default(0) }}</p>
                </div>
                <div class="flex-shrink-0 ml-3">
                    <div class="w-12 h-12 bg-warning/10 flex items-center justify-center">
                        <i data-lucide="pause-circle" class="h-6 w-6 text-warning"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Archived -->
        <div class="bg-card border border-border p-4 hover:border-secondary/30 transition-colors">
            <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Archived</p>
                    <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ stats.archived | default(0) }}</p>
                </div>
                <div class="flex-shrink-0 ml-3">
                    <div class="w-12 h-12 bg-secondary/10 flex items-center justify-center">
                        <i data-lucide="archive" class="h-6 w-6 text-secondary-foreground"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="bg-card border border-border p-4 mb-6">
        <form method="GET" action="/admin/tenants" class="flex flex-col sm:flex-row gap-3 items-end">
            <div class="flex-1 min-w-0">
                <label for="status-filter" class="block text-sm font-medium text-foreground mb-1">Status</label>
                <select id="status-filter" name="status" class="w-full sm:w-48 px-3 py-2 border border-input bg-background text-foreground text-sm focus:outline-none focus:ring-2 focus:ring-ring">
                    <option value="" {% if not filters.status %}selected{% endif %}>All statuses</option>
                    <option value="active" {% if filters.status == 'active' %}selected{% endif %}>Active</option>
                    <option value="suspended" {% if filters.status == 'suspended' %}selected{% endif %}>Suspended</option>
                    <option value="archived" {% if filters.status == 'archived' %}selected{% endif %}>Archived</option>
                </select>
            </div>
            <button type="submit" class="inline-flex items-center px-4 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                <i data-lucide="filter" class="h-4 w-4 mr-2"></i>
                Filter
            </button>
        </form>
    </div>

    <!-- Tenants Table -->
    {% if tenants and tenants.length > 0 %}
    <div class="bg-card border border-border overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-border">
                <thead class="bg-muted/50">
                    <tr>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Slug</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Display Name</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider hidden sm:table-cell">Domain</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Status</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider hidden md:table-cell">Created</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-muted-foreground uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    {% for tenant in tenants %}
                    <tr class="hover:bg-muted/50 transition-colors">
                        <td class="px-4 py-3 text-sm font-mono text-foreground">{{ tenant.slug }}</td>
                        <td class="px-4 py-3 text-sm text-foreground">{{ tenant.display_name }}</td>
                        <td class="px-4 py-3 text-sm text-muted-foreground hidden sm:table-cell">{{ tenant.domain or '—' }}</td>
                        <td class="px-4 py-3">
                            {% if tenant.status == 'active' %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-primary/10 text-primary">Active</span>
                            {% elif tenant.status == 'suspended' %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-warning/10 text-warning">Suspended</span>
                            {% elif tenant.status == 'archived' %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-secondary text-secondary-foreground">Archived</span>
                            {% else %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-muted text-muted-foreground">{{ tenant.status }}</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 text-sm text-muted-foreground hidden md:table-cell">
                            {% if tenant.createdAt %}
                                {{ tenant.createdAt | date('YYYY-MM-DD') }}
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="/admin/tenants/{{ tenant.slug }}" class="inline-flex items-center px-2.5 py-1.5 text-xs font-medium text-foreground border border-border hover:bg-muted" title="View">
                                    <i data-lucide="eye" class="h-3.5 w-3.5 mr-1"></i>
                                    View
                                </a>
                                <a href="/admin/tenants/{{ tenant.slug }}/edit" class="inline-flex items-center px-2.5 py-1.5 text-xs font-medium text-foreground border border-border hover:bg-muted" title="Edit">
                                    <i data-lucide="edit" class="h-3.5 w-3.5 mr-1"></i>
                                    Edit
                                </a>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% else %}
    <!-- Empty State -->
    <div class="bg-card border border-border p-12 text-center">
        <div class="w-16 h-16 bg-muted mx-auto flex items-center justify-center mb-4">
            <i data-lucide="building-2" class="h-8 w-8 text-muted-foreground"></i>
        </div>
        <h3 class="text-lg font-medium text-foreground mb-2">No tenants found</h3>
        <p class="text-sm text-muted-foreground">
            {% if filters.status %}
                No tenants match the selected filter. Try a different status filter.
            {% else %}
                No tenants have been created yet.
            {% endif %}
        </p>
    </div>
    {% endif %}
</div>
{% endblock %}
