{% extends "layouts/admin-layout.njk" %}

{% block admin_content %}
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Page Header -->
    <div class="mb-8">
        <nav class="flex mb-4" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-2 text-sm">
                <li>
                    <a href="/admin" class="text-muted-foreground hover:text-foreground">Admin</a>
                </li>
                <li class="text-muted-foreground">/</li>
                <li>
                    <a href="/admin/tenants" class="text-muted-foreground hover:text-foreground">Tenants</a>
                </li>
                <li class="text-muted-foreground">/</li>
                <li class="text-foreground font-medium">New Tenant</li>
            </ol>
        </nav>

        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div class="flex-1">
                <h1 class="text-xl sm:text-2xl font-bold text-foreground">New Tenant</h1>
                <p class="mt-2 text-sm text-muted-foreground">Create a new tenant for the platform</p>
            </div>
            <a href="/admin/tenants" class="inline-flex items-center px-4 py-2 border border-border text-sm font-medium text-foreground bg-card hover:bg-muted w-full sm:w-auto justify-center">
                <i data-lucide="arrow-left" class="h-4 w-4 mr-2"></i>
                Back to Tenants
            </a>
        </div>
    </div>

    {% if error %}
    <div class="mb-6 bg-destructive/10 border border-destructive/30 p-4">
        <div class="flex items-center gap-2">
            <i data-lucide="alert-circle" class="h-5 w-5 text-destructive flex-shrink-0"></i>
            <p class="text-sm text-destructive">{{ error }}</p>
        </div>
    </div>
    {% endif %}

    <!-- Create Form -->
    <form method="POST" action="/admin/tenants/new" class="space-y-6">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        <div class="bg-card border border-border p-4 sm:p-6 lg:p-8">
            <h3 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                <i data-lucide="building-2" class="h-5 w-5 mr-2 text-primary"></i>
                Tenant Information
            </h3>

            <div class="space-y-6">
                <!-- Slug -->
                <div>
                    <label for="slug" class="block text-sm font-medium text-foreground mb-1">
                        Slug <span class="text-destructive">*</span>
                    </label>
                    <input type="text" id="slug" name="slug"
                        value="{{ formData.slug if formData else '' }}"
                        required
                        pattern="[a-z0-9][a-z0-9_-]{0,62}"
                        placeholder="my-tenant"
                        class="w-full px-3 py-2 border border-input bg-background text-foreground text-sm focus:outline-none focus:ring-2 focus:ring-ring">
                    <p class="mt-1 text-xs text-muted-foreground">Lowercase alphanumeric characters, hyphens, or underscores. 1-63 characters. Cannot be changed after creation.</p>
                </div>

                <!-- Display Name -->
                <div>
                    <label for="display_name" class="block text-sm font-medium text-foreground mb-1">
                        Display Name <span class="text-destructive">*</span>
                    </label>
                    <input type="text" id="display_name" name="display_name"
                        value="{{ formData.display_name if formData else '' }}"
                        required
                        placeholder="My Tenant"
                        class="w-full px-3 py-2 border border-input bg-background text-foreground text-sm focus:outline-none focus:ring-2 focus:ring-ring">
                    <p class="mt-1 text-xs text-muted-foreground">Human-readable name displayed in the UI.</p>
                </div>

                <!-- Domain -->
                <div>
                    <label for="domain" class="block text-sm font-medium text-foreground mb-1">
                        Domain
                    </label>
                    <input type="text" id="domain" name="domain"
                        value="{{ formData.domain if formData else '' }}"
                        placeholder="tenant.example.com"
                        class="w-full px-3 py-2 border border-input bg-background text-foreground text-sm focus:outline-none focus:ring-2 focus:ring-ring">
                    <p class="mt-1 text-xs text-muted-foreground">Optional custom domain for this tenant.</p>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row gap-3 justify-end">
            <a href="/admin/tenants" class="inline-flex items-center justify-center px-4 py-2 border border-border text-sm font-medium text-foreground bg-card hover:bg-muted">
                Cancel
            </a>
            <button type="submit" class="inline-flex items-center justify-center px-4 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90">
                <i data-lucide="plus" class="h-4 w-4 mr-2"></i>
                Create Tenant
            </button>
        </div>
    </form>
</div>
{% endblock %}
