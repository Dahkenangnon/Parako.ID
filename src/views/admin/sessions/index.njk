{% extends "layouts/admin-layout.njk" %}
{% block admin_content %}
    <div
        class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="mb-6">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="min-w-0 flex-1">
                    <h1 class="text-xl sm:text-2xl font-bold text-foreground truncate">User Sessions</h1>
                    <p class="mt-1 text-sm text-muted-foreground">Monitor and manage all active user sessions across the platform</p>
                </div>
            </div>
        </div>
        <!-- Statistics Grid -->
        <div class="grid grid-cols-1 xs:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-6">
            <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Total Sessions</p>
                        <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ (pagination.totalSessions | default(0)) + (expressPagination.totalSessions | default(0)) }}</p>
                    </div>
                    <div class="flex-shrink-0 ml-3">
                        <div class="w-12 h-12 bg-primary/10 flex items-center justify-center">
                            <i data-lucide="monitor" class="h-6 w-6 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">OIDC Sessions</p>
                        <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ pagination.totalSessions | default(0) }}</p>
                    </div>
                    <div class="flex-shrink-0 ml-3">
                        <div class="w-12 h-12 bg-primary/10 flex items-center justify-center">
                            <i data-lucide="shield" class="h-6 w-6 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Express Sessions</p>
                        <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ expressPagination.totalSessions | default(0) }}</p>
                    </div>
                    <div class="flex-shrink-0 ml-3">
                        <div class="w-12 h-12 bg-secondary/10 flex items-center justify-center">
                            <i data-lucide="log-in" class="h-6 w-6 text-secondary-foreground"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">With Apps</p>
                        <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ sessions | selectattr('clients') | selectattr('clients.length', 'greaterthan', 0) | list | length | default(0) }}</p>
                    </div>
                    <div class="flex-shrink-0 ml-3">
                        <div class="w-12 h-12 bg-secondary/10 flex items-center justify-center">
                            <i data-lucide="grid-3x3" class="h-6 w-6 text-secondary-foreground"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Advanced Filter Section -->
        <div class="bg-card border border-border overflow-hidden mb-6">
            <form
                method="GET" action="/admin/sessions">
                <!-- Filter Header -->
                <div class="bg-muted/50 px-4 py-2 border-b border-border">
                    <div class="flex items-center gap-2">
                        <i data-lucide="filter" class="h-4 w-4 text-muted-foreground"></i>
                        <h3 class="text-sm font-medium text-foreground">Filters</h3>
                    </div>
                </div>
                <!-- Filter Controls -->
                <div
                    class="p-4 space-y-4">
                    <!-- Search Section -->
                    <div>
                        <label for="search" class="block text-xs font-medium text-muted-foreground mb-2">Search</label>
                        <div class="relative">
                            <i
                                data-lucide="search"
                                class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none"></i>
                            <input type="text" name="search" id="search" value="{{ filters.search }}" placeholder="Username, email, device, IP..." class="w-full pl-10 pr-3 py-2 text-sm border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"></div>
                        </div>
                        <!-- Filter & Sort Grid -->
                        <div>
                            <label class="block text-xs font-medium text-muted-foreground mb-2">Filter & Sort</label>
                            <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                                <div class="relative">
                                    <input type="text" name="username" placeholder="Username..." value="{{ filters.username }}" class="w-full px-3 py-2 text-sm border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"></div>
                                    <div class="relative">
                                        <select
                                            name="status"
                                            class="appearance-none w-full px-3 py-2 pr-8 text-sm border border-border bg-background focus:outline-none focus:ring-2
                                                focus:ring-primary/20 focus:border-primary">
                                            <option value="all" {{ 'selected' if filters.status == 'all' }}>All Sessions</option>
                                            <option value="active" {{ 'selected' if filters.status == 'active' }}>Active Only</option>
                                            <option value="expired" {{ 'selected' if filters.status == 'expired' }}>Expired Only</option>
                                        </select>
                                        <i
                                            data-lucide="chevron-down"
                                            class="absolute right-2 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none"></i>
                                    </div>
                                    <div class="relative">
                                        <select
                                            name="sortBy"
                                            class="appearance-none w-full px-3 py-2 pr-8 text-sm border border-border bg-background focus:outline-none focus:ring-2
                                                focus:ring-primary/20 focus:border-primary">
                                            <option value="loginTime" {{ 'selected' if filters.sortBy == 'loginTime' }}>Login Time</option>
                                            <option value="username" {{ 'selected' if filters.sortBy == 'username' }}>Username</option>
                                            <option value="expiresAt" {{ 'selected' if filters.sortBy == 'expiresAt' }}>Expires At</option>
                                        </select>
                                        <i
                                            data-lucide="chevron-down"
                                            class="absolute right-2 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none"></i>
                                    </div>
                                    <div class="relative">
                                        <select
                                            name="sortOrder"
                                            class="appearance-none w-full px-3 py-2 pr-8 text-sm border border-border bg-background focus:outline-none focus:ring-2
                                                focus:ring-primary/20 focus:border-primary">
                                            <option value="desc" {{ 'selected' if filters.sortOrder == 'desc' }}>Descending</option>
                                            <option value="asc" {{ 'selected' if filters.sortOrder == 'asc' }}>Ascending</option>
                                        </select>
                                        <i
                                            data-lucide="chevron-down"
                                            class="absolute right-2 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Action Footer -->
                        <div class="bg-muted/30 px-4 py-3 border-t border-border flex flex-col sm:flex-row gap-2 sm:justify-end">
                            <button
                                type="submit"
                                class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-primary text-primary-foreground text-sm font-medium
                                    hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                                <i data-lucide="filter" class="h-4 w-4"></i>
                                <span>Apply Filters</span>
                            </button>
                            <a
                                href="/admin/sessions"
                                class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-secondary text-secondary-foreground text-sm font-medium
                                    hover:bg-secondary/80 focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2">
                                <i data-lucide="x" class="h-4 w-4"></i>
                                <span>Clear Filters</span>
                            </a>
                        </div>
                    </form>
                </div>

                {# ── OIDC Sessions Table ── #}
                <div class="bg-card border border-border mb-6">
                    <div class="px-6 py-4 border-b border-border">
                        <div class="flex items-center justify-between">
                            <h2 class="text-lg font-semibold text-foreground flex items-center">
                                <i data-lucide="shield" class="h-5 w-5 mr-2 text-primary"></i>
                                OIDC Sessions
                            </h2>
                            <div class="text-sm text-muted-foreground">
                                {% if pagination.totalSessions > 0 %}
                                    Showing {{ pagination.startIndex }}-{{ pagination.endIndex }} of
                                    {{ pagination.totalSessions }} sessions
                                {% else %}
                                    No sessions
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% if sessions and sessions.length > 0 %}
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-border">
                                <thead class="bg-muted/50 border-b border-border">
                                    <tr>
                                        <th scope="col" class="px-6 py-3 text-left">
                                            <a
                                                href="?sortBy=username&sortOrder={% if filters.sortBy == 'username' and filters.sortOrder == 'asc' %}desc{% else %}asc{% endif %}{% if filters.search %}&search={{ filters.search }}{% endif %}{% if filters.username %}&username={{ filters.username }}{% endif %}{% if filters.status != 'all' %}&status={{ filters.status }}{% endif %}"
                                                class="group inline-flex items-center gap-1.5 text-xs font-semibold text-muted-foreground uppercase tracking-wide
                                                    hover:text-foreground transition-colors">
                                                <span>User</span>
                                                {% if filters.sortBy == 'username' %}
                                                    {% if filters.sortOrder == 'asc' %}
                                                        <i data-lucide="arrow-up" class="h-3 w-3 text-foreground"></i>
                                                    {% else %}
                                                        <i data-lucide="arrow-down" class="h-3 w-3 text-foreground"></i>
                                                    {% endif %}
                                                {% endif %}
                                            </a>
                                        </th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Device</th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Status</th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Type</th>
                                        <th scope="col" class="px-6 py-3 text-left">
                                            <a
                                                href="?sortBy=loginTime&sortOrder={% if filters.sortBy == 'loginTime' and filters.sortOrder == 'asc' %}desc{% else %}asc{% endif %}{% if filters.search %}&search={{ filters.search }}{% endif %}{% if filters.username %}&username={{ filters.username }}{% endif %}{% if filters.status != 'all' %}&status={{ filters.status }}{% endif %}"
                                                class="group inline-flex items-center gap-1.5 text-xs font-semibold text-muted-foreground uppercase tracking-wide
                                                    hover:text-foreground transition-colors">
                                                <span>Login Time</span>
                                                {% if filters.sortBy == 'loginTime' %}
                                                    {% if filters.sortOrder == 'asc' %}
                                                        <i data-lucide="arrow-up" class="h-3 w-3 text-foreground"></i>
                                                    {% else %}
                                                        <i data-lucide="arrow-down" class="h-3 w-3 text-foreground"></i>
                                                    {% endif %}
                                                {% endif %}
                                            </a>
                                        </th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">
                                        Connected Apps</th>
                                        <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-muted-foreground uppercase tracking-wide">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-card divide-y divide-border">
                                    {% for session in sessions %}
                                        <tr
                                            class="hover:bg-muted/50 transition-colors">
                                            <!-- User Info -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                <div class="min-w-0 flex-1">
                                                    <div class="text-sm font-medium text-foreground truncate max-w-32" title="{{ session.userInfo.full_name }}">{{ session.userInfo.full_name }}</div>
                                                    <div class="text-sm text-muted-foreground truncate max-w-32" title="{{ session.userInfo.username }}">{{ session.userInfo.username }}</div>
                                                    {% if session.userInfo.email and session.userInfo.email != 'Unknown' %}
                                                        <div class="text-xs text-muted-foreground truncate max-w-32" title="{{ session.userInfo.email }}">{{ session.userInfo.email }}</div>
                                                    {% endif %}
                                                </div>
                                            </td>
                                            <!-- Device Info -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                <div class="text-sm text-foreground truncate max-w-32" title="{{ session.device }}">{{ session.device }}</div>
                                                <div class="text-xs text-muted-foreground truncate max-w-32" title="{{ session.location }}">{{ session.location }}</div>
                                            </td>
                                            <!-- Status -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                {% if session.status == 'active' %}
                                                    <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-primary/10 text-primary">
                                                        <i data-lucide="check-circle" class="h-3 w-3 mr-1"></i>
                                                        Active
                                                    </span>
                                                {% else %}
                                                    <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-warning/10 text-warning-foreground
                                                            dark:text-warning">
                                                        <i data-lucide="x-circle" class="h-3 w-3 mr-1"></i>
                                                        Expired
                                                    </span>
                                                {% endif %}
                                            </td>
                                            <!-- Type -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-violet-100 text-violet-800 dark:bg-violet-900/30 dark:text-violet-300">
                                                    <i data-lucide="shield" class="h-3 w-3 mr-1"></i>
                                                    OIDC
                                                </span>
                                            </td>
                                            <!-- Login Time -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                <div class="text-sm text-foreground truncate max-w-32" title="{{ session.startTime }}">{{ session.startTime }}</div>
                                                <div class="text-xs text-muted-foreground truncate max-w-32" title="{{ session.sessionAge }}">{{ session.sessionAge }}</div>
                                            </td>
                                            <!-- Connected Apps -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                {% if session.clients and session.clients.length > 0 %}
                                                    <div class="text-sm text-foreground">
                                                        {% for client in session.clients %}
                                                            {{ client.name }}
                                                            {% if not loop.last %},
                                                            {% endif %}
                                                        {% endfor %}
                                                    </div>
                                                {% else %}
                                                    <span class="text-xs text-muted-foreground">None</span>
                                                {% endif %}
                                            </td>
                                            <!-- Actions -->
                                            <td class="px-6 py-5 whitespace-nowrap text-right text-sm font-medium">
                                                <div class="flex items-center justify-end space-x-2">
                                                    <a href="/admin/sessions/{{ session.id }}?type=oidc" class="text-primary hover:text-primary/80" title="View Details">
                                                        <i data-lucide="eye" class="h-4 w-4"></i>
                                                    </a>
                                                    {% if session.status == 'active' %}
                                                        <form
                                                            method="post"
                                                            action="/admin/sessions/{{ session.id }}/revoke"
                                                            class="inline">
                                                            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                                                            <input type="hidden" name="sessionType" value="oidc">
                                                                <button type="submit" class="text-destructive hover:text-destructive/80" title="Revoke Session">
                                                                    <i data-lucide="power-off" class="h-4 w-4"></i>
                                                                </button>
                                                            </form>
                                                        {% endif %}
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                            <!-- OIDC Pagination -->
                            {% if pagination.totalPages > 1 %}
                                <div class="px-6 py-4 border-t border-border">
                                    <div class="flex items-center justify-between">
                                        <div class="text-sm text-muted-foreground">
                                            Page {{ pagination.page }} of {{ pagination.totalPages }}
                                        </div>
                                        <div class="flex space-x-2">
                                            {% if pagination.hasPrev %}
                                                <a
                                                    href="?page={{ pagination.page - 1 }}&limit={{ pagination.limit }}&search={{ filters.search }}&username={{ filters.username }}&status={{ filters.status }}&sortBy={{ filters.sortBy }}&sortOrder={{ filters.sortOrder }}{% if expressPagination.page > 1 %}&expressPage={{ expressPagination.page }}{% endif %}"
                                                    class="inline-flex items-center px-3 py-2 border border-border text-sm font-medium text-foreground bg-background
                                                        hover:bg-muted focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2">
                                                    <i data-lucide="chevron-left" class="h-4 w-4 mr-1"></i>
                                                    Previous
                                                </a>
                                            {% endif %}
                                            {% if pagination.hasNext %}
                                                <a
                                                    href="?page={{ pagination.page + 1 }}&limit={{ pagination.limit }}&search={{ filters.search }}&username={{ filters.username }}&status={{ filters.status }}&sortBy={{ filters.sortBy }}&sortOrder={{ filters.sortOrder }}{% if expressPagination.page > 1 %}&expressPage={{ expressPagination.page }}{% endif %}"
                                                    class="inline-flex items-center px-3 py-2 border border-border text-sm font-medium text-foreground bg-background
                                                        hover:bg-muted focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2">
                                                    Next
                                                    <i data-lucide="chevron-right" class="h-4 w-4 ml-1"></i>
                                                </a>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% else %}
                            <div class="p-8 text-center">
                                <i data-lucide="shield" class="h-12 w-12 text-muted-foreground mx-auto mb-3"></i>
                                <h3 class="text-base font-medium text-foreground mb-1">No OIDC Sessions</h3>
                                <p class="text-sm text-muted-foreground">
                                    {% if filters.search or filters.username or filters.status != 'all' %}
                                        No OIDC sessions match your current filters.
                                    {% else %}
                                        No OIDC sessions are currently active or recorded.
                                    {% endif %}
                                </p>
                            </div>
                        {% endif %}
                    </div>

                {# ── Express Sessions Table ── #}
                <div class="bg-card border border-border">
                    <div class="px-6 py-4 border-b border-border">
                        <div class="flex items-center justify-between">
                            <h2 class="text-lg font-semibold text-foreground flex items-center">
                                <i data-lucide="log-in" class="h-5 w-5 mr-2 text-blue-600 dark:text-blue-400"></i>
                                Express Sessions (Direct Login)
                            </h2>
                            <div class="text-sm text-muted-foreground">
                                {% if expressPagination.totalSessions > 0 %}
                                    Showing {{ expressPagination.startIndex }}-{{ expressPagination.endIndex }} of
                                    {{ expressPagination.totalSessions }} sessions
                                {% else %}
                                    No sessions
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% if expressSessions and expressSessions.length > 0 %}
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-border">
                                <thead class="bg-muted/50 border-b border-border">
                                    <tr>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">User</th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Device</th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Status</th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Type</th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Login Time</th>
                                        <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-muted-foreground uppercase tracking-wide">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-card divide-y divide-border">
                                    {% for session in expressSessions %}
                                        <tr class="hover:bg-muted/50 transition-colors">
                                            <!-- User Info -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                <div class="min-w-0 flex-1">
                                                    <div class="text-sm font-medium text-foreground truncate max-w-32" title="{{ session.userInfo.full_name }}">{{ session.userInfo.full_name }}</div>
                                                    <div class="text-sm text-muted-foreground truncate max-w-32" title="{{ session.userInfo.username }}">{{ session.userInfo.username }}</div>
                                                    {% if session.userInfo.email and session.userInfo.email != 'Unknown' %}
                                                        <div class="text-xs text-muted-foreground truncate max-w-32" title="{{ session.userInfo.email }}">{{ session.userInfo.email }}</div>
                                                    {% endif %}
                                                </div>
                                            </td>
                                            <!-- Device Info -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                <div class="text-sm text-foreground truncate max-w-32" title="{{ session.device }}">{{ session.device }}</div>
                                                <div class="text-xs text-muted-foreground truncate max-w-32" title="{{ session.ip }}">{{ session.ip }}</div>
                                            </td>
                                            <!-- Status -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-primary/10 text-primary">
                                                    <i data-lucide="check-circle" class="h-3 w-3 mr-1"></i>
                                                    Active
                                                </span>
                                            </td>
                                            <!-- Type -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">
                                                    <i data-lucide="log-in" class="h-3 w-3 mr-1"></i>
                                                    Direct Login
                                                </span>
                                            </td>
                                            <!-- Login Time -->
                                            <td class="px-6 py-5 whitespace-nowrap">
                                                <div class="text-sm text-foreground truncate max-w-32" title="{{ session.startTime }}">{{ session.startTime }}</div>
                                                <div class="text-xs text-muted-foreground truncate max-w-32" title="{{ session.sessionAge }}">{{ session.sessionAge }}</div>
                                            </td>
                                            <!-- Actions -->
                                            <td class="px-6 py-5 whitespace-nowrap text-right text-sm font-medium">
                                                <div class="flex items-center justify-end space-x-2">
                                                    <a href="/admin/sessions/{{ session.id }}?type=express" class="text-primary hover:text-primary/80" title="View Details">
                                                        <i data-lucide="eye" class="h-4 w-4"></i>
                                                    </a>
                                                    <form
                                                        method="post"
                                                        action="/admin/sessions/{{ session.id }}/revoke"
                                                        class="inline">
                                                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                                                        <input type="hidden" name="sessionType" value="express">
                                                        <button type="submit" class="text-destructive hover:text-destructive/80" title="Revoke Session">
                                                            <i data-lucide="power-off" class="h-4 w-4"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        <!-- Express Pagination -->
                        {% if expressPagination.totalPages > 1 %}
                            <div class="px-6 py-4 border-t border-border">
                                <div class="flex items-center justify-between">
                                    <div class="text-sm text-muted-foreground">
                                        Page {{ expressPagination.page }} of {{ expressPagination.totalPages }}
                                    </div>
                                    <div class="flex space-x-2">
                                        {% if expressPagination.hasPrev %}
                                            <a
                                                href="?expressPage={{ expressPagination.page - 1 }}&expressLimit={{ expressPagination.limit }}&page={{ pagination.page }}&limit={{ pagination.limit }}&search={{ filters.search }}&username={{ filters.username }}&status={{ filters.status }}&sortBy={{ filters.sortBy }}&sortOrder={{ filters.sortOrder }}"
                                                class="inline-flex items-center px-3 py-2 border border-border text-sm font-medium text-foreground bg-background
                                                    hover:bg-muted focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2">
                                                <i data-lucide="chevron-left" class="h-4 w-4 mr-1"></i>
                                                Previous
                                            </a>
                                        {% endif %}
                                        {% if expressPagination.hasNext %}
                                            <a
                                                href="?expressPage={{ expressPagination.page + 1 }}&expressLimit={{ expressPagination.limit }}&page={{ pagination.page }}&limit={{ pagination.limit }}&search={{ filters.search }}&username={{ filters.username }}&status={{ filters.status }}&sortBy={{ filters.sortBy }}&sortOrder={{ filters.sortOrder }}"
                                                class="inline-flex items-center px-3 py-2 border border-border text-sm font-medium text-foreground bg-background
                                                    hover:bg-muted focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2">
                                                Next
                                                <i data-lucide="chevron-right" class="h-4 w-4 ml-1"></i>
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% else %}
                        <div class="p-8 text-center">
                            <i data-lucide="log-in" class="h-12 w-12 text-muted-foreground mx-auto mb-3"></i>
                            <h3 class="text-base font-medium text-foreground mb-1">No Express Sessions</h3>
                            <p class="text-sm text-muted-foreground">No direct login sessions are currently active.</p>
                        </div>
                    {% endif %}
                </div>
                </div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="{{ asset('js/admin/sessions/index.js') }}"></script>
{% endblock %}
