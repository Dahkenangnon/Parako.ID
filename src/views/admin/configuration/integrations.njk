{% extends "layouts/admin-layout.njk" %}

{% block title %}{{ title }}{% endblock %}

{% block admin_content %}
<div class="max-w-5xl mx-auto space-y-6">

    <!-- Header -->
    <div class="mb-6">
        {% include "partials/admin-configuration-tabs.njk" %}

        <div>
            <h1 class="text-2xl font-bold text-foreground">{{ title }}</h1>
            <p class="mt-2 text-sm text-muted-foreground">
                Configure email delivery and public URLs for your organization.
                Leave fields empty to use system defaults.
            </p>
        </div>
    </div>

    <form id="config-form" method="POST" action="/admin/configuration/{{ section }}" class="space-y-6">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {% set urls = config.urls if config.urls else {} %}
        {% set email = config.email if config.email else {} %}
        {% set pfUrls = platformIntegrations.urls if platformIntegrations and platformIntegrations.urls else {} %}
        {% set pfEmail = platformIntegrations.email if platformIntegrations and platformIntegrations.email else {} %}

        <!-- URL Configuration -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                <i data-lucide="link" class="h-5 w-5 mr-2 text-primary"></i>
                URL Configuration
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="urls_website" class="block text-sm font-medium text-foreground mb-2">Website URL</label>
                    <input type="url" id="urls_website" name="urls[website]"
                           value="{{ urls.website or '' }}"
                           placeholder="https://www.example.com"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    {% if pfUrls.website %}
                    <p class="mt-1 text-xs text-muted-foreground">System default: {{ pfUrls.website }}</p>
                    {% endif %}
                </div>
                <div>
                    <label for="urls_contact" class="block text-sm font-medium text-foreground mb-2">Contact URL</label>
                    <input type="url" id="urls_contact" name="urls[contact]"
                           value="{{ urls.contact or '' }}"
                           placeholder="https://www.example.com/contact"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    {% if pfUrls.contact %}
                    <p class="mt-1 text-xs text-muted-foreground">System default: {{ pfUrls.contact }}</p>
                    {% endif %}
                </div>
                <div>
                    <label for="urls_privacy" class="block text-sm font-medium text-foreground mb-2">Privacy Policy URL</label>
                    <input type="url" id="urls_privacy" name="urls[privacy_policy]"
                           value="{{ urls.privacy_policy or '' }}"
                           placeholder="https://www.example.com/privacy"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    {% if pfUrls.privacy_policy %}
                    <p class="mt-1 text-xs text-muted-foreground">System default: {{ pfUrls.privacy_policy }}</p>
                    {% endif %}
                </div>
                <div>
                    <label for="urls_tos" class="block text-sm font-medium text-foreground mb-2">Terms of Service URL</label>
                    <input type="url" id="urls_tos" name="urls[terms_of_service]"
                           value="{{ urls.terms_of_service or '' }}"
                           placeholder="https://www.example.com/terms"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    {% if pfUrls.terms_of_service %}
                    <p class="mt-1 text-xs text-muted-foreground">System default: {{ pfUrls.terms_of_service }}</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Email Configuration -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                <i data-lucide="mail" class="h-5 w-5 mr-2 text-primary"></i>
                Email Configuration
            </h2>
            <p class="text-sm text-muted-foreground mb-6">
                Configure SMTP settings for your organization. Leave empty to use default email settings.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="email_smtp_host" class="block text-sm font-medium text-foreground mb-2">SMTP Host</label>
                    <input type="text" id="email_smtp_host" name="email[smtp_host]"
                           value="{{ email.smtp_host or '' }}"
                           placeholder="smtp.example.com"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    {% if pfEmail.smtp_host %}
                    <p class="mt-1 text-xs text-muted-foreground">System default: {{ pfEmail.smtp_host }}</p>
                    {% endif %}
                </div>
                <div>
                    <label for="email_smtp_port" class="block text-sm font-medium text-foreground mb-2">SMTP Port</label>
                    <input type="number" id="email_smtp_port" name="email[smtp_port]"
                           value="{{ email.smtp_port or '' }}"
                           placeholder="587" min="1" max="65535"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    {% if pfEmail.smtp_port %}
                    <p class="mt-1 text-xs text-muted-foreground">System default: {{ pfEmail.smtp_port }}</p>
                    {% endif %}
                </div>
                <div>
                    <label for="email_smtp_username" class="block text-sm font-medium text-foreground mb-2">SMTP Username</label>
                    <input type="text" id="email_smtp_username" name="email[smtp_username]"
                           value="{{ email.smtp_username or '' }}"
                           placeholder="user@example.com"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>
                <div>
                    <label for="email_smtp_password" class="block text-sm font-medium text-foreground mb-2">SMTP Password</label>
                    <div class="relative">
                        <input type="password" id="email_smtp_password" name="email[smtp_password]"
                               value="{{ email.smtp_password or '' }}"
                               data-field-path="integrations.email.smtp_password"
                               placeholder="&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;"
                               class="w-full px-3 py-2 pr-20 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        <button type="button"
                                onclick="revealTenantSecret('integrations.email.smtp_password', 'email_smtp_password')"
                                class="absolute right-2 top-1/2 -translate-y-1/2 px-2 py-1 text-xs bg-primary text-primary-foreground hover:bg-primary/90">
                            <i data-lucide="eye" class="h-3 w-3 inline mr-1"></i>
                            Reveal
                        </button>
                    </div>
                </div>
                <div>
                    <label for="email_from" class="block text-sm font-medium text-foreground mb-2">From Email Address</label>
                    <input type="email" id="email_from" name="email[from]"
                           value="{{ email.from or '' }}"
                           placeholder="noreply@example.com"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    {% if pfEmail.from %}
                    <p class="mt-1 text-xs text-muted-foreground">System default: {{ pfEmail.from }}</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Test Email -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                <i data-lucide="send" class="h-5 w-5 mr-2 text-primary"></i>
                Test Email
            </h2>
            <div class="flex flex-col sm:flex-row gap-3">
                <input type="email" id="test-email-address"
                       placeholder="test@example.com"
                       class="flex-1 px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                <button type="button" id="send-test-email-button"
                        class="inline-flex items-center justify-center px-4 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90">
                    <i data-lucide="send" class="h-4 w-4 mr-2"></i>
                    Send Test
                </button>
            </div>
            <p id="test-email-result" class="mt-2 text-sm hidden"></p>
        </div>

    </form>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-3 justify-between pt-4 border-t border-border">
        <div>
            {% if hasOverride %}
            <form method="POST" action="/admin/configuration/{{ section }}/reset"
                  onsubmit="return confirm('Are you sure you want to reset Integrations configuration to defaults? This cannot be undone.')">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button type="submit"
                        class="inline-flex items-center justify-center px-4 py-2 border border-destructive text-destructive text-sm font-medium hover:bg-destructive/10">
                    <i data-lucide="refresh-cw" class="h-4 w-4 mr-2"></i>
                    Reset to Defaults
                </button>
            </form>
            {% endif %}
        </div>
        <div class="flex gap-3">
            <a href="/admin/configuration"
               class="inline-flex items-center justify-center px-4 py-2 border border-border text-foreground text-sm font-medium hover:bg-muted">
                <i data-lucide="arrow-left" class="h-4 w-4 mr-2"></i>
                Back
            </a>
            <button type="submit" form="config-form"
                    class="inline-flex items-center justify-center px-4 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90">
                <i data-lucide="save" class="h-4 w-4 mr-2"></i>
                Save Changes
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="{{ asset('js/admin/configuration/common.js') }}"></script>
<script src="{{ asset('js/admin/configuration/integrations.js') }}"></script>
<script src="{{ asset('js/admin/configuration/validation.js') }}"></script>
{% endblock %}
