{% extends "layouts/admin-layout.njk" %}
{% block title %}
    {{ title }}
{% endblock %}
{% block admin_content %}
    <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="mb-8">
            {% set activePage = "oidc" %}
            {% include "partials/admin-settings-tabs.njk" %}
            <div>
                <h1 class="text-xl sm:text-2xl font-bold text-foreground">{{ title }}</h1>
                <p class="mt-2 text-sm text-muted-foreground">Configure OIDC-specific settings including issuer, routes, secrets, and
                    algorithms</p>
            </div>
        </div>
        <form method="POST" action="/admin/settings/oidc" class="space-y-6" onsubmit="return confirmCriticalChange(event)">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <div
                    class="max-w-6xl mx-auto space-y-6">
                    <!-- Issuer & Routes -->
                    <div class="bg-card border border-border p-6">
                        <h2 class="text-lg font-semibold text-foreground flex items-center mb-4">
                            <i data-lucide="globe" class="h-5 w-5 mr-2 text-primary"></i>
                            Issuer & Routes
                        </h2>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-foreground mb-2">OIDC Issuer URL</label>
                                {% set computedIssuer = config.issuer if config.issuer else (deploymentUrl + (config.path or '/oidc/v1')) %}
                                <div class="px-3 py-2 bg-muted/50 border border-border text-foreground text-sm font-mono">
                                    {{ computedIssuer or 'Not configured' }}
                                </div>
                                <p class="mt-1 text-xs text-muted-foreground">Auto-computed from Deployment URL + OIDC Path. Change these in Deployment settings.</p>
                                </div>
                                <div>
                                    <label for="oidc.path" class="block text-sm font-medium text-foreground mb-2">OIDC Path</label>
                                    <input type="text" id="oidc.path" name="oidc[path]" value="{{ config.path or '/oidc/v1' }}" required placeholder="/oidc/v1" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                        <p class="mt-1 text-xs text-muted-foreground">Base path for OIDC endpoints (e.g., /oidc/v1)</p>
                                    </div>
                                    <div>
                                        <h3 class="text-base font-medium text-foreground mb-3">Endpoint Routes</h3>
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                            <div>
                                                <label for="oidc.routes.authorization" class="block text-sm font-medium text-foreground mb-2">Authorization</label>
                                                <input type="text" id="oidc.routes.authorization" name="oidc[routes][authorization]" value="{{ config.routes and config.routes.authorization or '/authorize' }}" placeholder="/authorize" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                    <p class="mt-1 text-xs text-muted-foreground">Authorization endpoint path</p>
                                                </div>
                                                <div>
                                                    <label for="oidc.routes.token" class="block text-sm font-medium text-foreground mb-2">Token</label>
                                                    <input type="text" id="oidc.routes.token" name="oidc[routes][token]" value="{{ config.routes and config.routes.token or '/token' }}" placeholder="/token" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                        <p class="mt-1 text-xs text-muted-foreground">Token endpoint path</p>
                                                    </div>
                                                    <div>
                                                        <label for="oidc.routes.userinfo" class="block text-sm font-medium text-foreground mb-2">UserInfo</label>
                                                        <input type="text" id="oidc.routes.userinfo" name="oidc[routes][userinfo]" value="{{ config.routes and config.routes.userinfo or '/userinfo' }}" placeholder="/userinfo" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                            <p class="mt-1 text-xs text-muted-foreground">UserInfo endpoint path</p>
                                                        </div>
                                                        <div>
                                                            <label for="oidc.routes.jwks" class="block text-sm font-medium text-foreground mb-2">JWKS</label>
                                                            <input type="text" id="oidc.routes.jwks" name="oidc[routes][jwks]" value="{{ config.routes and config.routes.jwks or '/jwks' }}" placeholder="/jwks" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                <p class="mt-1 text-xs text-muted-foreground">JSON Web Key Set endpoint path</p>
                                                            </div>
                                                            <div>
                                                                <label for="oidc.routes.registration" class="block text-sm font-medium text-foreground mb-2">Registration</label>
                                                                <input type="text" id="oidc.routes.registration" name="oidc[routes][registration]" value="{{ config.routes and config.routes.registration or '/register-rp' }}" placeholder="/register-rp" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                    <p class="mt-1 text-xs text-muted-foreground">Dynamic client registration endpoint path</p>
                                                                </div>
                                                                <div>
                                                                    <label for="oidc.routes.backchannel_authentication" class="block text-sm font-medium text-foreground mb-2">Backchannel
                                                                        Authentication</label>
                                                                    <input type="text" id="oidc.routes.backchannel_authentication" name="oidc[routes][backchannel_authentication]" value="{{ config.routes and config.routes.backchannel_authentication or '/backchannel' }}" placeholder="/backchannel" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                        <p class="mt-1 text-xs text-muted-foreground">Backchannel authentication endpoint path</p>
                                                                    </div>
                                                                    <div>
                                                                        <label for="oidc.routes.challenge" class="block text-sm font-medium text-foreground mb-2">Challenge</label>
                                                                        <input type="text" id="oidc.routes.challenge" name="oidc[routes][challenge]" value="{{ config.routes and config.routes.challenge or '/challenge' }}" placeholder="/challenge" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                            <p class="mt-1 text-xs text-muted-foreground">Challenge endpoint path</p>
                                                                        </div>
                                                                        <div>
                                                                            <label for="oidc.routes.code_verification" class="block text-sm font-medium text-foreground mb-2">Code Verification</label>
                                                                            <input type="text" id="oidc.routes.code_verification" name="oidc[routes][code_verification]" value="{{ config.routes and config.routes.code_verification or '/device' }}" placeholder="/device" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                <p class="mt-1 text-xs text-muted-foreground">Device code verification endpoint path</p>
                                                                            </div>
                                                                            <div>
                                                                                <label for="oidc.routes.device_authorization" class="block text-sm font-medium text-foreground mb-2">Device
                                                                                    Authorization</label>
                                                                                <input type="text" id="oidc.routes.device_authorization" name="oidc[routes][device_authorization]" value="{{ config.routes and config.routes.device_authorization or '/device/auth' }}" placeholder="/device/auth" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                    <p class="mt-1 text-xs text-muted-foreground">Device authorization endpoint path</p>
                                                                                </div>
                                                                                <div>
                                                                                    <label for="oidc.routes.end_session" class="block text-sm font-medium text-foreground mb-2">End Session</label>
                                                                                    <input type="text" id="oidc.routes.end_session" name="oidc[routes][end_session]" value="{{ config.routes and config.routes.end_session or '/session/end' }}" placeholder="/session/end" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                        <p class="mt-1 text-xs text-muted-foreground">End session endpoint path</p>
                                                                                    </div>
                                                                                    <div>
                                                                                        <label for="oidc.routes.introspection" class="block text-sm font-medium text-foreground mb-2">Introspection</label>
                                                                                        <input type="text" id="oidc.routes.introspection" name="oidc[routes][introspection]" value="{{ config.routes and config.routes.introspection or '/token/introspection' }}" placeholder="/token/introspection" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                            <p class="mt-1 text-xs text-muted-foreground">Token introspection endpoint path</p>
                                                                                        </div>
                                                                                        <div>
                                                                                            <label for="oidc.routes.pushed_authorization_request" class="block text-sm font-medium text-foreground mb-2">Pushed
                                                                                                Authorization Request</label>
                                                                                            <input type="text" id="oidc.routes.pushed_authorization_request" name="oidc[routes][pushed_authorization_request]" value="{{ config.routes and config.routes.pushed_authorization_request or '/request' }}" placeholder="/request" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                <p class="mt-1 text-xs text-muted-foreground">Pushed authorization request endpoint path</p>
                                                                                            </div>
                                                                                            <div>
                                                                                                <label for="oidc.routes.revocation" class="block text-sm font-medium text-foreground mb-2">Revocation</label>
                                                                                                <input type="text" id="oidc.routes.revocation" name="oidc[routes][revocation]" value="{{ config.routes and config.routes.revocation or '/token/revocation' }}" placeholder="/token/revocation" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                    <p class="mt-1 text-xs text-muted-foreground">Token revocation endpoint path</p>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                                <!-- Secrets -->
                                                                                <div class="bg-card border border-border p-6">
                                                                                    <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                                                                                        <i data-lucide="lock" class="h-5 w-5 mr-2 text-primary"></i>
                                                                                        Secrets
                                                                                    </h2>
                                                                                    <div class="space-y-4">
                                                                                        <div>
                                                                                            <label for="oidc.secrets.pairwise_salt" class="block text-sm font-medium text-foreground mb-2">Pairwise Salt</label>
                                                                                            <div class="relative">
                                                                                                <input
                                                                                                    type="text"
                                                                                                    id="oidc.secrets.pairwise_salt"
                                                                                                    name="oidc[secrets][pairwise_salt]"
                                                                                                    value="{{ config.secrets and config.secrets.pairwise_salt or '' }}"
                                                                                                    data-field-path="oidc.secrets.pairwise_salt"
                                                                                                    readonly
                                                                                                    class="w-full px-3 py-2 pr-20 bg-muted border border-border text-foreground placeholder-muted-foreground
                                                                                                        focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                    <button
                                                                                                        type="button"
                                                                                                        onclick="revealSecret('oidc.secrets.pairwise_salt', 'oidc.secrets.pairwise_salt')"
                                                                                                        class="absolute right-2 top-1/2 -translate-y-1/2 px-2 py-1 text-xs bg-primary text-primary-foreground
                                                                                                            hover:bg-primary/90">
                                                                                                        <i data-lucide="eye" class="h-3 w-3 inline mr-1"></i>
                                                                                                        Reveal
                                                                                                    </button>
                                                                                                </div>
                                                                                                <p class="mt-1 text-xs text-orange-600">⚠️ Revealing secrets is audited and logged</p>
                                                                                                <p class="mt-1 text-xs text-muted-foreground">Salt used for pairwise subject identifiers (e.g., parako-id-salt)</p>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                    <!-- Token TTL -->
                                                                                    <div class="bg-card border border-border p-6">
                                                                                        <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                                                                                            <i data-lucide="clock" class="h-5 w-5 mr-2 text-primary"></i>
                                                                                            Token TTL (Time To Live)
                                                                                        </h2>
                                                                                        <div class="space-y-4">
                                                                                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                                                                <div>
                                                                                                    <label for="oidc.token_ttl.access_token" class="block text-sm font-medium text-foreground mb-2">Access Token (seconds)</label>
                                                                                                    <input type="number" id="oidc.token_ttl.access_token" name="oidc[token_ttl][access_token]" value="{{ config.token_ttl and config.token_ttl.access_token or 3600 }}" min="1" placeholder="3600" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                        <p class="mt-1 text-xs text-muted-foreground">Access token lifetime in seconds (default: 1 hour)</p>
                                                                                                    </div>
                                                                                                    <div>
                                                                                                        <label for="oidc.token_ttl.id_token" class="block text-sm font-medium text-foreground mb-2">ID Token (seconds)</label>
                                                                                                        <input type="number" id="oidc.token_ttl.id_token" name="oidc[token_ttl][id_token]" value="{{ config.token_ttl and config.token_ttl.id_token or 3600 }}" min="1" placeholder="3600" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                            <p class="mt-1 text-xs text-muted-foreground">ID token lifetime in seconds (default: 1 hour)</p>
                                                                                                        </div>
                                                                                                        <div>
                                                                                                            <label for="oidc.token_ttl.refresh_token" class="block text-sm font-medium text-foreground mb-2">Refresh Token (seconds)</label>
                                                                                                            <input type="number" id="oidc.token_ttl.refresh_token" name="oidc[token_ttl][refresh_token]" value="{{ config.token_ttl and config.token_ttl.refresh_token or 1209600 }}" min="1" placeholder="1209600" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                <p class="mt-1 text-xs text-muted-foreground">Refresh token lifetime in seconds (default: 14 days)</p>
                                                                                                            </div>
                                                                                                            <div>
                                                                                                                <label for="oidc.token_ttl.authorization_code" class="block text-sm font-medium text-foreground mb-2">Authorization Code
                                                                                                                    (seconds)</label>
                                                                                                                <input type="number" id="oidc.token_ttl.authorization_code" name="oidc[token_ttl][authorization_code]" value="{{ config.token_ttl and config.token_ttl.authorization_code or 600 }}" min="1" placeholder="600" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                    <p class="mt-1 text-xs text-muted-foreground">Authorization code lifetime in seconds (default: 10 minutes)</p>
                                                                                                                </div>
                                                                                                                <div>
                                                                                                                    <label for="oidc.token_ttl.backchannel_auth" class="block text-sm font-medium text-foreground mb-2">Backchannel Auth
                                                                                                                        (seconds)</label>
                                                                                                                    <input type="number" id="oidc.token_ttl.backchannel_auth" name="oidc[token_ttl][backchannel_auth]" value="{{ config.token_ttl and config.token_ttl.backchannel_auth or 600 }}" min="1" placeholder="600" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                        <p class="mt-1 text-xs text-muted-foreground">Backchannel authentication lifetime in seconds (default: 10 minutes)</p>
                                                                                                                    </div>
                                                                                                                    <div>
                                                                                                                        <label for="oidc.token_ttl.client_credentials" class="block text-sm font-medium text-foreground mb-2">Client Credentials
                                                                                                                            (seconds)</label>
                                                                                                                        <input type="number" id="oidc.token_ttl.client_credentials" name="oidc[token_ttl][client_credentials]" value="{{ config.token_ttl and config.token_ttl.client_credentials or 3600 }}" min="1" placeholder="3600" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                            <p class="mt-1 text-xs text-muted-foreground">Client credentials token lifetime in seconds (default: 1 hour)</p>
                                                                                                                        </div>
                                                                                                                        <div>
                                                                                                                            <label for="oidc.token_ttl.device_code" class="block text-sm font-medium text-foreground mb-2">Device Code (seconds)</label>
                                                                                                                            <input type="number" id="oidc.token_ttl.device_code" name="oidc[token_ttl][device_code]" value="{{ config.token_ttl and config.token_ttl.device_code or 600 }}" min="1" placeholder="600" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                                <p class="mt-1 text-xs text-muted-foreground">Device code lifetime in seconds (default: 10 minutes)</p>
                                                                                                                            </div>
                                                                                                                            <div>
                                                                                                                                <label for="oidc.token_ttl.grant" class="block text-sm font-medium text-foreground mb-2">Grant (seconds)</label>
                                                                                                                                <input type="number" id="oidc.token_ttl.grant" name="oidc[token_ttl][grant]" value="{{ config.token_ttl and config.token_ttl.grant or 1209600 }}" min="1" placeholder="1209600" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                                    <p class="mt-1 text-xs text-muted-foreground">Grant lifetime in seconds (default: 14 days)</p>
                                                                                                                                </div>
                                                                                                                                <div>
                                                                                                                                    <label for="oidc.token_ttl.interaction" class="block text-sm font-medium text-foreground mb-2">Interaction (seconds)</label>
                                                                                                                                    <input type="number" id="oidc.token_ttl.interaction" name="oidc[token_ttl][interaction]" value="{{ config.token_ttl and config.token_ttl.interaction or 3600 }}" min="1" placeholder="3600" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                                        <p class="mt-1 text-xs text-muted-foreground">Interaction lifetime in seconds (default: 1 hour)</p>
                                                                                                                                    </div>
                                                                                                                                    <div>
                                                                                                                                        <label for="oidc.token_ttl.session" class="block text-sm font-medium text-foreground mb-2">Session (seconds)</label>
                                                                                                                                        <input type="number" id="oidc.token_ttl.session" name="oidc[token_ttl][session]" value="{{ config.token_ttl and config.token_ttl.session or 1209600 }}" min="1" placeholder="1209600" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                                            <p class="mt-1 text-xs text-muted-foreground">Session lifetime in seconds (default: 14 days)</p>
                                                                                                                                        </div>
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                            </div>
                                                                                                                            <!-- Discovery -->
                                                                                                                            <div class="bg-card border border-border p-6">
                                                                                                                                <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                                                                                                                                    <i data-lucide="search" class="h-5 w-5 mr-2 text-primary"></i>
                                                                                                                                    Discovery Document
                                                                                                                                </h2>
                                                                                                                                <div class="space-y-4">
                                                                                                                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                                                                                                        <div>
                                                                                                                                            <label for="oidc.discovery.claims_locales_supported" class="block text-sm font-medium text-foreground mb-2">Claims
                                                                                                                                                Locales Supported</label>
                                                                                                                                            <input type="text" id="oidc.discovery.claims_locales_supported" name="oidc[discovery][claims_locales_supported]" value="{{ config.discovery and config.discovery.claims_locales_supported and config.discovery.claims_locales_supported | join(',') or 'en' }}" placeholder="en,fr,es" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                                                <p class="mt-1 text-xs text-muted-foreground">Comma-separated list of supported claim locales (e.g., en,fr,es)</p>
                                                                                                                                            </div>
                                                                                                                                            <div>
                                                                                                                                                <label for="oidc.discovery.ui_locales_supported" class="block text-sm font-medium text-foreground mb-2">UI Locales
                                                                                                                                                    Supported</label>
                                                                                                                                                <input type="text" id="oidc.discovery.ui_locales_supported" name="oidc[discovery][ui_locales_supported]" value="{{ config.discovery and config.discovery.ui_locales_supported and config.discovery.ui_locales_supported | join(',') or 'en' }}" placeholder="en,fr,es" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                                                    <p class="mt-1 text-xs text-muted-foreground">Comma-separated list of supported UI locales (e.g., en,fr,es)</p>
                                                                                                                                                </div>
                                                                                                                                            </div>
                                                                                                                                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                                                                                                                <div>
                                                                                                                                                    <label for="oidc.discovery.display_values_supported" class="block text-sm font-medium text-foreground mb-2">Display
                                                                                                                                                        Values Supported</label>
                                                                                                                                                    <input type="text" id="oidc.discovery.display_values_supported" name="oidc[discovery][display_values_supported]" value="{{ config.discovery and config.discovery.display_values_supported and config.discovery.display_values_supported | join(',') or 'en' }}" placeholder="en,fr,es" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                                                        <p class="mt-1 text-xs text-muted-foreground">Comma-separated list of supported display values (e.g., en,fr,es)</p>
                                                                                                                                                    </div>
                                                                                                                                                    <div>
                                                                                                                                                        <label for="oidc.discovery.service_documentation" class="block text-sm font-medium text-foreground mb-2">Service
                                                                                                                                                            Documentation URI</label>
                                                                                                                                                        <input type="url" id="oidc.discovery.service_documentation" name="oidc[discovery][service_documentation]" value="{{ config.discovery and config.discovery.service_documentation or '' }}" placeholder="https://your-domain.com/docs" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                                                                                                                                            <p class="mt-1 text-xs text-muted-foreground">URL to service documentation (optional)</p>
                                                                                                                                                        </div>
                                                                                                                                                    </div>
                                                                                                                                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                                                                                                                        <div>
                                                                                                                                                            <label for="oidc.discovery.op_policy_uri" class="block text-sm font-medium text-foreground mb-2">OP Policy URI</label>
