{% extends "layouts/admin-layout.njk" %}

{% block title %}{{ title }}{% endblock %}

{% block admin_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
        {% set activePage = "security" %}
        {% include "partials/admin-settings-tabs.njk" %}

        <div>
            <h1 class="text-xl sm:text-2xl font-bold text-foreground">{{ title }}</h1>
            <p class="mt-2 text-sm text-muted-foreground">Manage JWT secrets, cookie secrets, and token expiration settings</p>
        </div>
    </div>

    {% include "partials/admin-security-subtabs.njk" %}

    <form method="POST" action="/admin/settings/security/secrets" class="space-y-6" onsubmit="return confirmCriticalChange(event)">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        <div class="max-w-6xl mx-auto space-y-6">
                <!-- Security Secrets - Danger Zone -->
                <div class="bg-card border-2 border-orange-200 dark:border-orange-800 overflow-hidden">
                    <div class="px-6 py-4 bg-orange-50 dark:bg-orange-900/30 border-b border-orange-200 dark:border-orange-800">
                        <div class="flex items-center justify-between">
                            <h2 class="text-lg font-semibold text-foreground flex items-center">
                                <i data-lucide="key" class="h-5 w-5 mr-2 text-orange-600 dark:text-orange-400"></i>
                                Security Secrets
                            </h2>
                            <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-orange-100 dark:bg-orange-900/30 text-orange-800 dark:text-orange-200 border border-orange-300 dark:border-orange-800">
                                <i data-lucide="alert-triangle" class="h-3 w-3 mr-1"></i>
                                Danger Zone
                            </span>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="bg-orange-100 dark:bg-orange-900/30 border border-orange-200 dark:border-orange-800 p-4 mb-6">
                            <div class="flex items-start">
                                <i data-lucide="alert-triangle" class="h-5 w-5 text-orange-600 dark:text-orange-400 mr-2 mt-0.5"></i>
                                <div class="text-sm text-orange-800 dark:text-orange-200">
                                    <p class="font-medium mb-1">Warning: Critical Security Configuration</p>
                                    <p>Changing these values will invalidate all existing sessions and tokens. All users will be logged out and must re-authenticate. Proceed with extreme caution.</p>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label for="secrets.jwt_secret" class="block text-sm font-medium text-foreground mb-2">JWT Secret</label>
                                <div class="relative">
                                    <input type="text" id="secrets.jwt_secret"
                                           name="secrets[jwt_secret]"
                                           value="{{ config.secrets and config.secrets.jwt_secret or '' }}" required
                                           readonly
                                           data-field-path="security.secrets.jwt_secret"
                                           class="w-full px-3 py-2 pr-28 bg-muted border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                    <button type="button" onclick="revealSecret('secrets.jwt_secret', 'security.secrets.jwt_secret')"
                                            class="absolute right-2 top-1/2 -translate-y-1/2 px-3 py-1 text-xs font-medium bg-primary text-primary-foreground hover:bg-primary/90">
                                        <i data-lucide="eye" class="h-3 w-3 inline mr-1"></i>
                                        Reveal
                                    </button>
                                </div>
                                <p class="mt-1 text-xs text-orange-600 dark:text-orange-400">
                                    <i data-lucide="alert-triangle" class="h-3 w-3 inline mr-1"></i>
                                    Click "Reveal" to view or modify. Action will be audited.
                                </p>
                            </div>
                            <div>
                                <label for="secrets.jwt_expires_in" class="block text-sm font-medium text-foreground mb-2">JWT Expiration</label>
                                <input type="text" id="secrets.jwt_expires_in"
                                       name="secrets[jwt_expires_in]"
                                       value="{{ config.secrets and config.secrets.jwt_expires_in or '' }}" required
                                       class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                <p class="mt-1 text-xs text-muted-foreground">JWT token expiration time (e.g., 1h, 24h, 7d)</p>
                            </div>
                        </div>

                        <div class="mt-4">
                            <label for="secrets.cookie_secrets" class="block text-sm font-medium text-foreground mb-2">Cookie Secrets</label>
                            <div class="relative">
                                <textarea id="secrets.cookie_secrets"
                                          name="secrets[cookie_secrets]" rows="3" required
                                          readonly
                                          data-field-path="security.secrets.cookie_secrets"
                                          class="w-full px-3 py-2 pr-28 bg-muted border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">{{ config.secrets and config.secrets.cookie_secrets and config.secrets.cookie_secrets | join('\n') or '' }}</textarea>
                                <button type="button" onclick="revealSecret('secrets.cookie_secrets', 'security.secrets.cookie_secrets')"
                                        class="absolute right-2 top-2 px-3 py-1 text-xs font-medium bg-primary text-primary-foreground hover:bg-primary/90">
                                    <i data-lucide="eye" class="h-3 w-3 inline mr-1"></i>
                                    Reveal
                                </button>
                            </div>
                            <p class="mt-1 text-xs text-orange-600 dark:text-orange-400">
                                <i data-lucide="alert-triangle" class="h-3 w-3 inline mr-1"></i>
                                Click "Reveal" to view or modify. One secret per line (minimum 2). Action will be audited.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="flex flex-col sm:flex-row gap-3 justify-end pt-6 border-t border-border">
                    <a href="/admin/settings" class="inline-flex items-center justify-center px-4 py-2 border border-border text-foreground text-sm font-medium hover:bg-muted focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2">
                        <i data-lucide="x" class="h-4 w-4 mr-2"></i>
                        Cancel
                    </a>
                    <button type="button" onclick="resetForm()" class="inline-flex items-center justify-center px-4 py-2 border border-border text-foreground text-sm font-medium hover:bg-muted focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2">
                        <i data-lucide="undo" class="h-4 w-4 mr-2"></i>
                        Reset Form
                    </button>
                    <button type="submit" class="inline-flex items-center justify-center px-4 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                            <i data-lucide="save" class="h-4 w-4 mr-2"></i>
                            Save Changes
                        </button>
                </div>
            </div>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="/js/admin/settings.js"></script>
<script src="/js/admin/settings/common.js"></script>
<script src="/js/admin/settings/security.js"></script>
{% endblock %}
