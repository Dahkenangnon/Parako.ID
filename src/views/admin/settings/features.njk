{% extends "layouts/admin-layout.njk" %}
{% block title %}
    {{ title }}
{% endblock %}
{% block admin_content %}
    <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="mb-8">
            {% set activePage = "features" %}
            {% include "partials/admin-settings-tabs.njk" %}
            <div>
                <h1 class="text-xl sm:text-2xl font-bold text-foreground">{{ title }}</h1>
                <p class="mt-2 text-sm text-muted-foreground">Configure OIDC, social login, and API settings</p>
            </div>
        </div>
        <form method="POST" action="/admin/settings/features" class="space-y-6">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <div
                    class="max-w-6xl mx-auto space-y-6">
                    <!-- OIDC Features -->
                    <div class="bg-card border border-border p-6">
                        <h2 class="text-lg font-semibold text-foreground flex items-center mb-4">
                            <i data-lucide="key" class="h-5 w-5 mr-2 text-primary"></i>
                            OIDC Features
                        </h2>
                        <div
                            class="space-y-6">
                            <!-- Core OIDC Flows -->
                            <div>
                                <h3 class="text-base font-medium text-foreground mb-3">Core OIDC Flows</h3>
                                <p class="text-sm text-muted-foreground mb-4">Enable OIDC features and flows for your provider.</p>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="flex items-center space-x-2">
                                        <input type="checkbox" id="oidc.dev_interactions.enabled" name="oidc[dev_interactions][enabled]" {% if config.oidc and config.oidc.dev_interactions and config.oidc.dev_interactions.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                            <label for="oidc.dev_interactions.enabled" class="text-sm font-medium text-foreground">
                                                Development Interactions
                                            </label>
                                        </div>
                                        <div class="flex items-center space-x-2">
                                            <input type="checkbox" id="oidc.device_flow.enabled" name="oidc[device_flow][enabled]" {% if config.oidc and config.oidc.device_flow and config.oidc.device_flow.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                <label for="oidc.device_flow.enabled" class="text-sm font-medium text-foreground">
                                                    Device Flow
                                                </label>
                                            </div>
                                            <div class="flex items-center space-x-2">
                                                <input type="checkbox" id="oidc.client_credentials.enabled" name="oidc[client_credentials][enabled]" {% if config.oidc and config.oidc.client_credentials and config.oidc.client_credentials.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                    <label for="oidc.client_credentials.enabled" class="text-sm font-medium text-foreground">
                                                        Client Credentials
                                                    </label>
                                                </div>
                                                <div class="flex items-center space-x-2">
                                                    <input type="checkbox" id="oidc.token_revocation.enabled" name="oidc[token_revocation][enabled]" {% if config.oidc and config.oidc.token_revocation and config.oidc.token_revocation.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                        <label for="oidc.token_revocation.enabled" class="text-sm font-medium text-foreground">
                                                            Token Revocation
                                                        </label>
                                                    </div>
                                                    <div class="flex items-center space-x-2">
                                                        <input type="checkbox" id="oidc.token_introspection.enabled" name="oidc[token_introspection][enabled]" {% if config.oidc and config.oidc.token_introspection and config.oidc.token_introspection.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                            <label for="oidc.token_introspection.enabled" class="text-sm font-medium text-foreground">
                                                                Token Introspection
                                                            </label>
                                                        </div>
                                                        <div class="flex items-center space-x-2">
                                                            <input type="checkbox" id="oidc.jwt_introspection.enabled" name="oidc[jwt_introspection][enabled]" {% if config.oidc and config.oidc.jwt_introspection and config.oidc.jwt_introspection.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                <label for="oidc.jwt_introspection.enabled" class="text-sm font-medium text-foreground">
                                                                    JWT Introspection
                                                                </label>
                                                            </div>
                                                            <div class="flex items-center space-x-2">
                                                                <input type="checkbox" id="oidc.userinfo_endpoint.enabled" name="oidc[userinfo_endpoint][enabled]" {% if config.oidc and config.oidc.userinfo_endpoint and config.oidc.userinfo_endpoint.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                    <label for="oidc.userinfo_endpoint.enabled" class="text-sm font-medium text-foreground">
                                                                        UserInfo Endpoint
                                                                    </label>
                                                                </div>
                                                                <div class="flex items-center space-x-2">
                                                                    <input type="checkbox" id="oidc.resource_indicators.enabled" name="oidc[resource_indicators][enabled]" {% if config.oidc and config.oidc.resource_indicators and config.oidc.resource_indicators.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                        <label for="oidc.resource_indicators.enabled" class="text-sm font-medium text-foreground">
                                                                            Resource Indicators
                                                                        </label>
                                                                    </div>
                                                                    <div class="flex items-center space-x-2">
                                                                        <input type="checkbox" id="oidc.rp_initiated_logout.enabled" name="oidc[rp_initiated_logout][enabled]" {% if config.oidc and config.oidc.rp_initiated_logout and config.oidc.rp_initiated_logout.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                            <label for="oidc.rp_initiated_logout.enabled" class="text-sm font-medium text-foreground">
                                                                                RP Initiated Logout
                                                                            </label>
                                                                        </div>
                                                                        <div class="flex items-center space-x-2">
                                                                            <input type="checkbox" id="oidc.backchannel_logout.enabled" name="oidc[backchannel_logout][enabled]" {% if config.oidc and config.oidc.backchannel_logout and config.oidc.backchannel_logout.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                <label for="oidc.backchannel_logout.enabled" class="text-sm font-medium text-foreground">
                                                                                    Backchannel Logout
                                                                                </label>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <!-- Security Features -->
                                                                    <div>
                                                                        <h3 class="text-base font-medium text-foreground mb-3">Security Features</h3>
                                                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                                            <div class="flex items-center space-x-2">
                                                                                <input type="checkbox" id="oidc.pkce.enabled" name="oidc[pkce][enabled]" {% if config.oidc and config.oidc.pkce and config.oidc.pkce.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                    <label for="oidc.pkce.enabled" class="text-sm font-medium text-foreground">
                                                                                        PKCE (Proof Key for Code Exchange)
                                                                                    </label>
                                                                                </div>
                                                                                <div class="flex items-center space-x-2">
                                                                                    <input type="checkbox" id="oidc.pkce.required" name="oidc[pkce][required]" {% if config.oidc and config.oidc.pkce and config.oidc.pkce.required %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                        <label for="oidc.pkce.required" class="text-sm font-medium text-foreground">
                                                                                            PKCE Required
                                                                                        </label>
                                                                                    </div>
                                                                                    <div class="flex items-center space-x-2">
                                                                                        <input type="checkbox" id="oidc.encryption.enabled" name="oidc[encryption][enabled]" {% if config.oidc and config.oidc.encryption and config.oidc.encryption.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                            <label for="oidc.encryption.enabled" class="text-sm font-medium text-foreground">
                                                                                                Encryption
                                                                                            </label>
                                                                                        </div>
                                                                                        <div class="flex items-center space-x-2">
                                                                                            <input type="checkbox" id="oidc.request_objects.enabled" name="oidc[request_objects][enabled]" {% if config.oidc and config.oidc.request_objects and config.oidc.request_objects.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                <label for="oidc.request_objects.enabled" class="text-sm font-medium text-foreground">
                                                                                                    Request Objects
                                                                                                </label>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                    <!-- Dynamic Client Registration -->
                                                                                    <div>
                                                                                        <h3 class="text-base font-medium text-foreground mb-3">Dynamic Client Registration</h3>
                                                                                        <p class="text-sm text-muted-foreground mb-4">Enable dynamic client registration.</p>
                                                                                        <div class="space-y-4">
                                                                                            <div class="flex items-center space-x-2">
                                                                                                <input type="checkbox" id="oidc.dynamic_client_registration.enabled" name="oidc[dynamic_client_registration][enabled]" {% if config.oidc and config.oidc.dynamic_client_registration and config.oidc.dynamic_client_registration.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                    <label for="oidc.dynamic_client_registration.enabled" class="text-sm font-medium text-foreground">
                                                                                                        Enable Dynamic Client Registration
                                                                                                    </label>
                                                                                                </div>
                                                                                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                                                                    <div class="flex items-center space-x-2">
                                                                                                        <input type="checkbox" id="oidc.dynamic_client_registration.require_initial_access_token" name="oidc[dynamic_client_registration][require_initial_access_token]" {% if config.oidc and config.oidc.dynamic_client_registration and config.oidc.dynamic_client_registration.require_initial_access_token %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                            <label for="oidc.dynamic_client_registration.require_initial_access_token" class="text-sm font-medium text-foreground">
                                                                                                                Require Initial Access Token
                                                                                                            </label>
                                                                                                        </div>
                                                                                                        <div class="flex items-center space-x-2">
                                                                                                            <input type="checkbox" id="oidc.dynamic_client_registration.issue_registration_access_token" name="oidc[dynamic_client_registration][issue_registration_access_token]" {% if config.oidc and config.oidc.dynamic_client_registration and config.oidc.dynamic_client_registration.issue_registration_access_token %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                <label
                                                                                                                    for="oidc.dynamic_client_registration.issue_registration_access_token"
                                                                                                                    class="text-sm font-medium text-foreground">
                                                                                                                    Issue Registration Access Token
                                                                                                                </label>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </div>
                                                                                                <!-- Client Registration Management -->
                                                                                                <div>
                                                                                                    <h3 class="text-base font-medium text-foreground mb-3">Client Registration Management</h3>
                                                                                                    <div class="space-y-4">
                                                                                                        <div class="flex items-center space-x-2">
                                                                                                            <input type="checkbox" id="oidc.client_registration_management.enabled" name="oidc[client_registration_management][enabled]" {% if config.oidc and config.oidc.client_registration_management and config.oidc.client_registration_management.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                <label for="oidc.client_registration_management.enabled" class="text-sm font-medium text-foreground">
                                                                                                                    Enable Client Registration Management
                                                                                                                </label>
                                                                                                            </div>
                                                                                                            <div class="flex items-center space-x-2">
                                                                                                                <input type="checkbox" id="oidc.client_registration_management.rotate_registration_access_token" name="oidc[client_registration_management][rotate_registration_access_token]" {% if config.oidc and config.oidc.client_registration_management and config.oidc.client_registration_management.rotate_registration_access_token %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                    <label
                                                                                                                        for="oidc.client_registration_management.rotate_registration_access_token"
                                                                                                                        class="text-sm font-medium text-foreground">
                                                                                                                        Rotate Registration Access Token
                                                                                                                    </label>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                        <!-- Extra Parameters -->
                                                                                                        <div>
                                                                                                            <h3 class="text-base font-medium text-foreground mb-3">Extra Parameters</h3>
                                                                                                            <div class="space-y-4">
                                                                                                                <div class="flex items-center space-x-2">
                                                                                                                    <input type="checkbox" id="oidc.extra_params.enabled" name="oidc[extra_params][enabled]" {% if config.oidc and config.oidc.extra_params and config.oidc.extra_params.enabled %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                        <label for="oidc.extra_params.enabled" class="text-sm font-medium text-foreground">
                                                                                                                            Enable Extra Parameters
                                                                                                                        </label>
                                                                                                                    </div>
                                                                                                                    <div>
                                                                                                                        <label for="oidc.extra_params.allowed_params" class="block text-sm font-medium text-foreground mb-2">Allowed Parameters</label>
                                                                                                                        <textarea
                                                                                                                            id="oidc.extra_params.allowed_params"
                                                                                                                            name="oidc[extra_params][allowed_params]"
                                                                                                                            rows="3"
                                                                                                                            class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground
                                                                                                                                focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
                                                                                                                            placeholder="utm_source&#10;utm_medium&#10;tenant_id">{{ config.oidc and config.oidc.extra_params and config.oidc.extra_params.allowed_params and config.oidc.extra_params.allowed_params | join('\n') or '' }}</textarea>
                                                                                                                        <p class="mt-1 text-xs text-muted-foreground">One per line</p>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                            <!-- Device Flow Configuration -->
                                                                                                            <div>
                                                                                                                <h3 class="text-base font-medium text-foreground mb-3">Device Flow Configuration</h3>
                                                                                                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                                                                                    <div>
                                                                                                                        <label for="oidc.device_flow.charset" class="block text-sm font-medium text-foreground mb-2">Character Set</label>
                                                                                                                        <select
                                                                                                                            id="oidc.device_flow.charset"
                                                                                                                            name="oidc[device_flow][charset]"
                                                                                                                            class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2
                                                                                                                                focus:ring-primary focus:border-transparent">
                                                                                                                            <option value="digits" {% if config.oidc and config.oidc.device_flow and config.oidc.device_flow.charset == 'digits' %} selected {% endif %}>Digits</option>
                                                                                                                            <option value="base-20" {% if config.oidc and config.oidc.device_flow and config.oidc.device_flow.charset == 'base-20' %} selected {% endif %}>Base-20</option>
                                                                                                                        </select>
                                                                                                                    </div>
                                                                                                                    <div>
                                                                                                                        <label for="oidc.device_flow.mask" class="block text-sm font-medium text-foreground mb-2">Display Mask</label>
                                                                                                                        <input type="text" id="oidc.device_flow.mask" name="oidc[device_flow][mask]" value="{{ config.oidc and config.oidc.device_flow and config.oidc.device_flow.mask or '***-*-***' }}" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"></div>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                                <!-- Protocol Behavior Settings -->
                                                                                                                <div>
                                                                                                                    <h3 class="text-base font-medium text-foreground mb-3">Protocol Behavior Settings</h3>
                                                                                                                    <p class="text-sm text-muted-foreground mb-4">Configure protocol behavior and security.</p>
                                                                                                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                                                                                        <div class="flex items-center space-x-2">
                                                                                                                            <input type="checkbox" id="oidc.accept_query_param_access_tokens" name="oidc[accept_query_param_access_tokens]" {% if config.oidc and config.oidc.accept_query_param_access_tokens %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                                <label for="oidc.accept_query_param_access_tokens" class="text-sm font-medium text-foreground">
                                                                                                                                    Accept Query Param Access Tokens
                                                                                                                                </label>
                                                                                                                            </div>
                                                                                                                            <div class="flex items-center space-x-2">
                                                                                                                                <input type="checkbox" id="oidc.conform_id_token_claims" name="oidc[conform_id_token_claims]" {% if config.oidc and config.oidc.conform_id_token_claims %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                                    <label for="oidc.conform_id_token_claims" class="text-sm font-medium text-foreground">
                                                                                                                                        Conform ID Token Claims
                                                                                                                                    </label>
                                                                                                                                </div>
                                                                                                                                <div class="flex items-center space-x-2">
                                                                                                                                    <input type="checkbox" id="oidc.allow_omitting_single_registered_redirect_uri" name="oidc[allow_omitting_single_registered_redirect_uri]" {% if config.oidc and config.oidc.allow_omitting_single_registered_redirect_uri %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                                        <label for="oidc.allow_omitting_single_registered_redirect_uri" class="text-sm font-medium text-foreground">
                                                                                                                                            Allow Omitting Single Registered Redirect URI
                                                                                                                                        </label>
                                                                                                                                    </div>
                                                                                                                                    <div class="flex items-center space-x-2">
                                                                                                                                        <input type="checkbox" id="oidc.enable_http_post_methods" name="oidc[enable_http_post_methods]" {% if config.oidc and config.oidc.enable_http_post_methods %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                                            <label for="oidc.enable_http_post_methods" class="text-sm font-medium text-foreground">
                                                                                                                                                Enable HTTP POST Methods
                                                                                                                                            </label>
                                                                                                                                        </div>
                                                                                                                                        <div class="flex items-center space-x-2">
                                                                                                                                            <input type="checkbox" id="oidc.expires_with_session" name="oidc[expires_with_session]" {% if config.oidc and config.oidc.expires_with_session %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                                                <label for="oidc.expires_with_session" class="text-sm font-medium text-foreground">
                                                                                                                                                    Expires With Session
                                                                                                                                                </label>
                                                                                                                                            </div>
                                                                                                                                            <div class="flex items-center space-x-2">
                                                                                                                                                <input type="checkbox" id="oidc.rotate_refresh_token" name="oidc[rotate_refresh_token]" {% if config.oidc and config.oidc.rotate_refresh_token %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                                                    <label for="oidc.rotate_refresh_token" class="text-sm font-medium text-foreground">
                                                                                                                                                        Rotate Refresh Token
                                                                                                                                                    </label>
                                                                                                                                                </div>
                                                                                                                                                <div class="flex items-center space-x-2">
                                                                                                                                                    <input type="checkbox" id="oidc.client_based_cors" name="oidc[client_based_cors]" {% if config.oidc and config.oidc.client_based_cors %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                                                        <label for="oidc.client_based_cors" class="text-sm font-medium text-foreground">
                                                                                                                                                            Client Based CORS
                                                                                                                                                        </label>
                                                                                                                                                    </div>
                                                                                                                                                    <div>
                                                                                                                                                        <label for="oidc.clock_tolerance" class="block text-sm font-medium text-foreground mb-2">Clock Tolerance (seconds)</label>
                                                                                                                                                        <input type="number" id="oidc.clock_tolerance" name="oidc[clock_tolerance]" value="{{ config.oidc and config.oidc.clock_tolerance or '' }}" min="0" max="300" class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"></div>
                                                                                                                                                    </div>
                                                                                                                                                </div>
                                                                                                                                                <!-- Claims and Scopes Configuration -->
                                                                                                                                                <div>
                                                                                                                                                    <h3 class="text-base font-medium text-foreground mb-3">Claims and Scopes Configuration</h3>
                                                                                                                                                    <p class="text-sm text-muted-foreground mb-4">Configure claims, scopes, and subject types.</p>
                                                                                                                                                    <div class="space-y-4">
                                                                                                                                                        <div>
                                                                                                                                                            <label for="oidc.acr_values.supported" class="block text-sm font-medium text-foreground mb-2">Supported ACR Values</label>
                                                                                                                                                            <textarea
                                                                                                                                                                id="oidc.acr_values.supported"
                                                                                                                                                                name="oidc[acr_values][supported]"
                                                                                                                                                                rows="2"
                                                                                                                                                                class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground
                                                                                                                                                                    focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">{{ config.oidc and config.oidc.acr_values and config.oidc.acr_values.supported and config.oidc.acr_values.supported | join('\n') or '' }}</textarea>
                                                                                                                                                            <p class="mt-1 text-xs text-muted-foreground">One per line</p>
                                                                                                                                                        </div>
                                                                                                                                                        <div>
                                                                                                                                                            <label for="oidc.scopes" class="block text-sm font-medium text-foreground mb-2">Scopes</label>
                                                                                                                                                            <textarea
                                                                                                                                                                id="oidc.scopes"
                                                                                                                                                                name="oidc[scopes]"
                                                                                                                                                                rows="2"
                                                                                                                                                                class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground
                                                                                                                                                                    focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
                                                                                                                                                                placeholder="openid&#10;profile&#10;email">{{ config.oidc and config.oidc.scopes and config.oidc.scopes | join('\n') or '' }}</textarea>
                                                                                                                                                            <p class="mt-1 text-xs text-muted-foreground">One per line</p>
                                                                                                                                                        </div>
                                                                                                                                                        <div>
                                                                                                                                                            <label for="oidc.subject_types" class="block text-sm font-medium text-foreground mb-2">Subject Types</label>
                                                                                                                                                            <div class="space-y-2">
                                                                                                                                                                <div class="flex items-center space-x-2">
                                                                                                                                                                    <input type="checkbox" id="subject_public" name="oidc[subject_types][]" value="public" {% if config.oidc and config.oidc.subject_types and 'public' in config.oidc.subject_types %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                                                                        <label for="subject_public" class="text-sm font-medium text-foreground">Public</label>
                                                                                                                                                                    </div>
                                                                                                                                                                    <div class="flex items-center space-x-2">
                                                                                                                                                                        <input type="checkbox" id="subject_pairwise" name="oidc[subject_types][]" value="pairwise" {% if config.oidc and config.oidc.subject_types and 'pairwise' in config.oidc.subject_types %} checked {% endif %} class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                                                                                                                                                            <label for="subject_pairwise" class="text-sm font-medium text-foreground">Pairwise</label>
                                                                                                                                                                        </div>
                                                                                                                                                                    </div>
                                                                                                                                                                </div>
                                                                                                                                                            </div>
