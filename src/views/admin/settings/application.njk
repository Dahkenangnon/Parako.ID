{% extends "layouts/admin-layout.njk" %}

{% block title %}{{ title }}{% endblock %}

{% block admin_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Page Header -->
    <div class="mb-8">
        {% set activePage = "application" %}
        {% include "partials/admin-settings-tabs.njk" %}

        <div>
            <h1 class="text-2xl font-bold text-foreground">{{ title }}</h1>
            <p class="mt-2 text-sm text-muted-foreground">Configure basic application information and localization settings</p>
        </div>
    </div>

    <form method="POST" action="/admin/settings/application" class="space-y-6">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        
        <div class="max-w-6xl mx-auto space-y-6">
            <!-- Basic Information -->
            <div class="bg-card border border-border p-6">
                <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                    <i data-lucide="info" class="h-5 w-5 mr-2 text-primary"></i>
                    Basic Information
                </h2>
                <div class="grid grid-cols-1 gap-6">
                    <div>
                        <label for="title" class="block text-sm font-medium text-foreground mb-2">Application Title</label>
                        <input type="text" id="title" name="title" 
                               value="{{ config.title or '' }}" required
                               class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        <p class="mt-1 text-xs text-muted-foreground">The display title of your application. This will be shown to users in various parts of the application.</p>
                    </div>

                    <div>
                        <label for="description" class="block text-sm font-medium text-foreground mb-2">Description</label>
                        <textarea id="description" name="description" rows="3" required
                                  class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">{{ config.description or '' }}</textarea>
                        <p class="mt-1 text-xs text-muted-foreground">Brief description of your application. This will be displayed to users and in meta tags.</p>
                    </div>
                </div>
            </div>

            <!-- Localization Settings -->
            <div class="bg-card border border-border p-6">
                <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center">
                    <i data-lucide="globe" class="h-5 w-5 mr-2 text-primary"></i>
                    Localization Settings
                </h2>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div>
                        <label for="locales.default" class="block text-sm font-medium text-foreground mb-2">Default Locale</label>
                        <select id="locales.default" name="locales[default]" required
                                class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                            <option value="">Select default locale</option>
                            <option value="en" {% if config.locales and config.locales.default == 'en' %}selected{% endif %}>English</option>
                            <option value="fr" {% if config.locales and config.locales.default == 'fr' %}selected{% endif %}>Français</option>
                            <option value="es" {% if config.locales and config.locales.default == 'es' %}selected{% endif %}>Español</option>
                            <option value="de" {% if config.locales and config.locales.default == 'de' %}selected{% endif %}>Deutsch</option>
                            <option value="it" {% if config.locales and config.locales.default == 'it' %}selected{% endif %}>Italiano</option>
                            <option value="pt" {% if config.locales and config.locales.default == 'pt' %}selected{% endif %}>Português</option>
                            <option value="ru" {% if config.locales and config.locales.default == 'ru' %}selected{% endif %}>Русский</option>
                            <option value="zh" {% if config.locales and config.locales.default == 'zh' %}selected{% endif %}>中文</option>
                            <option value="ja" {% if config.locales and config.locales.default == 'ja' %}selected{% endif %}>日本語</option>
                            <option value="ko" {% if config.locales and config.locales.default == 'ko' %}selected{% endif %}>한국어</option>
                        </select>
                        <p class="mt-1 text-xs text-muted-foreground">The default language used when no user preference is set.</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-foreground mb-2">Available Locales</label>
                        <div class="bg-muted/30 border border-border p-4 max-h-48 overflow-y-auto">
                            {% set availableLocales = config.locales and config.locales.available or [] %}
                            {% for locale in ['en', 'fr', 'es', 'de', 'it', 'pt', 'ru', 'zh', 'ja', 'ko'] %}
                            <div class="flex items-center space-x-2 mb-2">
                                <input type="checkbox"
                                       id="locale_{{ locale }}" name="locales[available][]"
                                       value="{{ locale }}"
                                       {% if locale in availableLocales %}checked{% endif %}
                                       class="h-4 w-4 text-primary border-border focus:ring-primary focus:ring-2">
                                <label for="locale_{{ locale }}" class="text-sm text-foreground">
                                    {{ locale|upper }} - {{ 
                                      {'en': 'English', 'fr': 'Français', 'es': 'Español', 'de': 'Deutsch', 
                                       'it': 'Italiano', 'pt': 'Português', 'ru': 'Русский', 'zh': '中文', 
                                       'ja': '日本語', 'ko': '한국어'}[locale] 
                                    }}
                                </label>
                            </div>
                            {% endfor %}
                        </div>
                        <p class="mt-2 text-xs text-muted-foreground">Select all locales that should be available to users. The default locale must be included in this list.</p>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-3 justify-end pt-6 border-t border-border">
                <a href="/admin/settings" class="inline-flex items-center justify-center px-4 py-2 border border-border text-foreground text-sm font-medium hover:bg-muted focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2">
                    <i data-lucide="x" class="h-4 w-4 mr-2"></i>
                    Cancel
                </a>
                <button type="button" onclick="resetForm()" class="inline-flex items-center justify-center px-4 py-2 border border-border text-foreground text-sm font-medium hover:bg-muted focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2">
                    <i data-lucide="undo" class="h-4 w-4 mr-2"></i>
                    Reset Form
                </button>
                <button type="submit" class="inline-flex items-center justify-center px-4 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                    <i data-lucide="save" class="h-4 w-4 mr-2"></i>
                    Save Changes
                </button>
            </div>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="{{ asset('js/admin/settings/common.js') }}"></script>
<script src="{{ asset('js/admin/settings/application.js') }}"></script>
{% endblock %}
