{% extends "layouts/admin-layout.njk" %}

{% block admin_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Page Header -->
    <div class="mb-8">
        <nav class="flex mb-4" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-2 text-sm">
                <li>
                    <a href="/admin" class="text-muted-foreground hover:text-foreground">Admin</a>
                </li>
                <li class="text-muted-foreground">/</li>
                <li>
                    <a href="/admin/users" class="text-muted-foreground hover:text-foreground">Users</a>
                </li>
                <li class="text-muted-foreground">/</li>
                <li>
                    <a href="/admin/users/{{ user._id }}" class="text-muted-foreground hover:text-foreground">{{ user.name or user.username }}</a>
                </li>
                <li class="text-muted-foreground">/</li>
                <li class="text-foreground font-medium">Activities</li>
            </ol>
        </nav>
    </div>

    <!-- Profile Banner -->
    <div class="bg-card border border-border mb-6">
        <div class="p-4 sm:p-6 lg:p-8 border-b-2 border-border">
            <div class="flex flex-col sm:flex-row items-start gap-4">
                <!-- Avatar & User Info Section -->
                <div class="flex items-start gap-4 flex-1 min-w-0 w-full">
                    <!-- Avatar -->
                    {% if user.picture %}
                        <img class="h-14 w-14 sm:h-16 sm:w-16 rounded-full border-4 border-border flex-shrink-0" src="{{ user.picture }}" alt="{{ user.name or user.username }}">
                    {% else %}
                        <div class="h-14 w-14 sm:h-16 sm:w-16 rounded-full bg-primary flex items-center justify-center text-primary-foreground text-lg sm:text-xl font-bold border-4 border-border flex-shrink-0">
                            {{ (user.given_name and user.given_name[0]) or (user.username and user.username[0]) or 'U' }}{{ (user.family_name and user.family_name[0]) or '' }}
                        </div>
                    {% endif %}

                    <!-- User Info -->
                    <div class="flex-1 min-w-0">
                        <h1 class="text-lg sm:text-xl lg:text-2xl font-normal tracking-tight text-foreground mb-1">{{ user.given_name }} {{ user.family_name }} - Activities</h1>
                        <p class="text-xs sm:text-sm text-muted-foreground font-mono mb-3 break-all">{{ user.email }} • Activity history and security logs</p>

                        <!-- Status & Roles -->
                        <div class="flex flex-wrap items-center gap-2">
                            <!-- Status Badge -->
                            {% if user.account_is_anonymized %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-muted text-muted-foreground">
                                    <i data-lucide="user-x" class="h-3 w-3 mr-1"></i>
                                    Anonymized
                                </span>
                            {% elif user.account_enabled %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-primary/10 text-primary">
                                    <i data-lucide="check-circle" class="h-3 w-3 mr-1"></i>
                                    Active
                                </span>
                            {% else %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-destructive/10 text-destructive">
                                    <i data-lucide="x-circle" class="h-3 w-3 mr-1"></i>
                                    Disabled
                                </span>
                            {% endif %}

                            <!-- Roles -->
                            {% for role in user.roles %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium
                                    {% if role == 'admin' or role == 'superadmin' %}
                                        bg-destructive/10 text-destructive
                                    {% elif role == 'user' %}
                                        bg-secondary/10 text-secondary
                                    {% else %}
                                        bg-secondary/10 text-secondary
                                    {% endif %}">
                                    {{ role | title }}
                                </span>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
                    <a href="/admin/users/{{ user._id }}" class="inline-flex items-center justify-center px-4 py-2 border border-border text-sm font-medium text-foreground bg-card hover:bg-muted">
                        <i data-lucide="arrow-left" class="h-4 w-4 mr-2"></i>
                        Back to User
                    </a>
                    <a href="/admin/users/{{ user._id }}/edit" class="inline-flex items-center justify-center px-4 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90">
                        <i data-lucide="edit" class="h-4 w-4 mr-2"></i>
                        Edit User
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="bg-card border border-border p-4 sm:p-6 mb-6">
        <form method="GET" action="/admin/users/{{ user._id }}/activities" class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-4">
            <!-- Activity Type Filter -->
            <div class="flex-1">
                <label for="type" class="block text-sm font-medium text-foreground mb-2">Activity Type</label>
                <select name="type" id="type" class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    {% for activityType in activityTypes %}
                    <option value="{{ activityType }}" {% if filters.type == activityType %}selected{% endif %}>
                        {% if activityType == 'all' %}
                            All Activities
                        {% else %}
                            {{ activityType | replace('_', ' ') | title }}
                        {% endif %}
                    </option>
                    {% endfor %}
                </select>
            </div>

            <!-- Items per page -->
            <div>
                <label for="limit" class="block text-sm font-medium text-foreground mb-2">Per Page</label>
                <select name="limit" id="limit" class="px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    <option value="25" {% if pagination.limit == 25 %}selected{% endif %}>25</option>
                    <option value="50" {% if pagination.limit == 50 %}selected{% endif %}>50</option>
                    <option value="100" {% if pagination.limit == 100 %}selected{% endif %}>100</option>
                </select>
            </div>

            <!-- Filter Button -->
            <div class="pt-6">
                <button type="submit" class="px-6 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                    Apply Filter
                </button>
            </div>
        </form>
    </div>

    <!-- Activities Timeline -->
    <div class="space-y-4">
        <!-- Header -->
        <div class="bg-card border border-border p-6">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-semibold text-foreground">Activity Timeline</h2>
                <div class="text-sm text-muted-foreground">
                    Showing {{ pagination.totalResults }} activities
                </div>
            </div>
        </div>

        <!-- Activities List -->
        {% for activity in activities %}
        <div class="bg-card border border-border overflow-hidden">
            <!-- Activity Header -->
            <div class="px-6 py-4 border-b border-border bg-muted/30">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <!-- Activity Icon -->
                        <div class="flex-shrink-0">
                            {% if activity.status == 'success' %}
                                <div class="h-10 w-10 bg-primary/10 flex items-center justify-center">
                                    <i data-lucide="check" class="h-5 w-5 text-primary"></i>
                                </div>
                            {% elif activity.status == 'failed' %}
                                <div class="h-10 w-10 bg-destructive/10 flex items-center justify-center">
                                    <i data-lucide="x" class="h-5 w-5 text-destructive"></i>
                                </div>
                            {% elif activity.status == 'warning' %}
                                <div class="h-10 w-10 bg-warning/10 flex items-center justify-center">
                                    <i data-lucide="alert-triangle" class="h-5 w-5 text-warning"></i>
                                </div>
                            {% else %}
                                <div class="h-10 w-10 bg-secondary/10 flex items-center justify-center">
                                    <i data-lucide="info" class="h-5 w-5 text-secondary"></i>
                                </div>
                            {% endif %}
                        </div>

                        <!-- Activity Info -->
                        <div>
                            <h3 class="text-base font-semibold text-foreground">{{ activity.description }}</h3>
                            <div class="flex items-center space-x-2 mt-1">
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium
                                    {% if activity.status == 'success' %}
                                        bg-primary/10 text-primary
                                    {% elif activity.status == 'failed' %}
                                        bg-destructive/10 text-destructive
                                    {% elif activity.status == 'warning' %}
                                        bg-warning/10 text-warning
                                    {% else %}
                                        bg-secondary/10 text-secondary
                                    {% endif %}">
                                    {{ activity.status | title }}
                                </span>
                                <span class="inline-flex items-center px-2 py-1 text-xs font-medium bg-muted/50 text-muted-foreground">
                                    {{ activity.description }}
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Timestamp -->
                    <div class="text-right">
                        <time class="text-sm font-medium text-foreground font-mono" datetime="{{ activity.timestamp }}">
                            {{ activity.timestamp | date("MMM DD, YYYY", displayTimezone) }}
                        </time>
                        <div class="text-xs text-muted-foreground font-mono">
                            {{ activity.timestamp | date("HH:mm:ss", displayTimezone) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Activity Details -->
            <div class="px-6 py-4">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <!-- Basic Information -->
                    <div class="space-y-4">
                        <h4 class="text-sm font-semibold text-foreground mb-3 flex items-center">
                            <i data-lucide="info" class="h-4 w-4 mr-2 text-primary"></i>
                            Basic Information
                        </h4>
                        
                        <div class="space-y-3">
                            <!-- IP Address -->
                            {% if activity.ip_address %}
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-muted-foreground">IP Address</span>
                                <span class="text-sm font-mono text-foreground">{{ activity.ip_address }}</span>
                            </div>
                            {% endif %}

                            <!-- User Agent -->
                            {% if activity.user_agent and activity.user_agent != 'Unknown' %}
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-muted-foreground">User Agent</span>
                                <span class="text-sm text-foreground font-mono truncate max-w-xs" title="{{ activity.user_agent }}">{{ activity.user_agent }}</span>
                            </div>
                            {% endif %}

                            <!-- Client ID -->
                            {% if activity.client_id %}
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-muted-foreground">Client ID</span>
                                <span class="text-sm font-mono text-foreground">{{ activity.client_id }}</span>
                            </div>
                            {% endif %}

                            <!-- Activity ID -->
                            {% if activity.id %}
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-muted-foreground">Activity ID</span>
                                <span class="text-sm font-mono text-foreground">{{ activity.id }}</span>
                            </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Device Information -->
                    {% if activity.device_infos %}
                    <div class="space-y-4">
                        <h4 class="text-sm font-semibold text-foreground mb-3 flex items-center">
                            <i data-lucide="smartphone" class="h-4 w-4 mr-2 text-primary"></i>
                            Device Information
                        </h4>
                        
                        <div class="space-y-3">
                            <!-- Browser -->
                            {% if activity.device_infos.browser and activity.device_infos.browser.name %}
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-muted-foreground">Browser</span>
                                <span class="text-sm text-foreground">
                                    {{ activity.device_infos.browser.name }}{% if activity.device_infos.browser.version %} {{ activity.device_infos.browser.version }}{% endif %}
                                </span>
                            </div>
                            {% endif %}

                            <!-- Operating System -->
                            {% if activity.device_infos.os and activity.device_infos.os.name %}
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-muted-foreground">Operating System</span>
                                <span class="text-sm text-foreground">
                                    {{ activity.device_infos.os.name }}{% if activity.device_infos.os.version %} {{ activity.device_infos.os.version }}{% endif %}
                                </span>
                            </div>
                            {% endif %}

                            <!-- Device Type -->
                            {% if activity.device_infos.device and activity.device_infos.device.type %}
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-muted-foreground">Device Type</span>
                                <span class="text-sm text-foreground">
                                    {{ activity.device_infos.device.type }}{% if activity.device_infos.device.vendor %} - {{ activity.device_infos.device.vendor }}{% endif %}
                                </span>
                            </div>
                            {% endif %}

                            <!-- Screen Resolution -->
                            {% if activity.device_infos.screen and activity.device_infos.screen.width and activity.device_infos.screen.height %}
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-muted-foreground">Screen Resolution</span>
                                <span class="text-sm text-foreground">{{ activity.device_infos.screen.width }}×{{ activity.device_infos.screen.height }}</span>
                            </div>
                            {% endif %}

                            <!-- Language -->
                            {% if activity.device_infos.language %}
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-muted-foreground">Language</span>
                                <span class="text-sm text-foreground">{{ activity.device_infos.language }}</span>
                            </div>
                            {% endif %}

                            <!-- Platform -->
                            {% if activity.device_infos.platform %}
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-muted-foreground">Platform</span>
                                <span class="text-sm text-foreground">{{ activity.device_infos.platform }}</span>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    {% endif %}
                </div>

                <!-- Geographic Information -->
                {% if activity.device_infos and activity.device_infos.geo_location and activity.device_infos.geo_location.country %}
                <div class="mt-6 pt-4 border-t border-border">
                    <h4 class="text-sm font-semibold text-foreground mb-3 flex items-center">
                        <i data-lucide="map-pin" class="h-4 w-4 mr-2 text-primary"></i>
                        Geographic Location
                    </h4>
                    <div class="flex items-center space-x-4">
                        {% if activity.device_infos.geo_location.city %}
                        <span class="text-sm text-foreground">{{ activity.device_infos.geo_location.city }}</span>
                        {% endif %}
                        <span class="text-sm text-foreground">{{ activity.device_infos.geo_location.country }}</span>
                        {% if activity.device_infos.geo_location.region %}
                        <span class="text-sm text-muted-foreground">({{ activity.device_infos.geo_location.region }})</span>
                        {% endif %}
                    </div>
                </div>
                {% endif %}

                <!-- Security Assessment -->
                {% if activity.device_infos and (activity.device_infos.risk_level or activity.device_infos.is_suspicious or activity.device_infos.is_new_device or activity.device_infos.requires_2fa) %}
                <div class="mt-6 pt-4 border-t border-border">
                    <h4 class="text-sm font-semibold text-foreground mb-3 flex items-center">
                        <i data-lucide="shield" class="h-4 w-4 mr-2 text-primary"></i>
                        Security Assessment
                    </h4>
                    
                    <div class="flex items-center space-x-4 flex-wrap">
                        <!-- Risk Level -->
                        {% if activity.device_infos.risk_level %}
                        <div class="flex items-center space-x-1">
                            {% if activity.device_infos.risk_level == 'low' %}
                                <i data-lucide="shield-check" class="h-4 w-4 text-primary"></i>
                                <span class="text-sm text-primary font-medium">Low Risk</span>
                            {% elif activity.device_infos.risk_level == 'medium' %}
                                <i data-lucide="shield-alert" class="h-4 w-4 text-warning"></i>
                                <span class="text-sm text-warning font-medium">Medium Risk</span>
                            {% elif activity.device_infos.risk_level == 'high' %}
                                <i data-lucide="shield-x" class="h-4 w-4 text-destructive"></i>
                                <span class="text-sm text-destructive font-medium">High Risk</span>
                            {% elif activity.device_infos.risk_level == 'critical' %}
                                <i data-lucide="shield-off" class="h-4 w-4 text-destructive"></i>
                                <span class="text-sm text-destructive font-medium">Critical Risk</span>
                            {% endif %}
                        </div>
                        {% endif %}

                        <!-- Security Flags -->
                        {% if activity.device_infos.is_suspicious %}
                        <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-destructive/10 text-destructive">
                            <i data-lucide="alert-triangle" class="h-3 w-3 mr-1"></i>
                            Suspicious Activity
                        </span>
                        {% endif %}
                        {% if activity.device_infos.is_new_device %}
                        <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-warning/10 text-warning">
                            <i data-lucide="smartphone" class="h-3 w-3 mr-1"></i>
                            New Device
                        </span>
                        {% endif %}
                        {% if activity.device_infos.requires_2fa %}
                        <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-secondary/10 text-secondary">
                            <i data-lucide="shield" class="h-3 w-3 mr-1"></i>
                            2FA Required
                        </span>
                        {% endif %}

                        <!-- Confidence Score -->
                        {% if activity.device_infos.confidence_score %}
                        <span class="text-sm text-muted-foreground">
                            <i data-lucide="percent" class="h-3 w-3 inline mr-1"></i>
                            {{ activity.device_infos.confidence_score }}% confidence
                        </span>
                        {% endif %}
                    </div>

                    <!-- Risk Assessment Details -->
                    {% if activity.device_infos.reason %}
                    <div class="mt-3 p-3 bg-muted/30">
                        <div class="text-sm text-muted-foreground">
                            <strong>Risk Assessment:</strong> {{ activity.device_infos.reason }}
                        </div>
                    </div>
                    {% endif %}
                </div>
                {% endif %}
            </div>
        </div>
        {% else %}
        <div class="bg-card border border-border p-12 text-center">
            <div class="text-muted-foreground">
                <i data-lucide="activity" class="h-12 w-12 mx-auto mb-4 opacity-50"></i>
                <h3 class="text-lg font-medium mb-2">No activities found</h3>
                <p class="text-sm">This user has no recorded activities{% if filters.type and filters.type != 'all' %} for the selected activity type{% endif %}.</p>
            </div>
        </div>
        {% endfor %}

        <!-- Pagination -->
        {% if pagination.totalPages > 1 %}
        <div class="bg-muted/50 px-4 py-3 flex items-center justify-between border-t border-border sm:px-6">
            <div class="flex-1 flex justify-between sm:hidden">
                {% if pagination.hasPrevPage %}
                    <a href="?page={{ pagination.prevPage }}{% if filters.type != 'all' %}&type={{ filters.type }}{% endif %}&limit={{ pagination.limit }}" 
                       class="relative inline-flex items-center px-4 py-2 border border-border text-sm font-medium text-foreground bg-card hover:bg-muted">
                        Previous
                    </a>
                {% endif %}
                {% if pagination.hasNextPage %}
                    <a href="?page={{ pagination.nextPage }}{% if filters.type != 'all' %}&type={{ filters.type }}{% endif %}&limit={{ pagination.limit }}" 
                       class="ml-3 relative inline-flex items-center px-4 py-2 border border-border text-sm font-medium text-foreground bg-card hover:bg-muted">
                        Next
                    </a>
                {% endif %}
            </div>
            <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                <div>
                    <p class="text-sm text-muted-foreground">
                        Showing <span class="font-medium">{{ ((pagination.page - 1) * pagination.limit) + 1 }}</span> to <span class="font-medium">{{ pagination.page * pagination.limit if pagination.page * pagination.limit < pagination.totalResults else pagination.totalResults }}</span> of <span class="font-medium">{{ pagination.totalResults }}</span> activities
                    </p>
                </div>
                <div>
                    <nav class="relative z-0 inline-flex -space-x-px">
                        {% if pagination.hasPrevPage %}
                            <a href="?page={{ pagination.prevPage }}{% if filters.type != 'all' %}&type={{ filters.type }}{% endif %}&limit={{ pagination.limit }}" 
                               class="relative inline-flex items-center px-2 py-2 border border-border bg-card text-sm font-medium text-muted-foreground hover:bg-muted">
                                <i data-lucide="chevron-left" class="h-5 w-5"></i>
                            </a>
                        {% endif %}

                        <!-- Page numbers -->
                        {% set startPage = pagination.page - 2 if pagination.page > 2 else 1 %}
                        {% set endPage = startPage + 4 if startPage + 4 <= pagination.totalPages else pagination.totalPages %}
                        {% set startPage = endPage - 4 if endPage - 4 > 0 else 1 %}

                        {% for pageNum in range(startPage, endPage + 1) %}
                            {% if pageNum == pagination.page %}
                                <span class="relative inline-flex items-center px-4 py-2 border border-border bg-primary text-primary-foreground text-sm font-medium">
                                    {{ pageNum }}
                                </span>
                            {% else %}
                                <a href="?page={{ pageNum }}{% if filters.type != 'all' %}&type={{ filters.type }}{% endif %}&limit={{ pagination.limit }}" 
                                   class="relative inline-flex items-center px-4 py-2 border border-border bg-card text-sm font-medium text-foreground hover:bg-muted">
                                    {{ pageNum }}
                                </a>
                            {% endif %}
                        {% endfor %}

                        {% if pagination.hasNextPage %}
                            <a href="?page={{ pagination.nextPage }}{% if filters.type != 'all' %}&type={{ filters.type }}{% endif %}&limit={{ pagination.limit }}" 
                               class="relative inline-flex items-center px-2 py-2 border border-border bg-card text-sm font-medium text-muted-foreground hover:bg-muted">
                                <i data-lucide="chevron-right" class="h-5 w-5"></i>
                            </a>
                        {% endif %}
                    </nav>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="{{ asset('js/admin/users/activities.js') }}"></script>
{% endblock %}
