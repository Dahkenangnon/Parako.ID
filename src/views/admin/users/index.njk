{% extends "layouts/admin-layout.njk" %}

{% block admin_content %}
<!-- Hidden CSRF Token for JavaScript -->
<input type="hidden" name="_csrf" value="{{ csrfToken }}">

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Page Header -->
    <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="min-w-0 flex-1">
                <h1 class="text-xl sm:text-2xl font-bold text-foreground truncate">User Management</h1>
                <p class="mt-1 text-sm text-muted-foreground">Manage user accounts, permissions, and activities</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
                <a href="/admin/data-transfer/users" class="inline-flex items-center justify-center px-3 sm:px-4 py-2 bg-secondary text-secondary-foreground text-sm font-medium hover:bg-secondary/80 focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2">
                    <i data-lucide="arrow-left-right" class="h-4 w-4 mr-1 sm:mr-2"></i>
                    <span class="hidden xs:inline">Import / Export</span>
                    <span class="xs:hidden">Import</span>
                </a>
                <a href="/admin/users/new" class="inline-flex items-center justify-center px-3 sm:px-4 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                    <i data-lucide="user-plus" class="h-4 w-4 mr-1 sm:mr-2"></i>
                    <span class="hidden xs:inline">Add User</span>
                    <span class="xs:hidden">Add</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Statistics Grid - Professional Card Layout -->
    <div class="grid grid-cols-1 xs:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-6">
        <!-- Total Users -->
        <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
            <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Total Users</p>
                    <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ stats.totalUsers | default(0) }}</p>
                </div>
                <div class="flex-shrink-0 ml-3">
                    <div class="w-12 h-12 bg-primary/10 flex items-center justify-center">
                        <i data-lucide="users" class="h-6 w-6 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Active Users -->
        <div class="bg-card border border-border p-4 hover:border-primary/30 transition-colors">
            <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Active Users</p>
                    <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ stats.activeUsers | default(0) }}</p>
                </div>
                <div class="flex-shrink-0 ml-3">
                    <div class="w-12 h-12 bg-primary/10 flex items-center justify-center">
                        <i data-lucide="user-check" class="h-6 w-6 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Admin Users -->
        <div class="bg-card border border-border p-4 hover:border-warning/30 transition-colors">
            <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Admins</p>
                    <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ stats.adminUsers | default(0) }}</p>
                </div>
                <div class="flex-shrink-0 ml-3">
                    <div class="w-12 h-12 bg-warning/10 flex items-center justify-center">
                        <i data-lucide="shield" class="h-6 w-6 text-warning"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- New Users -->
        <div class="bg-card border border-border p-4 hover:border-secondary/30 transition-colors">
            <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">New (30d)</p>
                    <p class="mt-2 text-2xl font-bold text-foreground truncate">{{ stats.recentUsers | default(0) }}</p>
                </div>
                <div class="flex-shrink-0 ml-3">
                    <div class="w-12 h-12 bg-secondary/10 flex items-center justify-center">
                        <i data-lucide="user-plus" class="h-6 w-6 text-secondary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters - Advanced Sectioned Design -->
    <div class="bg-card border border-border overflow-hidden mb-6">
        <form method="GET" action="/admin/users">
            <!-- Filter Header -->
            <div class="bg-muted/50 px-4 py-2 border-b border-border">
                <div class="flex items-center gap-2">
                    <i data-lucide="filter" class="h-4 w-4 text-muted-foreground"></i>
                    <h3 class="text-sm font-medium text-foreground">Filters</h3>
                </div>
            </div>

            <!-- Filter Controls -->
            <div class="p-4 space-y-4">
                <!-- Search Section -->
                <div>
                    <label for="search" class="block text-xs font-medium text-muted-foreground mb-2">Search</label>
                    <div class="relative">
                        <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none"></i>
                        <input
                            type="text"
                            name="search"
                            id="search"
                            value="{{ filters.search }}"
                            placeholder="Search by username, email, or name..."
                            class="w-full pl-10 pr-3 py-2 text-sm border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
                        >
                    </div>
                </div>

                <!-- Filter & Sort Grid -->
                <div>
                    <label class="block text-xs font-medium text-muted-foreground mb-2">Filter & Sort</label>
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                        <!-- Role -->
                        <div class="relative">
                            <select
                                name="role"
                                id="role"
                                class="appearance-none w-full pl-3 pr-9 py-2 text-sm border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
                            >
                                <option value="">All Roles</option>
                                {% for role in roles %}
                                <option value="{{ role }}" {% if filters.role == role %}selected{% endif %}>{{ role | title }}</option>
                                {% endfor %}
                            </select>
                            <i data-lucide="chevron-down" class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none"></i>
                        </div>

                        <!-- Status -->
                        <div class="relative">
                            <select
                                name="status"
                                id="status"
                                class="appearance-none w-full pl-3 pr-9 py-2 text-sm border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
                            >
                                <option value="all" {% if filters.status == 'all' %}selected{% endif %}>All Status</option>
                                <option value="active" {% if filters.status == 'active' %}selected{% endif %}>Active</option>
                                <option value="disabled" {% if filters.status == 'disabled' %}selected{% endif %}>Disabled</option>
                                <option value="anonymized" {% if filters.status == 'anonymized' %}selected{% endif %}>Anonymized</option>
                            </select>
                            <i data-lucide="chevron-down" class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none"></i>
                        </div>

                        <!-- Sort By -->
                        <div class="relative">
                            <select
                                name="sortBy"
                                id="sortBy"
                                class="appearance-none w-full pl-3 pr-9 py-2 text-sm border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
                            >
                                <option value="created_at" {% if filters.sortBy == 'created_at' %}selected{% endif %}>Created Date</option>
                                <option value="username" {% if filters.sortBy == 'username' %}selected{% endif %}>Username</option>
                                <option value="email" {% if filters.sortBy == 'email' %}selected{% endif %}>Email</option>
                                <option value="last_login" {% if filters.sortBy == 'last_login' %}selected{% endif %}>Last Login</option>
                            </select>
                            <i data-lucide="chevron-down" class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none"></i>
                        </div>

                        <!-- Sort Order -->
                        <div class="relative">
                            <select
                                name="sortOrder"
                                id="sortOrder"
                                class="appearance-none w-full pl-3 pr-9 py-2 text-sm border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
                            >
                                <option value="desc" {% if filters.sortOrder == 'desc' %}selected{% endif %}>Descending</option>
                                <option value="asc" {% if filters.sortOrder == 'asc' %}selected{% endif %}>Ascending</option>
                            </select>
                            <i data-lucide="chevron-down" class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Footer -->
            <div class="bg-muted/30 px-4 py-3 border-t border-border flex flex-col sm:flex-row gap-2 sm:justify-end">
                <button
                    type="submit"
                    class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors"
                >
                    <i data-lucide="filter" class="h-4 w-4"></i>
                    <span>Apply Filters</span>
                </button>
                <a
                    href="/admin/users"
                    class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-secondary text-secondary-foreground text-sm font-medium hover:bg-secondary/80 focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2 transition-colors"
                >
                    <i data-lucide="x" class="h-4 w-4"></i>
                    <span>Clear Filters</span>
                </a>
            </div>
        </form>
    </div>

    <!-- Users Table -->
    <div class="bg-card border border-border overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-border">
                <thead class="bg-muted/50 border-b border-border">
                    <tr>
                        <!-- User (Sortable) -->
                        <th scope="col" class="px-6 py-3 text-left">
                            <a href="?sortBy=username&sortOrder={% if filters.sortBy == 'username' and filters.sortOrder == 'asc' %}desc{% else %}asc{% endif %}{% if filters.search %}&search={{ filters.search }}{% endif %}{% if filters.role %}&role={{ filters.role }}{% endif %}{% if filters.status != 'all' %}&status={{ filters.status }}{% endif %}"
                               class="group inline-flex items-center gap-1.5 text-xs font-semibold text-muted-foreground uppercase tracking-wide hover:text-foreground transition-colors">
                                <span>User</span>
                                {% if filters.sortBy == 'username' %}
                                    {% if filters.sortOrder == 'asc' %}
                                        <i data-lucide="arrow-up" class="h-3 w-3 text-foreground"></i>
                                    {% else %}
                                        <i data-lucide="arrow-down" class="h-3 w-3 text-foreground"></i>
                                    {% endif %}
                                {% endif %}
                            </a>
                        </th>
                        <!-- Email (Sortable) -->
                        <th scope="col" class="px-6 py-3 text-left">
                            <a href="?sortBy=email&sortOrder={% if filters.sortBy == 'email' and filters.sortOrder == 'asc' %}desc{% else %}asc{% endif %}{% if filters.search %}&search={{ filters.search }}{% endif %}{% if filters.role %}&role={{ filters.role }}{% endif %}{% if filters.status != 'all' %}&status={{ filters.status }}{% endif %}"
                               class="group inline-flex items-center gap-1.5 text-xs font-semibold text-muted-foreground uppercase tracking-wide hover:text-foreground transition-colors">
                                <span>Email</span>
                                {% if filters.sortBy == 'email' %}
                                    {% if filters.sortOrder == 'asc' %}
                                        <i data-lucide="arrow-up" class="h-3 w-3 text-foreground"></i>
                                    {% else %}
                                        <i data-lucide="arrow-down" class="h-3 w-3 text-foreground"></i>
                                    {% endif %}
                                {% endif %}
                            </a>
                        </th>
                        <!-- Custom Identifier columns -->
                        {% for ciField in customIdentifierFields %}
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">{{ ciField.name }}</th>
                        {% endfor %}
                        <!-- Roles (Not Sortable) -->
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Roles</th>
                        <!-- Status (Not Sortable) -->
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Status</th>
                        <!-- Actions (Not Sortable) -->
                        <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-muted-foreground uppercase tracking-wide">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-card divide-y divide-border">
                    {% for user in users %}
                    <tr class="hover:bg-primary/5 border-b border-border">
                        <!-- User Info -->
                        <td class="px-6 py-5 whitespace-nowrap">
                            <div class="flex items-center">
                                {% if user.account_is_anonymized %}
                                    <div class="h-10 w-10 rounded-full bg-muted/50 flex items-center justify-center text-muted-foreground font-medium opacity-60">
                                        Ano
                                    </div>
                                {% elif user.picture %}
                                    <img class="h-10 w-10 rounded-full" src="{{ user.picture }}" alt="{{ user.name or user.username }}">
                                {% else %}
                                    <div class="h-10 w-10 rounded-full bg-primary flex items-center justify-center text-primary-foreground font-medium">
                                        {{ (user.given_name and user.given_name[0]) or (user.username and user.username[0]) or 'U' }}{{ (user.family_name and user.family_name[0]) or '' }}
                                    </div>
                                {% endif %}
                                <div class="ml-4 min-w-0 flex-1">
                                    <div class="text-sm font-medium text-foreground truncate max-w-32" title="{{ user.name or user.username }}">{{ user.name or user.username }}</div>
                                </div>
                            </div>
                        </td>

                        <!-- Email / Contact -->
                        <td class="px-6 py-5 whitespace-nowrap">
                            {% if user.email %}
                                <div class="text-sm text-foreground truncate max-w-48" title="{{ user.email }}">{{ user.email }}</div>
                                {% if user.email_verified %}
                                    <div class="text-xs text-primary flex items-center">
                                        <i data-lucide="check-circle" class="h-3 w-3 mr-1"></i>
                                        Verified
                                    </div>
                                {% else %}
                                    <div class="text-xs text-warning flex items-center">
                                        <i data-lucide="alert-circle" class="h-3 w-3 mr-1"></i>
                                        Unverified
                                    </div>
                                {% endif %}
                            {% elif user.recovery and user.recovery.secondary_email and user.recovery.secondary_email.email %}
                                <div class="text-sm text-foreground truncate max-w-48" title="{{ user.recovery.secondary_email.email }}">{{ user.recovery.secondary_email.email }}</div>
                                <div class="text-xs text-muted-foreground flex items-center">
                                    <i data-lucide="mail" class="h-3 w-3 mr-1"></i>
                                    Recovery email
                                </div>
                            {% elif user.phone_number %}
                                <div class="text-sm text-foreground truncate max-w-48" title="{{ user.phone_number }}">{{ user.phone_number }}</div>
                                {% if user.phone_number_verified %}
                                    <div class="text-xs text-primary flex items-center">
                                        <i data-lucide="check-circle" class="h-3 w-3 mr-1"></i>
                                        Phone verified
                                    </div>
                                {% else %}
                                    <div class="text-xs text-muted-foreground flex items-center">
                                        <i data-lucide="phone" class="h-3 w-3 mr-1"></i>
                                        Phone only
                                    </div>
                                {% endif %}
                            {% else %}
                                <div class="text-sm text-muted-foreground">No contact</div>
                            {% endif %}
                        </td>

                        <!-- Custom Identifier columns -->
                        {% for ciField in customIdentifierFields %}
                        <td class="px-6 py-5 whitespace-nowrap">
                            {% if user['custom_identifier_' + ciField.slot] %}
                                <div class="text-sm text-foreground font-mono truncate max-w-32" title="{{ user['custom_identifier_' + ciField.slot] }}">{{ user['custom_identifier_' + ciField.slot] }}</div>
                            {% else %}
                                <div class="text-sm text-muted-foreground">—</div>
                            {% endif %}
                        </td>
                        {% endfor %}

                        <!-- Roles -->
                        <td class="px-6 py-5 whitespace-nowrap">
                            <div class="flex flex-wrap gap-1 max-w-32">
                                {% for role in user.roles %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium truncate max-w-24
                                        {% if role == 'admin' or role == 'superadmin' %}
                                            bg-destructive/10 text-destructive
                                        {% elif role == 'user' %}
                                            bg-primary/10 text-primary
                                        {% else %}
                                            bg-secondary/10 text-secondary
                                        {% endif %}" title="{{ role | title }}">
                                        {{ role | title }}
                                    </span>
                                {% endfor %}
                            </div>
                        </td>

                        <!-- Status -->
                        <td class="px-6 py-5 whitespace-nowrap">
                            {% if user.account_is_anonymized %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-muted text-muted-foreground">
                                    <i data-lucide="user-x" class="h-3 w-3 mr-1"></i>
                                    Anonymized
                                </span>
                            {% elif user.account_enabled %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-primary/10 text-primary">
                                    <i data-lucide="check-circle" class="h-3 w-3 mr-1"></i>
                                    Active
                                </span>
                            {% else %}
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium bg-warning/10 text-warning">
                                    <i data-lucide="x-circle" class="h-3 w-3 mr-1"></i>
                                    Disabled
                                </span>
                            {% endif %}
                        </td>

                        <!-- Actions -->
                        <td class="px-6 py-5 whitespace-nowrap text-right text-sm font-medium">
                            <div class="flex items-center justify-end space-x-2">
                                <a href="/admin/users/{{ user._id }}" class="text-primary hover:text-primary/80" title="View Details">
                                    <i data-lucide="eye" class="h-4 w-4"></i>
                                </a>
                                <a href="/admin/users/{{ user._id }}/edit" class="text-primary hover:text-primary/80" title="Edit User">
                                    <i data-lucide="edit" class="h-4 w-4"></i>
                                </a>
                                <a href="/admin/users/{{ user._id }}/activities" class="text-primary hover:text-primary/80" title="View Activities">
                                    <i data-lucide="activity" class="h-4 w-4"></i>
                                </a>

                                <!-- Action Buttons -->
                                {% if not user.account_is_anonymized %}
                                    {% if user.account_enabled %}
                                        <button onclick="toggleUserStatus('{{ user._id }}', 'disable')" class="text-warning hover:text-warning/80" title="Disable User">
                                            <i data-lucide="user-minus" class="h-4 w-4"></i>
                                        </button>
                                    {% else %}
                                        <button onclick="toggleUserStatus('{{ user._id }}', 'enable')" class="text-primary hover:text-primary/80" title="Enable User">
                                            <i data-lucide="user-plus" class="h-4 w-4"></i>
                                        </button>
                                    {% endif %}
                                    <button onclick="anonymizeUser('{{ user._id }}', '{{ user.username }}')" class="text-destructive hover:text-destructive/80" title="Anonymize User">
                                        <i data-lucide="trash-2" class="h-4 w-4"></i>
                                    </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="{{ 5 + customIdentifierFields.length }}" class="px-6 py-12 text-center">
                            <div class="text-muted-foreground">
                                <i data-lucide="users" class="h-12 w-12 mx-auto mb-4 opacity-50"></i>
                                <h3 class="text-lg font-medium mb-2">No users found</h3>
                                <p class="text-sm">Try adjusting your search or filter criteria.</p>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        {% if pagination.totalPages > 1 %}
        <div class="bg-muted/50 px-4 py-3 flex items-center justify-between border-t border-border sm:px-6">
            <div class="flex-1 flex justify-between sm:hidden">
                {% if pagination.hasPrevPage %}
                    <a href="?page={{ pagination.prevPage }}{% if filters.search %}&search={{ filters.search }}{% endif %}{% if filters.role != 'all' %}&role={{ filters.role }}{% endif %}{% if filters.status != 'all' %}&status={{ filters.status }}{% endif %}&sortBy={{ filters.sortBy }}&sortOrder={{ filters.sortOrder }}"
                       class="relative inline-flex items-center px-4 py-2 border border-border text-sm font-medium text-foreground bg-card hover:bg-muted">
                        Previous
                    </a>
                {% endif %}
                {% if pagination.hasNextPage %}
                    <a href="?page={{ pagination.nextPage }}{% if filters.search %}&search={{ filters.search }}{% endif %}{% if filters.role != 'all' %}&role={{ filters.role }}{% endif %}{% if filters.status != 'all' %}&status={{ filters.status }}{% endif %}&sortBy={{ filters.sortBy }}&sortOrder={{ filters.sortOrder }}"
                       class="ml-3 relative inline-flex items-center px-4 py-2 border border-border text-sm font-medium text-foreground bg-card hover:bg-muted">
                        Next
                    </a>
                {% endif %}
            </div>
            <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                <div>
                    <p class="text-sm text-muted-foreground">
                        Showing <span class="font-medium">{{ ((pagination.page - 1) * pagination.limit) + 1 }}</span> to <span class="font-medium">{{ pagination.page * pagination.limit if pagination.page * pagination.limit < pagination.totalResults else pagination.totalResults }}</span> of <span class="font-medium">{{ pagination.totalResults }}</span> results
                    </p>
                </div>
                <div>
                    <nav class="relative z-0 inline-flex -space-x-px">
                        {% if pagination.hasPrevPage %}
                            <a href="?page={{ pagination.prevPage }}{% if filters.search %}&search={{ filters.search }}{% endif %}{% if filters.role != 'all' %}&role={{ filters.role }}{% endif %}{% if filters.status != 'all' %}&status={{ filters.status }}{% endif %}&sortBy={{ filters.sortBy }}&sortOrder={{ filters.sortOrder }}"
                               class="relative inline-flex items-center px-2 py-2 border border-border bg-card text-sm font-medium text-muted-foreground hover:bg-muted">
                                <i data-lucide="chevron-left" class="h-5 w-5"></i>
                            </a>
                        {% endif %}

                        <!-- Page numbers -->
                        {% set startPage = pagination.page - 2 if pagination.page > 2 else 1 %}
                        {% set endPage = startPage + 4 if startPage + 4 <= pagination.totalPages else pagination.totalPages %}
                        {% set startPage = endPage - 4 if endPage - 4 > 0 else 1 %}

                        {% for pageNum in range(startPage, endPage + 1) %}
                            {% if pageNum == pagination.page %}
                                <span class="relative inline-flex items-center px-4 py-2 border border-border bg-primary text-primary-foreground text-sm font-medium">
                                    {{ pageNum }}
                                </span>
                            {% else %}
                                <a href="?page={{ pageNum }}{% if filters.search %}&search={{ filters.search }}{% endif %}{% if filters.role != 'all' %}&role={{ filters.role }}{% endif %}{% if filters.status != 'all' %}&status={{ filters.status }}{% endif %}&sortBy={{ filters.sortBy }}&sortOrder={{ filters.sortOrder }}"
                                   class="relative inline-flex items-center px-4 py-2 border border-border bg-card text-sm font-medium text-foreground hover:bg-muted">
                                    {{ pageNum }}
                                </a>
                            {% endif %}
                        {% endfor %}

                        {% if pagination.hasNextPage %}
                            <a href="?page={{ pagination.nextPage }}{% if filters.search %}&search={{ filters.search }}{% endif %}{% if filters.role != 'all' %}&role={{ filters.role }}{% endif %}{% if filters.status != 'all' %}&status={{ filters.status }}{% endif %}&sortBy={{ filters.sortBy }}&sortOrder={{ filters.sortOrder }}"
                               class="relative inline-flex items-center px-2 py-2 border border-border bg-card text-sm font-medium text-muted-foreground hover:bg-muted">
                                <i data-lucide="chevron-right" class="h-5 w-5"></i>
                            </a>
                        {% endif %}
                    </nav>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block scripts %}
{{ super() }}
<!-- Admin Users Management Script -->
<script src="{{ asset('js/admin/users.js') }}"></script>
{% endblock %}
