{% extends "layouts/admin-layout.njk" %}

{% block admin_content %}
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Page Header -->
    <div class="mb-8">
        <nav class="flex mb-4" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-2 text-sm">
                <li>
                    <a href="/admin" class="text-muted-foreground hover:text-foreground">Admin</a>
                </li>
                <li class="text-muted-foreground">/</li>
                <li>
                    <a href="/admin/users" class="text-muted-foreground hover:text-foreground">Users</a>
                </li>
                <li class="text-muted-foreground">/</li>
                <li class="text-foreground font-medium">Add New User</li>
            </ol>
        </nav>

        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div class="flex-1">
                <h1 class="text-xl sm:text-2xl font-bold text-foreground">Add New User</h1>
                <p class="mt-2 text-sm text-muted-foreground">Create a new user account with access credentials and permissions</p>
            </div>
            <a href="/admin/users" class="inline-flex items-center px-4 py-2 border border-border text-sm font-medium text-foreground bg-card hover:bg-muted w-full sm:w-auto justify-center">
                <i data-lucide="arrow-left" class="h-4 w-4 mr-2"></i>
                Back to Users
            </a>
        </div>
    </div>

    <!-- Create Form -->
    <form method="POST" action="/admin/users/new" class="space-y-6" id="createUserForm">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        <!-- Essential Information (Top Priority) -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                <i data-lucide="star" class="h-5 w-5 mr-2 text-primary"></i>
                Essential Information
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Email -->
                <div>
                    <label for="email" class="block text-sm font-medium text-foreground mb-2">Email Address <span class="text-red-500">*</span></label>
                    <input type="email" id="email" name="email" required
                           placeholder="user@example.com"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- First Name -->
                <div>
                    <label for="given_name" class="block text-sm font-medium text-foreground mb-2">First Name <span class="text-red-500">*</span></label>
                    <input type="text" id="given_name" name="given_name" required
                           placeholder="Enter first name"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Last Name -->
                <div>
                    <label for="family_name" class="block text-sm font-medium text-foreground mb-2">Last Name <span class="text-red-500">*</span></label>
                    <input type="text" id="family_name" name="family_name" required
                           placeholder="Enter last name"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>


                <!-- Custom Identifier Fields -->
                {% for ciField in customIdentifierFields %}
                <div>
                    <label for="custom_identifier_{{ ciField.slot }}" class="block text-sm font-medium text-foreground mb-2">{{ ciField.name }}</label>
                    <input type="text" id="custom_identifier_{{ ciField.slot }}" name="custom_identifier_{{ ciField.slot }}"
                           placeholder="{{ ciField.hint_for_user }}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    {% if ciField.hint_for_user %}
                    <p class="mt-1 text-xs text-muted-foreground">{{ ciField.hint_for_user }}</p>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- Account Security -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                <i data-lucide="key" class="h-5 w-5 mr-2 text-muted-foreground"></i>
                Account Security
            </h2>
            <div class="space-y-4">
                <!-- Password -->
                <div>
                    <label for="password" class="block text-sm font-medium text-foreground mb-2">Password <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="password" id="password" name="password" required
                               placeholder="Enter secure password"
                               class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent pr-10">
                        <button type="button" onclick="togglePasswordVisibility('password')" 
                                class="absolute inset-y-0 right-0 pr-3 flex items-center text-muted-foreground hover:text-foreground">
                            <i data-lucide="eye" class="h-4 w-4" id="password_icon"></i>
                        </button>
                    </div>
                    <div class="mt-1 text-xs text-muted-foreground">
                        <ul class="space-y-1">
                            <li>• Minimum 8 characters required</li>
                            <li>• Include uppercase and lowercase letters</li>
                            <li>• Include at least one number</li>
                            <li>• Include at least one special character</li>
                        </ul>
                    </div>
                </div>

                <!-- Confirm Password -->
                <div>
                    <label for="confirm_password" class="block text-sm font-medium text-foreground mb-2">Confirm Password <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="password" id="confirm_password" name="confirm_password" required
                               placeholder="Confirm password"
                               class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent pr-10">
                        <button type="button" onclick="togglePasswordVisibility('confirm_password')" 
                                class="absolute inset-y-0 right-0 pr-3 flex items-center text-muted-foreground hover:text-foreground">
                            <i data-lucide="eye" class="h-4 w-4" id="confirm_password_icon"></i>
                        </button>
                    </div>
                    <div id="password_match_indicator" class="mt-1 text-xs hidden">
                        <span id="password_match_text"></span>
                    </div>
                </div>

                <!-- Password Options -->
                <div class="space-y-3">
                    <div class="flex items-center space-x-2">
                        <input type="checkbox" id="password_force_reset" name="password_force_reset" value="true"
                               class="h-4 w-4 text-primary border-border focus:ring-primary">
                        <label for="password_force_reset" class="text-sm text-foreground">
                            Force password reset on first login
                        </label>
                    </div>
                    <div class="flex items-center space-x-2">
                        <input type="checkbox" id="generatePassword" name="generatePassword"
                               class="h-4 w-4 text-primary border-border focus:ring-primary">
                        <label for="generatePassword" class="text-sm text-foreground">
                            Generate secure password automatically
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Roles and Permissions -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                <i data-lucide="shield" class="h-5 w-5 mr-2 text-muted-foreground"></i>
                Roles and Permissions
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- User Roles -->
                <div>
                    <label for="roles" class="block text-sm font-medium text-foreground mb-2">User Roles</label>
                    <select id="roles" name="roles" multiple size="6" 
                            class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        {% for role in roles %}
                        <option value="{{ role }}" {% if role == 'user' %}selected{% endif %}>
                            {{ role | title }}
                        </option>
                        {% endfor %}
                    </select>
                    <p class="mt-1 text-xs text-muted-foreground">Hold Ctrl (Cmd on Mac) to select multiple roles</p>
                </div>

                <!-- Account Status -->
                <div>
                    <label for="account_enabled" class="block text-sm font-medium text-foreground mb-2">Account Status</label>
                    <select id="account_enabled" name="account_enabled" 
                            class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        <option value="true" selected>Enabled</option>
                        <option value="false">Disabled</option>
                    </select>
                    <p class="mt-1 text-xs text-muted-foreground">User can be enabled later if created as disabled</p>
                </div>
            </div>
        </div>

        <!-- Personal Information -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                <i data-lucide="user" class="h-5 w-5 mr-2 text-muted-foreground"></i>
                Personal Information
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Middle Name -->
                <div>
                    <label for="middle_name" class="block text-sm font-medium text-foreground mb-2">Middle Name</label>
                    <input type="text" id="middle_name" name="middle_name"
                           placeholder="Enter middle name"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Nickname -->
                <div>
                    <label for="nickname" class="block text-sm font-medium text-foreground mb-2">Nickname</label>
                    <input type="text" id="nickname" name="nickname"
                           placeholder="Enter nickname"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>


                <!-- Gender -->
                <div>
                    <label for="gender" class="block text-sm font-medium text-foreground mb-2">Gender</label>
                    <select id="gender" name="gender" 
                            class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        <option value="">Select gender</option>
                        <option value="M">Male</option>
                        <option value="F">Female</option>
                    </select>
                </div>

                <!-- Birthdate -->
                <div>
                    <label for="birthdate" class="block text-sm font-medium text-foreground mb-2">Birthdate</label>
                    <input type="date" id="birthdate" name="birthdate"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Phone Number -->
                <div>
                    <label for="phone_number" class="block text-sm font-medium text-foreground mb-2">Phone Number</label>
                    <input type="tel" id="phone_number" name="phone_number"
                           placeholder="+1 (555) 123-4567"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Profile URL -->
                <div>
                    <label for="profile" class="block text-sm font-medium text-foreground mb-2">Profile URL</label>
                    <input type="text" id="profile" name="profile"
                           placeholder="https://example.com/profile or /profile"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Website -->
                <div>
                    <label for="website" class="block text-sm font-medium text-foreground mb-2">Website</label>
                    <input type="text" id="website" name="website"
                           placeholder="https://example.com or /website"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Picture URL -->
                <div>
                    <label for="picture" class="block text-sm font-medium text-foreground mb-2">Profile Picture URL</label>
                    <input type="text" id="picture" name="picture"
                           placeholder="https://example.com/avatar.jpg or /img/avatar.jpg"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>
            </div>
        </div>

        <!-- Location Information -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                <i data-lucide="map-pin" class="h-5 w-5 mr-2 text-muted-foreground"></i>
                Location Information
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Country -->
                <div>
                    <label for="country" class="block text-sm font-medium text-foreground mb-2">Country</label>
                    <input type="text" id="country" name="country" value="bj"
                           placeholder="Enter country code (e.g., bj, us, fr)"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Region/State -->
                <div>
                    <label for="region" class="block text-sm font-medium text-foreground mb-2">Region/State</label>
                    <input type="text" id="region" name="region"
                           placeholder="Enter region or state"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- City -->
                <div>
                    <label for="city" class="block text-sm font-medium text-foreground mb-2">City</label>
                    <input type="text" id="city" name="city"
                           placeholder="Enter city"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Postal Code -->
                <div>
                    <label for="postal_code" class="block text-sm font-medium text-foreground mb-2">Postal Code</label>
                    <input type="text" id="postal_code" name="postal_code"
                           placeholder="Enter postal code"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Street Address -->
                <div class="md:col-span-2">
                    <label for="street_address" class="block text-sm font-medium text-foreground mb-2">Street Address</label>
                    <input type="text" id="street_address" name="street_address"
                           placeholder="Enter street address"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Locale -->
                <div>
                    <label for="locale" class="block text-sm font-medium text-foreground mb-2">Locale</label>
                    <select id="locale" name="locale" 
                            class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        {% for locale in app.locales.available %}
                        <option value="{{ locale }}" {% if locale == app.locales.default %}selected{% endif %}>
                            {{ 
                              {'en': 'English', 'fr': 'Français', 'es': 'Español', 'de': 'Deutsch', 
                               'it': 'Italiano', 'pt': 'Português', 'ru': 'Русский', 'zh': '中文', 
                               'ja': '日本語', 'ko': '한국어'}[locale] or locale | upper
                            }}
                        </option>
                        {% endfor %}
                    </select>
                </div>

