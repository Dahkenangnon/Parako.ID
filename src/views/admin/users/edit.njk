        <!-- Password Reset -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                <i data-lucide="key" class="h-5 w-5 mr-2 text-muted-foreground"></i>
                Password Management
            </h2>
            <div class="space-y-4">
                <div class="bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800 p-4">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i data-lucide="alert-triangle" class="h-5 w-5 text-orange-600 dark:text-orange-400"></i>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-orange-800 dark:text-orange-200">Password Reset</h3>
                            <p class="mt-2 text-sm text-orange-700 dark:text-orange-300">
                                Only enter a new password if you want to change the user's current password. Leave blank to keep the existing password.
                            </p>
                        </div>
                    </div>
                </div>

                <div>
                    <label for="new_password" class="block text-sm font-medium text-foreground mb-2">New Password</label>
                    <div class="relative">
                        <input type="password" id="new_password" name="new_password" 
                               placeholder="Leave blank to keep current password"
                               class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent pr-10">
                        <button type="button" onclick="togglePasswordVisibility('new_password')" 
                                class="absolute inset-y-0 right-0 pr-3 flex items-center text-muted-foreground hover:text-foreground">
                            <i data-lucide="eye" class="h-4 w-4" id="new_password_icon"></i>
                        </button>
                    </div>
                    <p class="mt-1 text-xs text-muted-foreground">Minimum 8 characters required if setting a new password</p>
                </div>

                <div class="flex items-center space-x-2">
                    <input type="checkbox" id="password_force_reset" name="password_force_reset" value="true"
                           {% if user.password_force_reset %}checked{% endif %}
                           class="h-4 w-4 text-primary border-border focus:ring-primary">
                    <label for="password_force_reset" class="text-sm text-medium text-foreground">
                        Force password reset on next login
                    </label>
                </div>
            </div>
        </div>


        <!-- Form Actions -->
        <div class="bg-card border border-border p-4 sm:p-6">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="text-xs sm:text-sm text-muted-foreground">
                    Last updated: {% if user.updated_at %}{{ user.updated_at | date("MMM DD, YYYY HH:mm:ss", displayTimezone) }}{% else %}Unknown{% endif %}
                </div>
                <div class="flex flex-col sm:flex-row gap-2 sm:gap-3 w-full sm:w-auto">
                    <a href="/admin/users/{{ user._id }}" class="px-6 py-2 border border-border text-sm font-medium text-foreground bg-card hover:bg-muted text-center">
                        Cancel
                    </a>
                    <button type="submit" class="px-6 py-2 bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                        <i data-lucide="save" class="h-4 w-4 mr-2 inline"></i>
                        Save Changes
