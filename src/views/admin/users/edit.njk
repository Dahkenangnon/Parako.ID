{% extends "layouts/admin-layout.njk" %}

{% block admin_content %}
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Page Header -->
    <div class="mb-8">
        <nav class="flex mb-4" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-2 text-sm">
                <li>
                    <a href="/admin" class="text-muted-foreground hover:text-foreground">Admin</a>
                </li>
                <li class="text-muted-foreground">/</li>
                <li>
                    <a href="/admin/users" class="text-muted-foreground hover:text-foreground">Users</a>
                </li>
                <li class="text-muted-foreground">/</li>
                <li>
                    <a href="/admin/users/{{ user._id }}" class="text-muted-foreground hover:text-foreground">{{ user.name or user.username }}</a>
                </li>
                <li class="text-muted-foreground">/</li>
                <li class="text-foreground font-medium">Edit</li>
            </ol>
        </nav>

        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div class="flex-1">
                <h1 class="text-xl sm:text-2xl font-bold text-foreground">Edit User: {{ user.name or user.username }}</h1>
                <p class="mt-2 text-sm text-muted-foreground">Update user information and account settings</p>
            </div>
            <a href="/admin/users/{{ user._id }}" class="inline-flex items-center px-4 py-2 border border-border text-sm font-medium text-foreground bg-card hover:bg-muted w-full sm:w-auto justify-center">
                <i data-lucide="arrow-left" class="h-4 w-4 mr-2"></i>
                Back to User
            </a>
        </div>
    </div>

    <!-- Edit Form -->
    <form method="POST" action="/admin/users/{{ user._id }}/edit" class="space-y-6">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        <!-- Essential Information (Top Priority) -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                <i data-lucide="star" class="h-5 w-5 mr-2 text-primary"></i>
                Essential Information
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Username (readonly) -->
                <div>
                    <label for="username" class="block text-sm font-medium text-foreground mb-2">Username</label>
                    <input type="text" id="username" value="{{ user.username }}" readonly 
                           class="w-full px-3 py-2 bg-muted border border-border text-muted-foreground cursor-not-allowed">
                    <p class="mt-1 text-xs text-muted-foreground">Username cannot be changed</p>
                </div>

                <!-- Email -->
                <div>
                    <label for="email" class="block text-sm font-medium text-foreground mb-2">Email Address <span class="text-red-500">*</span></label>
                    <input type="email" id="email" name="email" value="{{ user.email }}" required
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- First Name -->
                <div>
                    <label for="given_name" class="block text-sm font-medium text-foreground mb-2">First Name <span class="text-red-500">*</span></label>
                    <input type="text" id="given_name" name="given_name" value="{{ user.given_name }}" required
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Last Name -->
                <div>
                    <label for="family_name" class="block text-sm font-medium text-foreground mb-2">Last Name <span class="text-red-500">*</span></label>
                    <input type="text" id="family_name" name="family_name" value="{{ user.family_name }}" required
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Custom Identifier Fields -->
                {% for ciField in customIdentifierFields %}
                <div>
                    <label for="custom_identifier_{{ ciField.slot }}" class="block text-sm font-medium text-foreground mb-2">{{ ciField.name }}</label>
                    <input type="text" id="custom_identifier_{{ ciField.slot }}" name="custom_identifier_{{ ciField.slot }}" value="{{ user['custom_identifier_' + ciField.slot] or '' }}"
                           placeholder="{{ ciField.hint_for_user or '' }}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    {% if ciField.hint_for_user %}
                    <p class="mt-1 text-xs text-muted-foreground">{{ ciField.hint_for_user }}</p>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- Account Settings -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                <i data-lucide="settings" class="h-5 w-5 mr-2 text-muted-foreground"></i>
                Account Settings
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Roles -->
                <div>
                    <label for="roles" class="block text-sm font-medium text-foreground mb-2">User Roles</label>
                    <select id="roles" name="roles" multiple size="5" 
                            class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        {% for role in roles %}
                        <option value="{{ role }}" {% if role in user.roles %}selected{% endif %}>
                            {{ role | title }}
                        </option>
                        {% endfor %}
                    </select>
                    <p class="mt-1 text-xs text-muted-foreground">Hold Ctrl (Cmd on Mac) to select multiple roles</p>
                </div>

                <!-- Account Status -->
                <div>
                    <label for="account_enabled" class="block text-sm font-medium text-foreground mb-2">Account Status</label>
                    <select id="account_enabled" name="account_enabled" 
                            class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        <option value="true" {% if user.account_enabled %}selected{% endif %}>Enabled</option>
                        <option value="false" {% if not user.account_enabled %}selected{% endif %}>Disabled</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Personal Information -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                <i data-lucide="user" class="h-5 w-5 mr-2 text-muted-foreground"></i>
                Personal Information
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Middle Name -->
                <div>
                    <label for="middle_name" class="block text-sm font-medium text-foreground mb-2">Middle Name</label>
                    <input type="text" id="middle_name" name="middle_name" value="{{ user.middle_name }}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Nickname -->
                <div>
                    <label for="nickname" class="block text-sm font-medium text-foreground mb-2">Nickname</label>
                    <input type="text" id="nickname" name="nickname" value="{{ user.nickname }}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>


                <!-- Gender -->
                <div>
                    <label for="gender" class="block text-sm font-medium text-foreground mb-2">Gender</label>
                    <select id="gender" name="gender" 
                            class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        <option value="">Select gender</option>
                        <option value="M" {% if user.gender == 'M' %}selected{% endif %}>Male</option>
                        <option value="F" {% if user.gender == 'F' %}selected{% endif %}>Female</option>
                    </select>
                </div>

                <!-- Birthdate -->
                <div>
                    <label for="birthdate" class="block text-sm font-medium text-foreground mb-2">Birthdate</label>
                    <input type="date" id="birthdate" name="birthdate" 
                           value="{% if user.birthdate %}{{ user.birthdate }}{% endif %}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Phone Number -->
                <div>
                    <label for="phone_number" class="block text-sm font-medium text-foreground mb-2">Phone Number</label>
                    <input type="tel" id="phone_number" name="phone_number" value="{{ user.phone_number }}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Profile URL -->
                <div>
                    <label for="profile" class="block text-sm font-medium text-foreground mb-2">Profile URL</label>
                    <input type="text" id="profile" name="profile" value="{{ user.profile }}"
                           placeholder="https://example.com/profile or /profile"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Website -->
                <div>
                    <label for="website" class="block text-sm font-medium text-foreground mb-2">Website</label>
                    <input type="text" id="website" name="website" value="{{ user.website }}"
                           placeholder="https://example.com or /website"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Picture URL -->
                <div>
                    <label for="picture" class="block text-sm font-medium text-foreground mb-2">Profile Picture URL</label>
                    <input type="text" id="picture" name="picture" value="{{ user.picture }}"
                           placeholder="https://example.com/avatar.jpg or /img/avatar.jpg"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>
            </div>
        </div>

        <!-- Location Information -->
        <div class="bg-card border border-border p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center">
                <i data-lucide="map-pin" class="h-5 w-5 mr-2 text-muted-foreground"></i>
                Location Information
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Country -->
                <div>
                    <label for="country" class="block text-sm font-medium text-foreground mb-2">Country</label>
                    <input type="text" id="country" name="country" value="{{ user.country }}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Region/State -->
                <div>
                    <label for="region" class="block text-sm font-medium text-foreground mb-2">Region/State</label>
                    <input type="text" id="region" name="region" value="{{ user.region }}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- City -->
                <div>
                    <label for="city" class="block text-sm font-medium text-foreground mb-2">City</label>
                    <input type="text" id="city" name="city" value="{{ user.city }}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Postal Code -->
                <div>
                    <label for="postal_code" class="block text-sm font-medium text-foreground mb-2">Postal Code</label>
                    <input type="text" id="postal_code" name="postal_code" value="{{ user.postal_code }}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Street Address -->
                <div class="md:col-span-2">
                    <label for="street_address" class="block text-sm font-medium text-foreground mb-2">Street Address</label>
                    <input type="text" id="street_address" name="street_address" value="{{ user.street_address }}"
                           class="w-full px-3 py-2 bg-background border border-border text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>

                <!-- Locale -->
                <div>
                    <label for="locale" class="block text-sm font-medium text-foreground mb-2">Locale</label>
                    <select id="locale" name="locale" 
                            class="w-full px-3 py-2 bg-background border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        {% for locale in app.locales.available %}
                        <option value="{{ locale }}" {% if user.locale == locale %}selected{% endif %}>
                            {{ 
                              {'en': 'English', 'fr': 'Français', 'es': 'Español', 'de': 'Deutsch', 
                               'it': 'Italiano', 'pt': 'Português', 'ru': 'Русский', 'zh': '中文', 
                               'ja': '日本語', 'ko': '한국어'}[locale] or locale | upper
                            }}
                        </option>
                        {% endfor %}
                    </select>
                </div>

                <!-- Timezone -->
                <div>
                    <label for="zoneinfo" class="block text-sm font-medium text-foreground mb-2">Timezone</label>
                    <select id="zoneinfo" name="zoneinfo"
