{% extends "layouts/auth-layout.njk" %}

{% block auth_content %}
                <div class="flex justify-center mb-2">
                    {{ image(branding.logo, { alt: app.title + " Logo", className: 'dark:hidden h-10 w-auto', loading: 'eager', fetchpriority: 'high' }) }}
                    {{ image(branding.logoDark, { alt: app.title + " Logo", className: 'hidden dark:block h-10 w-auto', loading: 'eager', fetchpriority: 'high' }) }}
                </div>

                <!-- Error Icon -->
                <div class="flex justify-center mb-3">
                    <div class="bg-indigo-50 dark:bg-indigo-900 border-2 border-indigo-200 dark:border-indigo-700 p-3">
                        <svg class="h-10 w-10 text-indigo-500 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                        </svg>
                    </div>
                </div>

                <!-- Error Content -->
                <div class="text-center mb-4">
                    <h1 class="auth-heading text-4xl font-bold text-gray-900 dark:text-foreground mb-1">401</h1>
                    <h2 class="text-lg font-semibold text-gray-800 dark:text-foreground mb-2">{{ t('common.error_page.401.title') }}</h2>
                    <p class="text-sm text-gray-600 dark:text-muted-foreground mb-3">{{ t('common.error_page.401.description') }}</p>

                    {% if errorDetails %}
                    <div class="mt-3 p-3 bg-indigo-50 dark:bg-indigo-900 border-2 border-indigo-200 dark:border-indigo-700 text-xs text-left text-gray-600 dark:text-muted-foreground font-mono overflow-x-auto max-h-24">
                        {{ errorDetails }}
                    </div>
                    {% endif %}
                </div>

                <!-- Action Buttons -->
                <div class="space-y-2">
                    <a href="{{ routes.authFull.login }}" class="auth-btn w-full h-9 bg-primary text-white font-semibold border-2 border-transparent focus:outline-none focus:border-2 focus:border-gray-900 dark:focus:border-white text-sm flex items-center justify-center">
                        {{ t('common.button.sign_in') }}
                    </a>
                    <a href="{{ urls.website or '/' }}" class="w-full h-9 bg-gray-100 dark:bg-muted border-2 border-gray-200 dark:border-border text-gray-700 dark:text-foreground font-semibold hover:bg-gray-200 dark:hover:bg-accent focus:outline-none text-sm flex items-center justify-center">
                        {{ t('common.button.go_home') }}
                    </a>
                </div>
{% endblock %}

{% block scripts %}
{{ super() }}
{% endblock %}
