{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "./src/assets/js",
    "outDir": "./public/js",
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": []
  },
  "include": ["src/assets/js/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "src/assets/js/sw/service-worker.ts"
  ]
}
