{
  "name": "parako.id",
  "version": "0.1.0",
  "description": "Self-hosted identity server with SSO, MFA, passkeys, and OAuth2 — zero per-user fees",
  "author": {
    "name": "Justin Dah-kenangnon",
    "email": "dah.kenangnon@gmail.com",
    "url": "https://github.com/Dahkenangnon"
  },
  "private": false,
  "license": "MIT",
  "homepage": "https://parako.id",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dahkenangnon/Parako.ID"
  },
  "bugs": {
    "url": "https://github.com/Dahkenangnon/Parako.ID/issues"
  },
  "maintainers": [
    "Justin Dah-kenangnon <dah.kenangnon@gmail.com>"
  ],
  "files": [
    "dist",
    "public",
    "runtime",
    "ecosystem.config.cjs",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "client": "./dist/scripts/manage/client.js",
    "keys": "./dist/scripts/manage/keys.js",
    "systemd": "./dist/scripts/manage/systemd.js"
  },
  "directories": {
    "lib": "dist/src",
    "bin": "dist/scripts/manage",
    "test": "test"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production node scripts/build.js",
    "dev": "node scripts/dev.js",
    "dev:worker": "node --watch-path=dist/src dist/src/worker.js",
    "dev:all": "node scripts/dev.js --with-worker",
    "start": "cross-env NODE_ENV=production pm2 start ecosystem.config.cjs && pm2 save",
    "restart": "cross-env NODE_ENV=production pm2 startOrRestart ecosystem.config.cjs && pm2 save",
    "prod:worker": "cross-env NODE_ENV=production pm2 start ecosystem.config.cjs --only parako-id-worker && pm2 save",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "lint:check": "npx eslint . --max-warnings 0",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "db:generate": "prisma generate --config=prisma.config.ts",
    "db:generate:pg": "prisma generate --config=prisma.config.pg.ts",
    "db:push": "prisma db push --config=prisma.config.ts",
    "db:migrate": "prisma migrate dev --config=prisma.config.pg.ts",
    "db:migrate:deploy": "prisma migrate deploy --config=prisma.config.pg.ts",
    "db:studio": "prisma studio --config=prisma.config.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "client": "node dist/scripts/manage/client.js",
    "keys": "node dist/scripts/manage/keys.js",
    "systemd": "node dist/scripts/manage/systemd.js",
    "build:release": "bash scripts/release.sh",
    "build:release:dry": "bash scripts/release.sh --dry-run --verbose",
    "postinstall": "prisma generate --config=prisma.config.ts",
    "prepare": "husky",
    "cm": "git-cz",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "keywords": [
    "oidc",
    "oauth2",
    "openid-connect",
    "identity-provider",
    "authentication",
    "authorization",
    "mfa",
    "2fa",
    "totp",
    "jwt",
    "jwks",
    "parako-id"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@fast-csv/format": "^5.0.5",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@simplewebauthn/server": "^13.2.3",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.70.4",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "compression": "^1.8.1",
    "connect-mongodb-session": "^5.0.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "hpp": "^0.2.3",
    "i18n": "^0.15.3",
    "inquirer": "8",
    "inversify": "^7.11.0",
    "ioredis": "^5.11.0",
    "jose": "^6.2.3",
    "jsonc-parser": "^3.3.1",
    "libphonenumber-js": "^1.12.38",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "nunjucks": "^3.2.4",
    "oidc-provider": "^9.8.4",
    "openid-client": "^6.8.4",
    "otplib": "^13.3.0",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "reflect-metadata": "^0.2.2",
    "twilio": "^5.12.2",
    "ua-parser-js": "^2.0.9",
    "yaml": "^2.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "@eslint/js": "^9.36.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@tailwindcss/cli": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.7.5",
    "@types/connect-mongodb-session": "^2.4.8",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.1",
    "@types/hpp": "^0.2.6",
    "@types/i18n": "^0.13.12",
    "@types/inquirer": "^9.0.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.1",
    "@types/nodemailer": "^7.0.1",
    "@types/nunjucks": "^3.2.6",
    "@types/oidc-provider": "^9.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "chokidar": "^4.0.3",
    "commitizen": "^4.3.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.36.0",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "koa": "^3.0.1",
    "mongodb-memory-server": "^11.0.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^24.2.9",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4"
  }
}
