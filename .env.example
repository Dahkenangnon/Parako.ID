# ===========================================
# Parako.ID Environment Configuration
# ===========================================
# Copy this file to .env and update the values.
# Sensitive values should NOT be committed to version control.
#
# Configuration Priority:
# 1. Environment variables (this file)
# 2. Database settings (admin panel)
# 3. Default values
# ===========================================

# -------------------------------------------
# CORE BOOTSTRAP SETTINGS (Required)
# -------------------------------------------
# These are essential for the application to start.
# They CANNOT be changed via admin panel - only via .env

# Application environment: development | staging | production
DEPLOYMENT_ENVIRONMENT=development

# Server port
DEPLOYMENT_SERVER_PORT=9007

# Base URL of this deployment (used to derive OIDC issuer, tenant URLs, etc.)
# In multi-tenant mode, tenant URLs are derived as https://{tenant}.{base_domain}
# Example: DEPLOYMENT_URL=https://parako.test → tenant issuer: https://acme.parako.test/oidc/v1
# Leave blank to use the database/file config value, or http://localhost:9007 default.
# DEPLOYMENT_URL=https://parako.test

# Main app storage adapter: mongodb | sqlite | postgresql (default: sqlite)
STORAGE_ADAPTER=sqlite

# MongoDB connection URI (required when STORAGE_ADAPTER=mongodb)
# STORAGE_MONGODB_URI=mongodb://localhost:27017/parako-id

# SQLite path (used when STORAGE_ADAPTER=sqlite)
STORAGE_SQLITE_PATH=./data/parako.db

# PostgreSQL URL (required when STORAGE_ADAPTER=postgresql)
# STORAGE_POSTGRESQL_URL=postgresql://postgres:postgres@localhost:5432/parako
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/parako  # Prisma CLI only — not read by the app
# PostgreSQL SSL: set to 'false' for self-signed certs (default: true in production)
# PG_SSL_REJECT_UNAUTHORIZED=true

# OIDC + session storage adapter (optional — defaults to STORAGE_ADAPTER value)
# mongodb | redis | sqlite | postgresql
# OIDC_STORAGE_ADAPTER=redis

# Redis connection (used for session store, BullMQ, pub/sub)
# Required when OIDC_STORAGE_ADAPTER=redis, also used by worker and pub/sub
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0

# -------------------------------------------
# MULTI-TENANCY
# -------------------------------------------
# Enable multi-tenant mode with per-tenant data isolation.
# When true: all data is scoped per tenant via ALS + Mongoose plugin + Prisma
# extension + PostgreSQL RLS. ConfigManager caches per-tenant settings.
# Sessions are bound to tenants to prevent cross-tenant hijacking.
# When false (default): everything runs as a single "default" tenant.
# NOTE: SQLite does NOT support multi-tenancy (no RLS). Use MongoDB or PostgreSQL.
MULTI_TENANCY_ENABLED=false

# Tenant extraction strategy — comma-separated, evaluated in order.
# Valid values: header, subdomain
# MULTI_TENANCY_EXTRACTION_PRIORITY=header,subdomain

# HTTP header used for tenant identification (when 'header' strategy is active)
# MULTI_TENANCY_TENANT_HEADER=x-tenant-id

# OIDC provider pool settings (one Provider instance per tenant)
# MULTI_TENANCY_PROVIDER_POOL_MAX_SIZE=50
# MULTI_TENANCY_PROVIDER_POOL_IDLE_TTL_MS=1800000
# MULTI_TENANCY_PROVIDER_POOL_CLEANUP_INTERVAL_MS=60000

# Bootstrap admin for _platforms master tenant (first startup only)
# Creates an initial platform admin user so you can log into _platforms.
# After first login, create a permanent admin and remove these credentials.
#
# PRODUCTION: Do NOT put these in .env — use shell-scoped export instead:
#   export PARAKO_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
#   export PARAKO_BOOTSTRAP_ADMIN_PASSWORD=your-secure-password-min-12-chars
#   yarn start
# The credentials only live in that shell session and are gone when it exits.
# Parako.ID logs a warning on every startup while these remain set.
#
# DEVELOPMENT: Setting them here is acceptable for convenience.
# PARAKO_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# PARAKO_BOOTSTRAP_ADMIN_PASSWORD=your-secure-password-min-12-chars

# -------------------------------------------
# ENCRYPTION
# -------------------------------------------
# Master encryption key for sensitive data in database
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 64 hex characters (32 bytes)
# CRITICAL: Backup this key - losing it means losing access to encrypted data
ENCRYPTION_KEY=your-64-character-hex-encryption-key-here-replace-me

# -------------------------------------------
# LOGGING SETTINGS
# -------------------------------------------
# These can also be managed via admin panel

# Enable logging
SECURITY_LOGGING_ENABLED=true

# Log level: trace | debug | info | warn | error | fatal
SECURITY_LOGGING_LEVEL=info

# Pretty print logs (recommended for development only)
SECURITY_LOGGING_PRETTY_PRINT=true

# File logging
SECURITY_LOGGING_FILE_LOGGING_ENABLED=true
SECURITY_LOGGING_FILE_LOGGING_DIRECTORY=logs

# -------------------------------------------
# SECRETS (used by config file ${VAR} interpolation)
# -------------------------------------------
# These are referenced from parako.yaml / parako.jsonc via ${VAR} syntax.
# When using file config (USE_FILE_CONFIG=true), set the secrets your config
# file references. Auto-generated at runtime if not set (for defaults only).

# JWT signing secret (min 32 chars). Generate with: openssl rand -hex 32
JWT_SECRET=
# Cookie encryption secrets (generate each with: openssl rand -hex 32)
COOKIE_SECRET_1=
COOKIE_SECRET_2=
# HMAC secret for cross-tenant OAuth state signing (min 32 chars). Generate with: openssl rand -hex 32
HMAC_SECRET=
# OIDC pairwise subject salt
PAIRWISE_SALT=
# Email server password
SMTP_PASSWORD=


# -------------------------------------------
# DEVELOPMENT OPTIONS
# -------------------------------------------

# Use parako.jsonc as config source instead of database
# Only works in development environment
# Note: You can manage settings from admin panel instead
USE_FILE_CONFIG=true

# -------------------------------------------
# EXTERNAL SERVICE API TOKENS (Optional)
# -------------------------------------------
# These tokens can alternatively be set via admin panel.
# Environment variables take precedence over database values.
# Leaving blank will use database values (if configured).

# IP Geolocation Service (ipinfo.io)
# Used for geolocation lookup, impossible travel detection
# Get a token at: https://ipinfo.io/signup
# IPINFO_API_TOKEN=your-ipinfo-token

# IP Reputation Service (IPQualityScore)
# Used for VPN/proxy detection, fraud scoring
# Get an API key at: https://www.ipqualityscore.com/create-account
# IPQUALITYSCORE_API_KEY=your-ipqualityscore-api-key
