{
  "_comment": "Example OIDC client (Relying Party) registry. Copy this file to parako-rp.jsonc, edit the entries, and Parako.ID will load them on next start. Each entry follows the OpenID Connect Dynamic Client Registration shape; only the fields shown below are commonly set — others fall back to defaults. For interactive client creation, run: pnpm client add",
  "version": "1.0.0",
  "created_at": 0,
  "updated_at": 0,
  "clients": [
    {
      "_comment": "Regular Web Application — server-rendered app with a confidential client_secret",
      "client_id": "example-web-app",
      "client_secret": "REPLACE_WITH_64_CHAR_RANDOM_STRING",
      "client_name": "Example Web App",
      "client_uri": "https://app.example.com",
      "logo_uri": "https://app.example.com/logo.png",
      "application_type": "web",
      "token_endpoint_auth_method": "client_secret_basic",
      "grant_types": ["authorization_code", "refresh_token"],
      "response_types": ["code"],
      "redirect_uris": [
        "https://app.example.com/callback",
        "http://localhost:3000/callback"
      ],
      "post_logout_redirect_uris": ["https://app.example.com/"],
      "scope": "openid profile email",
      "accessTokenFormat": "jwt",
      "require_pkce": false,
      "active": true,
      "preset": "web",
      "tags": ["production"]
    },
    {
      "_comment": "Single Page Application — public client, PKCE required, no client_secret",
      "client_id": "example-spa",
      "client_name": "Example SPA",
      "application_type": "spa",
      "token_endpoint_auth_method": "none",
      "grant_types": ["authorization_code", "refresh_token"],
      "response_types": ["code"],
      "redirect_uris": [
        "https://spa.example.com/callback",
        "http://localhost:5173/callback"
      ],
      "post_logout_redirect_uris": ["https://spa.example.com/"],
      "scope": "openid profile email",
      "accessTokenFormat": "jwt",
      "require_pkce": true,
      "active": true,
      "preset": "spa"
    },
    {
      "_comment": "Native / Mobile Application — public client, custom URI scheme for callback, PKCE required",
      "client_id": "example-mobile",
      "client_name": "Example Mobile App",
      "application_type": "native",
      "token_endpoint_auth_method": "none",
      "grant_types": ["authorization_code", "refresh_token"],
      "response_types": ["code"],
      "redirect_uris": ["com.example.app://callback"],
      "post_logout_redirect_uris": [],
      "scope": "openid profile email offline_access",
      "accessTokenFormat": "jwt",
      "require_pkce": true,
      "active": true,
      "preset": "native"
    },
    {
      "_comment": "Machine-to-Machine — backend service authenticating with its own credentials (no end-user)",
      "client_id": "example-m2m",
      "client_secret": "REPLACE_WITH_64_CHAR_RANDOM_STRING",
      "client_name": "Example Backend Service",
      "application_type": "web",
      "token_endpoint_auth_method": "client_secret_basic",
      "grant_types": ["client_credentials"],
      "response_types": [],
      "redirect_uris": [],
      "post_logout_redirect_uris": [],
      "scope": "parako:audit:read",
      "accessTokenFormat": "jwt",
      "active": true,
      "preset": "m2m",
      "isInternalClient": false
    }
  ]
}
